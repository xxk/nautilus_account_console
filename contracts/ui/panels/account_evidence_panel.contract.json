{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/ui/panels/account_evidence_panel.contract.json",
  "title": "Account Evidence Panel Read Model",
  "$comment": "Read-only evidence package projection; schema, checksum, run/session/trading day and raw payload refs are display evidence only, not runtime authority, ledger authority, source authority or action authority, and action_controls remains false through account_orders_panel boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workbench",
    "panel",
    "route",
    "fixture_state",
    "context",
    "account",
    "evidence_packages",
    "blockers",
    "source_refs",
    "boundaries",
    "rejection_rules"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "account_evidence_panel.v1" },
    "workbench": { "type": "string", "const": "Account Workbench" },
    "panel": { "type": "string", "const": "Account Evidence Panel" },
    "route": { "type": "string", "const": "/accounts/{account_id}/evidence" },
    "fixture_state": {
      "type": "string",
      "enum": ["current_evidence", "empty", "blocked", "stale", "partial"]
    },
    "context": { "$ref": "account_orders_panel.contract.json#/$defs/context" },
    "account": { "$ref": "account_orders_panel.contract.json#/$defs/account" },
    "evidence_packages": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_package" }
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "account_orders_panel.contract.json#/$defs/blocker" }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "account_orders_panel.contract.json#/$defs/source_ref" }
    },
    "boundaries": { "$ref": "account_orders_panel.contract.json#/$defs/boundaries" },
    "rejection_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "evidence_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "kind",
        "status",
        "owner",
        "schema_ref",
        "schema_version_ref",
        "checksum",
        "run_id",
        "session_id",
        "trading_day",
        "source_ref",
        "normalized_ref",
        "raw_payload_ref",
        "next_action"
      ],
      "properties": {
        "package_id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "order_lifecycle",
            "settlement",
            "equity_curve",
            "reconcile",
            "incident",
            "paper_slice",
            "owner_blocker"
          ]
        },
        "status": { "type": "string", "enum": ["current", "missing", "blocked", "stale", "partial"] },
        "owner": { "type": "string", "minLength": 1 },
        "schema_ref": { "type": "string", "minLength": 1 },
        "schema_version_ref": { "type": "string", "minLength": 1 },
        "checksum": { "$ref": "#/$defs/checksum" },
        "run_id": { "type": ["string", "null"] },
        "session_id": { "type": ["string", "null"] },
        "trading_day": { "type": ["string", "null"] },
        "source_ref": { "type": "string", "minLength": 1 },
        "normalized_ref": { "type": ["string", "null"] },
        "raw_payload_ref": { "type": ["string", "null"] },
        "next_action": { "type": "string", "minLength": 1 }
      }
    }
  }
}
