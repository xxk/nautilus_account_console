{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/ui/panels/account_positions_panel.contract.json",
  "title": "Account Positions Panel Read Model",
  "$comment": "Read-only positions projection; action_controls and all runtime/account/order/ledger/trading readiness boundaries remain false through account_orders_panel boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workbench",
    "panel",
    "route",
    "fixture_state",
    "context",
    "account",
    "positions",
    "blockers",
    "source_refs",
    "boundaries",
    "rejection_rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "account_positions_panel.v1"
    },
    "workbench": {
      "type": "string",
      "const": "Account Workbench"
    },
    "panel": {
      "type": "string",
      "const": "Account Positions Panel"
    },
    "route": {
      "type": "string",
      "const": "/accounts/{account_id}/positions"
    },
    "fixture_state": {
      "type": "string",
      "enum": ["current_positions", "empty", "blocked", "stale", "partial"]
    },
    "context": {
      "$ref": "account_orders_panel.contract.json#/$defs/context"
    },
    "account": {
      "$ref": "account_orders_panel.contract.json#/$defs/account"
    },
    "positions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/position_row"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "account_orders_panel.contract.json#/$defs/blocker"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "account_orders_panel.contract.json#/$defs/source_ref"
      }
    },
    "boundaries": {
      "$ref": "account_orders_panel.contract.json#/$defs/boundaries"
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "position_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_id",
        "instrument",
        "direction",
        "net_qty",
        "today_qty",
        "yesterday_qty",
        "available_qty",
        "frozen_qty",
        "average_price",
        "market_price",
        "market_value",
        "unrealized_pnl",
        "carryover_ref",
        "settlement_ref",
        "source_ref",
        "checksum"
      ],
      "properties": {
        "account_id": {
          "type": "string",
          "minLength": 1
        },
        "instrument": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "enum": ["LONG", "SHORT", "NET", "UNKNOWN"]
        },
        "net_qty": {
          "type": ["number", "null"]
        },
        "today_qty": {
          "type": ["number", "null"]
        },
        "yesterday_qty": {
          "type": ["number", "null"]
        },
        "available_qty": {
          "type": ["number", "null"]
        },
        "frozen_qty": {
          "type": ["number", "null"]
        },
        "average_price": {
          "type": ["number", "null"]
        },
        "market_price": {
          "type": ["number", "null"]
        },
        "market_value": {
          "type": ["number", "null"]
        },
        "unrealized_pnl": {
          "type": ["number", "null"]
        },
        "carryover_ref": {
          "type": ["string", "null"]
        },
        "settlement_ref": {
          "type": ["string", "null"]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    }
  }
}
