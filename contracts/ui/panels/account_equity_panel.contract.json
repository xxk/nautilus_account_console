{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/ui/panels/account_equity_panel.contract.json",
  "title": "Account Equity Panel Read Model",
  "$comment": "Read-only equity projection; action_controls and all runtime/account/order/ledger/trading readiness boundaries remain false through account_orders_panel boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workbench",
    "panel",
    "route",
    "fixture_state",
    "context",
    "account",
    "equity_points",
    "blockers",
    "source_refs",
    "boundaries",
    "rejection_rules"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "account_equity_panel.v1" },
    "workbench": { "type": "string", "const": "Account Workbench" },
    "panel": { "type": "string", "const": "Account Equity Panel" },
    "route": { "type": "string", "const": "/accounts/{account_id}/equity" },
    "fixture_state": {
      "type": "string",
      "enum": ["current_equity", "empty", "blocked", "stale", "partial"]
    },
    "context": { "$ref": "account_orders_panel.contract.json#/$defs/context" },
    "account": { "$ref": "account_orders_panel.contract.json#/$defs/account" },
    "equity_points": {
      "type": "array",
      "items": { "$ref": "#/$defs/equity_point" }
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "account_orders_panel.contract.json#/$defs/blocker" }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "account_orders_panel.contract.json#/$defs/source_ref" }
    },
    "boundaries": { "$ref": "account_orders_panel.contract.json#/$defs/boundaries" },
    "rejection_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "money_value": { "type": ["number", "null"] },
    "equity_point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "point_ts",
        "equity",
        "balance",
        "available_cash",
        "margin",
        "ledger_ref",
        "curve_ref",
        "source_ref",
        "checksum"
      ],
      "properties": {
        "point_ts": { "type": "string", "format": "date-time" },
        "equity": { "$ref": "#/$defs/money_value" },
        "balance": { "$ref": "#/$defs/money_value" },
        "available_cash": { "$ref": "#/$defs/money_value" },
        "margin": { "$ref": "#/$defs/money_value" },
        "ledger_ref": { "type": ["string", "null"] },
        "curve_ref": { "type": ["string", "null"] },
        "source_ref": { "type": "string", "minLength": 1 },
        "checksum": { "$ref": "#/$defs/checksum" }
      }
    }
  }
}
