{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/ui/panels/account_incidents_panel.contract.json",
  "title": "Account Incidents Panel Read Model",
  "$comment": "Read-only incident projection; incident owner and repair refs are operational display evidence only, not runtime authority or action authority, and action_controls remains false through account_orders_panel boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workbench",
    "panel",
    "route",
    "fixture_state",
    "context",
    "account",
    "incidents",
    "blockers",
    "source_refs",
    "boundaries",
    "rejection_rules"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "account_incidents_panel.v1" },
    "workbench": { "type": "string", "const": "Account Workbench" },
    "panel": { "type": "string", "const": "Account Incidents Panel" },
    "route": { "type": "string", "const": "/accounts/{account_id}/incidents" },
    "fixture_state": {
      "type": "string",
      "enum": ["active_incidents", "empty", "blocked", "stale", "partial"]
    },
    "context": { "$ref": "account_orders_panel.contract.json#/$defs/context" },
    "account": { "$ref": "account_orders_panel.contract.json#/$defs/account" },
    "incidents": {
      "type": "array",
      "items": { "$ref": "#/$defs/incident" }
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "account_orders_panel.contract.json#/$defs/blocker" }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "account_orders_panel.contract.json#/$defs/source_ref" }
    },
    "boundaries": { "$ref": "account_orders_panel.contract.json#/$defs/boundaries" },
    "rejection_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "incident": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "incident_id",
        "category",
        "severity",
        "status",
        "owner",
        "next_action",
        "repair_ref",
        "source_ref",
        "checksum"
      ],
      "properties": {
        "incident_id": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["outage", "stale_order", "reconcile_gap", "writer_failure", "source_blocker"]
        },
        "severity": { "type": "string", "enum": ["info", "warning", "high", "critical"] },
        "status": { "type": "string", "enum": ["open", "blocked", "stale", "partial", "resolved_projection"] },
        "owner": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string", "minLength": 1 },
        "repair_ref": { "type": ["string", "null"] },
        "source_ref": { "type": "string", "minLength": 1 },
        "checksum": { "$ref": "#/$defs/checksum" }
      }
    }
  }
}
