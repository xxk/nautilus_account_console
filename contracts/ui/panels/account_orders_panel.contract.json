{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/ui/panels/account_orders_panel.contract.json",
  "title": "Account Orders Panel Read Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workbench",
    "panel",
    "route",
    "fixture_state",
    "context",
    "account",
    "orders",
    "blockers",
    "source_refs",
    "boundaries",
    "rejection_rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "account_orders_panel.v1"
    },
    "workbench": {
      "type": "string",
      "const": "Account Workbench"
    },
    "panel": {
      "type": "string",
      "const": "Account Orders Panel"
    },
    "route": {
      "type": "string",
      "const": "/accounts/{account_id}/orders"
    },
    "fixture_state": {
      "type": "string",
      "enum": ["current_orders", "empty", "blocked", "stale"]
    },
    "context": {
      "$ref": "#/$defs/context"
    },
    "account": {
      "$ref": "#/$defs/account"
    },
    "orders": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/order_row"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blocker"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "boundaries": {
      "$ref": "#/$defs/boundaries"
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trading_day",
        "session_id",
        "run_id",
        "reducer_checkpoint_id",
        "reducer_checkpoint_ts",
        "stream_state",
        "projection_owner",
        "source_authority"
      ],
      "properties": {
        "trading_day": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "reducer_checkpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "reducer_checkpoint_ts": {
          "type": "string",
          "format": "date-time"
        },
        "stream_state": {
          "type": "string",
          "enum": ["healthy", "blocked", "stale", "partial", "empty", "warning"]
        },
        "projection_owner": {
          "type": "string",
          "const": "account-console-contracts"
        },
        "source_authority": {
          "type": "string",
          "enum": ["deterministic_fixture", "normalized_read_model", "typed_blocker"]
        }
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": ["account_id", "account_alias", "account_kind"],
      "properties": {
        "account_id": {
          "type": "string",
          "minLength": 1
        },
        "account_alias": {
          "type": "string",
          "minLength": 1
        },
        "account_kind": {
          "type": "string",
          "enum": ["sandbox_paper", "real_feed_sandbox_paper", "broker_paper_probe", "live_broker", "backtest_replay"]
        }
      }
    },
    "order_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_id",
        "client_order_id",
        "instrument",
        "side",
        "offset",
        "order_type",
        "limit_price",
        "quantity",
        "filled_quantity",
        "remaining_quantity",
        "status",
        "lifecycle_ref",
        "report_provenance_ref",
        "source_ref",
        "checksum"
      ],
      "properties": {
        "account_id": {
          "type": "string",
          "minLength": 1
        },
        "client_order_id": {
          "type": "string",
          "minLength": 1
        },
        "instrument": {
          "type": "string",
          "minLength": 1
        },
        "side": {
          "type": "string",
          "enum": ["BUY", "SELL"]
        },
        "offset": {
          "type": "string",
          "enum": ["OPEN", "CLOSE", "CLOSETODAY", "CLOSEYESTERDAY", "UNKNOWN"]
        },
        "order_type": {
          "type": "string",
          "enum": ["LIMIT", "MARKET", "UNKNOWN"]
        },
        "limit_price": {
          "type": ["number", "null"]
        },
        "quantity": {
          "type": ["number", "null"]
        },
        "filled_quantity": {
          "type": ["number", "null"]
        },
        "remaining_quantity": {
          "type": ["number", "null"]
        },
        "status": {
          "type": "string",
          "enum": ["filled", "working", "canceled", "rejected", "blocked", "stale", "unknown", "partial"]
        },
        "lifecycle_ref": {
          "type": ["string", "null"]
        },
        "report_provenance_ref": {
          "type": ["string", "null"]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "owner", "source_ref", "checksum", "authority"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "authority": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_id", "severity", "kind", "owner", "next_action", "source_ref", "checksum"],
      "properties": {
        "blocker_id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "high", "critical"]
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "next_action": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only_projection",
        "runtime_truth",
        "account_truth",
        "order_truth",
        "ledger_truth",
        "ui_truth",
        "paper_ready",
        "live_ready",
        "broker_tradable",
        "admission_truth",
        "capital_truth",
        "action_controls"
      ],
      "properties": {
        "read_only_projection": {
          "type": "boolean",
          "const": true
        },
        "runtime_truth": {
          "type": "boolean",
          "const": false
        },
        "account_truth": {
          "type": "boolean",
          "const": false
        },
        "order_truth": {
          "type": "boolean",
          "const": false
        },
        "ledger_truth": {
          "type": "boolean",
          "const": false
        },
        "ui_truth": {
          "type": "boolean",
          "const": false
        },
        "paper_ready": {
          "type": "boolean",
          "const": false
        },
        "live_ready": {
          "type": "boolean",
          "const": false
        },
        "broker_tradable": {
          "type": "boolean",
          "const": false
        },
        "admission_truth": {
          "type": "boolean",
          "const": false
        },
        "capital_truth": {
          "type": "boolean",
          "const": false
        },
        "action_controls": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
