{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/ui/panels/account_reconcile_panel.contract.json",
  "title": "Account Reconcile Panel Read Model",
  "$comment": "Read-only reconcile projection; mismatches, tolerances, owner and next action refs are display evidence only, not ledger or runtime authority, and action_controls remains false through account_orders_panel boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workbench",
    "panel",
    "route",
    "fixture_state",
    "context",
    "account",
    "reconcile_items",
    "blockers",
    "source_refs",
    "boundaries",
    "rejection_rules"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "account_reconcile_panel.v1" },
    "workbench": { "type": "string", "const": "Account Workbench" },
    "panel": { "type": "string", "const": "Account Reconcile Panel" },
    "route": { "type": "string", "const": "/accounts/{account_id}/reconcile" },
    "fixture_state": {
      "type": "string",
      "enum": ["matched", "empty", "mismatch", "stale", "partial"]
    },
    "context": { "$ref": "account_orders_panel.contract.json#/$defs/context" },
    "account": { "$ref": "account_orders_panel.contract.json#/$defs/account" },
    "reconcile_items": {
      "type": "array",
      "items": { "$ref": "#/$defs/reconcile_item" }
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "account_orders_panel.contract.json#/$defs/blocker" }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "account_orders_panel.contract.json#/$defs/source_ref" }
    },
    "boundaries": { "$ref": "account_orders_panel.contract.json#/$defs/boundaries" },
    "rejection_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "money_value": { "type": ["number", "null"] },
    "reconcile_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "category",
        "severity",
        "status",
        "expected_value",
        "observed_value",
        "delta",
        "tolerance_ref",
        "mismatch_ref",
        "owner",
        "next_action",
        "source_ref",
        "checksum"
      ],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["cash", "margin", "position", "order_lifecycle", "fee_tax", "settlement", "equity"]
        },
        "severity": { "type": "string", "enum": ["info", "warning", "high", "critical"] },
        "status": { "type": "string", "enum": ["matched", "mismatch", "blocked", "stale", "partial"] },
        "expected_value": { "$ref": "#/$defs/money_value" },
        "observed_value": { "$ref": "#/$defs/money_value" },
        "delta": { "$ref": "#/$defs/money_value" },
        "tolerance_ref": { "type": ["string", "null"] },
        "mismatch_ref": { "type": ["string", "null"] },
        "owner": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "checksum": { "$ref": "#/$defs/checksum" }
      }
    }
  }
}
