{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/ui/panels/p077_paper_slice_panel.contract.json",
  "title": "P077 Paper Slice Evidence Read Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workbench",
    "panel",
    "route",
    "fixture_state",
    "context",
    "slice",
    "evidence",
    "boundaries",
    "blockers"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "p077_paper_slice_panel.v1"
    },
    "workbench": {
      "type": "string",
      "const": "Order Observation"
    },
    "panel": {
      "type": "string",
      "const": "P077 Paper Slice Evidence Panel"
    },
    "route": {
      "type": "string",
      "const": "/orders/p077-paper-slice"
    },
    "fixture_state": {
      "type": "string",
      "enum": ["filled_reconciled", "blocked", "partial", "empty"]
    },
    "context": {
      "$ref": "#/$defs/context"
    },
    "slice": {
      "$ref": "#/$defs/slice"
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "boundaries": {
      "$ref": "#/$defs/boundaries"
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blocker"
      }
    }
  },
  "$defs": {
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trading_day",
        "session_id",
        "projection_owner",
        "producer_owner",
        "source_ref",
        "checksum",
        "schema_version",
        "rejection_rules"
      ],
      "properties": {
        "trading_day": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "projection_owner": {
          "type": "string",
          "const": "account-console-contracts"
        },
        "producer_owner": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "schema_version": {
          "type": "string",
          "minLength": 1
        },
        "rejection_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "slice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_alias",
        "instrument",
        "side",
        "quantity",
        "position_effect",
        "limit_price",
        "disposition",
        "fill_volume",
        "trade_price",
        "pre_position_qty",
        "post_position_qty",
        "observed_position_delta",
        "authorization_consumed",
        "active_authorization"
      ],
      "properties": {
        "account_alias": {
          "type": "string",
          "minLength": 1
        },
        "instrument": {
          "type": "string",
          "minLength": 1
        },
        "side": {
          "type": "string",
          "enum": ["BUY", "SELL"]
        },
        "quantity": {
          "type": "integer",
          "minimum": 1
        },
        "position_effect": {
          "type": "string",
          "enum": ["OPEN", "CLOSE", "CLOSETODAY", "CLOSEYESTERDAY"]
        },
        "limit_price": {
          "type": "number"
        },
        "disposition": {
          "type": "string",
          "enum": ["filled", "cancelled", "rejected", "blocked", "unknown"]
        },
        "fill_volume": {
          "type": "integer",
          "minimum": 0
        },
        "trade_price": {
          "type": ["number", "null"]
        },
        "pre_position_qty": {
          "type": "integer",
          "minimum": 0
        },
        "post_position_qty": {
          "type": "integer",
          "minimum": 0
        },
        "observed_position_delta": {
          "type": "integer"
        },
        "authorization_consumed": {
          "type": "boolean",
          "const": true
        },
        "active_authorization": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "owner", "source_ref", "checksum", "authority"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "authority": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only_projection",
        "runtime_truth",
        "ledger_truth",
        "ui_truth",
        "paper_ready",
        "live_ready",
        "broker_tradable",
        "admission_truth",
        "capital_truth"
      ],
      "properties": {
        "read_only_projection": {
          "type": "boolean",
          "const": true
        },
        "runtime_truth": {
          "type": "boolean",
          "const": false
        },
        "ledger_truth": {
          "type": "boolean",
          "const": false
        },
        "ui_truth": {
          "type": "boolean",
          "const": false
        },
        "paper_ready": {
          "type": "boolean",
          "const": false
        },
        "live_ready": {
          "type": "boolean",
          "const": false
        },
        "broker_tradable": {
          "type": "boolean",
          "const": false
        },
        "admission_truth": {
          "type": "boolean",
          "const": false
        },
        "capital_truth": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_id", "severity", "kind", "owner", "source_ref"],
      "properties": {
        "blocker_id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "high", "critical"]
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
