{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/ui/panels/account_summary_panel.contract.json",
  "title": "Account Summary Panel Read Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workbench",
    "panel",
    "route",
    "fixture_state",
    "context",
    "account",
    "balances",
    "pnl",
    "margin",
    "settlement",
    "positions",
    "blockers",
    "source_refs",
    "boundaries",
    "rejection_rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "account_summary_panel.v1"
    },
    "workbench": {
      "type": "string",
      "const": "Account Workbench"
    },
    "panel": {
      "type": "string",
      "const": "Account Summary Panel"
    },
    "route": {
      "type": "string",
      "const": "/accounts/{account_id}"
    },
    "fixture_state": {
      "type": "string",
      "enum": ["happy_path", "empty", "blocked", "stale", "partial"]
    },
    "context": {
      "$ref": "#/$defs/context"
    },
    "account": {
      "$ref": "#/$defs/account"
    },
    "balances": {
      "$ref": "#/$defs/balances"
    },
    "pnl": {
      "$ref": "#/$defs/pnl"
    },
    "margin": {
      "$ref": "#/$defs/margin"
    },
    "settlement": {
      "$ref": "#/$defs/settlement"
    },
    "positions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/position_summary"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blocker"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "boundaries": {
      "$ref": "#/$defs/boundaries"
    },
    "rejection_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "state_badge": {
      "type": "string",
      "enum": ["healthy", "blocked", "stale", "partial", "empty", "warning"]
    },
    "account_kind": {
      "type": "string",
      "enum": [
        "sandbox_paper",
        "real_feed_sandbox_paper",
        "broker_paper_probe",
        "live_broker",
        "backtest_replay"
      ]
    },
    "money_value": {
      "type": ["number", "null"]
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trading_day",
        "session_id",
        "run_id",
        "reducer_checkpoint_id",
        "reducer_checkpoint_ts",
        "stream_state",
        "projection_owner",
        "source_authority"
      ],
      "properties": {
        "trading_day": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "reducer_checkpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "reducer_checkpoint_ts": {
          "type": "string",
          "format": "date-time"
        },
        "stream_state": {
          "$ref": "#/$defs/state_badge"
        },
        "projection_owner": {
          "type": "string",
          "const": "account-console-contracts"
        },
        "source_authority": {
          "type": "string",
          "enum": ["deterministic_fixture", "normalized_read_model", "typed_blocker"]
        }
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_id",
        "account_alias",
        "account_kind",
        "portfolio_uid",
        "display_state",
        "base_currency"
      ],
      "properties": {
        "account_id": {
          "type": "string",
          "minLength": 1
        },
        "account_alias": {
          "type": "string",
          "minLength": 1
        },
        "account_kind": {
          "$ref": "#/$defs/account_kind"
        },
        "portfolio_uid": {
          "type": "string",
          "minLength": 1
        },
        "display_state": {
          "$ref": "#/$defs/state_badge"
        },
        "base_currency": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "balances": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cash", "frozen_cash", "available_cash", "buying_power"],
      "properties": {
        "cash": {
          "$ref": "#/$defs/money_value"
        },
        "frozen_cash": {
          "$ref": "#/$defs/money_value"
        },
        "available_cash": {
          "$ref": "#/$defs/money_value"
        },
        "buying_power": {
          "$ref": "#/$defs/money_value"
        }
      }
    },
    "pnl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["realized", "unrealized", "fees", "taxes"],
      "properties": {
        "realized": {
          "$ref": "#/$defs/money_value"
        },
        "unrealized": {
          "$ref": "#/$defs/money_value"
        },
        "fees": {
          "$ref": "#/$defs/money_value"
        },
        "taxes": {
          "$ref": "#/$defs/money_value"
        }
      }
    },
    "margin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_margin", "maintenance_margin", "margin_ratio"],
      "properties": {
        "initial_margin": {
          "$ref": "#/$defs/money_value"
        },
        "maintenance_margin": {
          "$ref": "#/$defs/money_value"
        },
        "margin_ratio": {
          "type": ["number", "null"],
          "minimum": 0
        }
      }
    },
    "settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "latest_settlement_ref", "position_carryover_ref"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["settled", "blocked", "stale", "partial", "missing"]
        },
        "latest_settlement_ref": {
          "type": ["string", "null"]
        },
        "position_carryover_ref": {
          "type": ["string", "null"]
        }
      }
    },
    "position_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instrument", "net_qty", "market_value", "source_ref", "checksum"],
      "properties": {
        "instrument": {
          "type": "string",
          "minLength": 1
        },
        "net_qty": {
          "type": ["number", "null"]
        },
        "market_value": {
          "$ref": "#/$defs/money_value"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_id", "severity", "kind", "owner", "next_action", "source_ref", "checksum"],
      "properties": {
        "blocker_id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "high", "critical"]
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "next_action": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "owner", "source_ref", "checksum", "authority"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "authority": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only_projection",
        "runtime_truth",
        "ledger_truth",
        "ui_truth",
        "paper_ready",
        "live_ready",
        "broker_tradable",
        "admission_truth",
        "capital_truth",
        "action_controls"
      ],
      "properties": {
        "read_only_projection": {
          "type": "boolean",
          "const": true
        },
        "runtime_truth": {
          "type": "boolean",
          "const": false
        },
        "ledger_truth": {
          "type": "boolean",
          "const": false
        },
        "ui_truth": {
          "type": "boolean",
          "const": false
        },
        "paper_ready": {
          "type": "boolean",
          "const": false
        },
        "live_ready": {
          "type": "boolean",
          "const": false
        },
        "broker_tradable": {
          "type": "boolean",
          "const": false
        },
        "admission_truth": {
          "type": "boolean",
          "const": false
        },
        "capital_truth": {
          "type": "boolean",
          "const": false
        },
        "action_controls": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
