{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/account_command/order_intent.schema.json",
  "title": "Account Command Order Intent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "intent_id",
    "account_id",
    "mode",
    "action",
    "instrument",
    "exchange",
    "side",
    "quantity",
    "order_type",
    "limit_price",
    "time_in_force",
    "offset",
    "idempotency_key",
    "operator_ref",
    "preflight_ref",
    "raw_secret_values_recorded",
    "raw_broker_endpoint_recorded"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "account_command.order_intent.v1" },
    "intent_id": { "type": "string", "pattern": "^intent\\.[a-z0-9_.-]+$" },
    "account_id": { "type": "string", "const": "acct.ctp.paper.19053" },
    "mode": { "type": "string", "enum": ["paper_armed", "live_dry_run", "live_armed"] },
    "action": { "type": "string", "const": "submit" },
    "instrument": { "type": "string", "minLength": 1 },
    "exchange": { "type": "string", "minLength": 1 },
    "side": { "type": "string", "enum": ["BUY", "SELL"] },
    "quantity": { "type": "integer", "minimum": 1 },
    "order_type": { "type": "string", "enum": ["LIMIT"] },
    "limit_price": { "type": "number", "exclusiveMinimum": 0 },
    "time_in_force": { "type": "string", "enum": ["GFD", "IOC", "FAK", "FOK"] },
    "offset": { "type": "string", "enum": ["OPEN", "CLOSE", "CLOSETODAY", "CLOSEYESTERDAY"] },
    "idempotency_key": { "type": "string", "minLength": 12 },
    "operator_ref": { "type": "string", "minLength": 1 },
    "preflight_ref": { "type": "string", "minLength": 1 },
    "raw_secret_values_recorded": { "type": "boolean", "const": false },
    "raw_broker_endpoint_recorded": { "type": "boolean", "const": false }
  }
}
