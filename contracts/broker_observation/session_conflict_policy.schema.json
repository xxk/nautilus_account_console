{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/broker_observation/session_conflict_policy.schema.json",
  "title": "Broker Observation Session Conflict Policy",
  "type": "object",
  "required": [
    "schema_version",
    "policy_id",
    "account_id",
    "source_kind",
    "session_owner",
    "raw_secret_values_recorded",
    "fail_closed",
    "conflict_keys",
    "unknown_owner_policy",
    "direct_session_allowed",
    "evaluations",
    "command"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "broker_observation_session_conflict_policy.v1" },
    "policy_id": { "type": "string" },
    "account_id": { "type": "string", "pattern": "^acct\\.[a-z0-9_.-]+$" },
    "source_kind": {
      "type": "string",
      "enum": [
        "ib_tws_observation",
        "ctp_observation",
        "stock_broker_observation",
        "cqg_observation",
        "tt_observation"
      ]
    },
    "session_owner": { "type": "string" },
    "raw_secret_values_recorded": { "type": "boolean", "const": false },
    "fail_closed": { "type": "boolean", "const": true },
    "conflict_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "broker_username_ref",
          "host_port_ref",
          "client_id_ref",
          "session_owner",
          "nautilus_trading_session_ref",
          "broker_connection_slot_ref"
        ]
      },
      "minItems": 4,
      "uniqueItems": true
    },
    "unknown_owner_policy": { "type": "string", "const": "blocked" },
    "direct_session_allowed": { "type": "boolean", "const": false },
    "evaluations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "input_refs",
          "decision",
          "blocker_id",
          "session_allowed",
          "reason",
          "next_action"
        ],
        "properties": {
          "case_id": { "type": "string" },
          "input_refs": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "decision": { "type": "string", "enum": ["blocked", "allowed"] },
          "blocker_id": { "type": ["string", "null"] },
          "session_allowed": { "type": "boolean" },
          "reason": { "type": "string" },
          "next_action": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "command": {
      "type": "object",
      "required": ["enabled", "allowed_actions"],
      "properties": {
        "enabled": { "type": "boolean", "const": false },
        "allowed_actions": {
          "type": "array",
          "maxItems": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
