{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nautilus.local/contracts/broker_observation/cross_broker_extension_matrix.schema.json",
  "title": "Broker Observation Cross Broker Extension Matrix",
  "type": "object",
  "required": [
    "schema_version",
    "matrix_id",
    "adr_id",
    "raw_secret_values_recorded",
    "canonical_contracts",
    "broker_rows",
    "extension_rules"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "broker_observation_cross_broker_extension_matrix.v1" },
    "matrix_id": { "type": "string" },
    "adr_id": { "type": "string", "const": "ADR-0005" },
    "raw_secret_values_recorded": { "type": "boolean", "const": false },
    "canonical_contracts": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "broker_observation_profile.v1",
          "broker_observation_session_conflict_policy.v1",
          "broker_observation_report_batch.v1",
          "broker_observation_freshness_sequence_checkpoint.v1",
          "broker_observation_store_snapshot.v1",
          "account_mirror_projection.v1"
        ]
      },
      "minItems": 6,
      "uniqueItems": true
    },
    "broker_rows": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "broker_family",
          "source_kind",
          "profile_contract",
          "report_contract",
          "store_contract",
          "freshness_contract",
          "projection_boundary",
          "command_allowed",
          "raw_secret_values_recorded",
          "status",
          "blocker_id"
        ],
        "properties": {
          "broker_family": { "type": "string", "enum": ["ib_tws", "ctp", "stock_broker", "cqg", "tt"] },
          "source_kind": {
            "type": "string",
            "enum": [
              "ib_tws_observation",
              "ctp_observation",
              "stock_broker_observation",
              "cqg_observation",
              "tt_observation"
            ]
          },
          "profile_contract": { "type": "string", "const": "broker_observation_profile.v1" },
          "report_contract": { "type": "string", "const": "broker_observation_report_batch.v1" },
          "store_contract": { "type": "string", "const": "broker_observation_store_snapshot.v1" },
          "freshness_contract": { "type": "string", "const": "broker_observation_freshness_sequence_checkpoint.v1" },
          "projection_boundary": { "type": "string", "const": "account_mirror" },
          "command_allowed": { "type": "boolean", "const": false },
          "raw_secret_values_recorded": { "type": "boolean", "const": false },
          "status": { "type": "string", "enum": ["pre_acceptance_blocked", "not_implemented_blocked", "implemented"] },
          "blocker_id": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "extension_rules": {
      "type": "object",
      "required": [
        "no_broker_specific_ui_truth",
        "no_command_from_observation",
        "no_raw_secret_material",
        "missing_adapter_blocks",
        "new_broker_must_extend_matrix"
      ],
      "properties": {
        "no_broker_specific_ui_truth": { "type": "boolean", "const": true },
        "no_command_from_observation": { "type": "boolean", "const": true },
        "no_raw_secret_material": { "type": "boolean", "const": true },
        "missing_adapter_blocks": { "type": "boolean", "const": true },
        "new_broker_must_extend_matrix": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
