{#- Renders the lazy paged browser for large record sets.
    Context variables:
      details_id, table_id, status_id, search_id         — DOM element ids
      filter_field_prefix, filter_value_prefix            — prefix strings for filter DOM ids
      jump_id, go_id, reset_id, context_toggle_id        — DOM element ids
      prev_id, next_id, columns_id, records_id           — DOM element ids
      page_size           — int, records per page
      filter_controls_html — pre-rendered filter control HTML (safe)
      hidden_columns_label — comma-joined hidden column names
      columns_json        — JSON string of column names (safe, raw JSON)
      records_json        — JSON string of all records (safe, raw JSON)
      column_widths_json  — JSON string of column width map (safe, raw JSON)
      hidden_columns_json — JSON string of hidden column list (safe, raw JSON)
      filter_count        — int, number of filter rows
-#}
<details class="fold-rest" id="{{ details_id }}">
<summary>打开分页浏览器 / Open paged browser</summary>
<div class="hint">当前记录量较大，完整明细改为展开后再解析，并且一次只渲染当前页 {{ page_size }} 条，避免浏览器在首屏阶段一次性创建海量 DOM 节点。</div>
<div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin:10px 0 12px;">
<input id="{{ search_id }}" type="search" placeholder="全局关键词 / Global keyword" style="min-width:280px;flex:1 1 280px;padding:6px 10px;border:1px solid #d0d7de;border-radius:8px;background:#fff;" />
</div>
<div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin:0 0 12px;">{{ filter_controls_html | safe }}</div>
<div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin:0 0 12px;">
<button type="button" id="{{ context_toggle_id }}" style="padding:6px 10px;border:1px solid #d0d7de;border-radius:8px;background:#fff;cursor:pointer;">显示上下文列 / Show context columns ({{ hidden_columns_label }})</button>
<button type="button" id="{{ prev_id }}" style="padding:6px 10px;border:1px solid #d0d7de;border-radius:8px;background:#fff;cursor:pointer;">上一页 / Prev</button>
<button type="button" id="{{ next_id }}" style="padding:6px 10px;border:1px solid #d0d7de;border-radius:8px;background:#fff;cursor:pointer;">下一页 / Next</button>
<input id="{{ jump_id }}" type="number" min="1" step="1" placeholder="页码" style="width:92px;padding:6px 10px;border:1px solid #d0d7de;border-radius:8px;background:#fff;" />
<button type="button" id="{{ go_id }}" style="padding:6px 10px;border:1px solid #d0d7de;border-radius:8px;background:#fff;cursor:pointer;">跳转 / Go</button>
<button type="button" id="{{ reset_id }}" style="padding:6px 10px;border:1px solid #d0d7de;border-radius:8px;background:#fff;cursor:pointer;">清空全部 / Reset filters</button>
<span id="{{ status_id }}" class="hint"></span>
</div>
<div id="{{ table_id }}"></div>
<script type="application/json" id="{{ columns_id }}">{{ columns_json | safe }}</script>
<script type="application/json" id="{{ records_id }}">{{ records_json | safe }}</script>
<script>(function(){var details=document.getElementById({{ details_id | tojson }});var tableRoot=document.getElementById({{ table_id | tojson }});var status=document.getElementById({{ status_id | tojson }});var search=document.getElementById({{ search_id | tojson }});var jump=document.getElementById({{ jump_id | tojson }});var go=document.getElementById({{ go_id | tojson }});var reset=document.getElementById({{ reset_id | tojson }});var contextToggle=document.getElementById({{ context_toggle_id | tojson }});var prev=document.getElementById({{ prev_id | tojson }});var next=document.getElementById({{ next_id | tojson }});var columnsNode=document.getElementById({{ columns_id | tojson }});var recordsNode=document.getElementById({{ records_id | tojson }});if(!details||!tableRoot||!status||!search||!jump||!go||!reset||!contextToggle||!prev||!next||!columnsNode||!recordsNode){return;}var pageSize={{ page_size }};var columnWidths={{ column_widths_json | safe }};var defaultHiddenColumns={{ hidden_columns_json | safe }};var filterFieldPrefix={{ filter_field_prefix | tojson }};var filterValuePrefix={{ filter_value_prefix | tojson }};var filterCount={{ filter_count }};var columns=null;var allRows=null;var filteredRows=[];var pageIndex=0;var initialized=false;var showContextColumns=false;function esc(value){if(value===null||value===undefined){return "-";}return String(value).replace(/[&<>"]/g,function(ch){if(ch==="&"){return "&amp;";}if(ch==="<"){return "&lt;";}if(ch===">"){return "&gt;";}return "&quot;";});}function headerStyle(column){var base="padding:6px 8px;font-size:.78rem;line-height:1.2;white-space:nowrap;";var width=columnWidths[column];return width?` style="${base}max-width:${width}px;width:${width}px;"`:` style="${base}"`;}function renderCell(column,value){var text=esc(value);var tdBase="padding:6px 8px;line-height:1.2;";var codeBase="display:inline-block;max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;vertical-align:top;padding:1px 4px;font-size:.78rem;line-height:1.15;";var width=columnWidths[column];if(!width){return `<td style="${tdBase}"><code style="${codeBase}">${text}</code></td>`;}return `<td style="${tdBase}max-width:${width}px;width:${width}px;"><code title="${text}" style="${codeBase}">${text}</code></td>`;}function getRenderColumns(){if(showContextColumns||defaultHiddenColumns.length===0){return columns;}return columns.filter(function(column){return defaultHiddenColumns.indexOf(column)===-1;});}function syncContextToggle(){if(defaultHiddenColumns.length===0){contextToggle.style.display="none";return;}var hiddenLabel=defaultHiddenColumns.join(", ");contextToggle.textContent=(showContextColumns?"隐藏上下文列 / Hide context columns (":"显示上下文列 / Show context columns (")+hiddenLabel+")";}function buildTable(renderRows){var renderColumns=getRenderColumns();var header="";for(var i=0;i<renderColumns.length;i+=1){header+=`<th${headerStyle(renderColumns[i])}>${esc(renderColumns[i])}</th>`;}var body="";for(var rowIndex=0;rowIndex<renderRows.length;rowIndex+=1){var row=renderRows[rowIndex];if(!row||typeof row!=="object"){body+=`<tr><td colspan="${renderColumns.length}"><code>${esc(row)}</code></td></tr>`;continue;}body+="<tr>";for(var colIndex=0;colIndex<renderColumns.length;colIndex+=1){var column=renderColumns[colIndex];body+=renderCell(column,row[column]);}body+="</tr>";}return `<div class="records-wrap" style="overflow-x:auto"><table style="font-size:.82rem;table-layout:auto;"><thead><tr>${header}</tr></thead><tbody>${body}</tbody></table></div>`;}function getFilterPairs(){var pairs=[];for(var i=0;i<filterCount;i+=1){var field=document.getElementById(filterFieldPrefix+"-"+i);var value=document.getElementById(filterValuePrefix+"-"+i);if(!field||!value){continue;}var query=(value.value||"").trim().toLowerCase();if(!query){continue;}pairs.push({field:(field.value||"").trim(),query:query});}return pairs;}function rowMatchesField(row,fieldName,query){if(!row||typeof row!=="object"){return String(row).toLowerCase().indexOf(query)!==-1;}if(fieldName){return String(row[fieldName]===undefined||row[fieldName]===null?"":row[fieldName]).toLowerCase().indexOf(query)!==-1;}for(var i=0;i<columns.length;i+=1){var cell=row[columns[i]];if(String(cell===undefined||cell===null?"":cell).toLowerCase().indexOf(query)!==-1){return true;}}return false;}function render(){var total=filteredRows.length;if(total===0){pageIndex=0;tableRoot.innerHTML=`<div class="hint">当前过滤条件下没有匹配记录。</div>`;status.textContent="过滤后 0 条记录";jump.value="";prev.disabled=true;next.disabled=true;go.disabled=true;syncContextToggle();return;}var totalPages=Math.max(Math.ceil(total/pageSize),1);if(pageIndex<0){pageIndex=0;}if(pageIndex>=totalPages){pageIndex=totalPages-1;}var start=pageIndex*pageSize;var end=Math.min(start+pageSize,total);tableRoot.innerHTML=buildTable(filteredRows.slice(start,end));status.textContent="第 "+(pageIndex+1)+" / "+totalPages+" 页，每页 "+pageSize+" 条，当前过滤后 "+total+" 条"+(defaultHiddenColumns.length&&!showContextColumns?"；默认隐藏列 "+defaultHiddenColumns.join(", "):"");jump.value=String(pageIndex+1);prev.disabled=pageIndex===0;next.disabled=pageIndex>=totalPages-1;go.disabled=false;syncContextToggle();return;}function applyFilter(){var globalQuery=(search.value||"").trim().toLowerCase();var filterPairs=getFilterPairs();filteredRows=allRows.filter(function(row){if(globalQuery&&!rowMatchesField(row,"",globalQuery)){return false;}for(var i=0;i<filterPairs.length;i+=1){if(!rowMatchesField(row,filterPairs[i].field,filterPairs[i].query)){return false;}}return true;});pageIndex=Math.max(Math.ceil(filteredRows.length/pageSize)-1,0);render();}function jumpToPage(){if(!initialized){initialize();}var totalPages=Math.max(Math.ceil(filteredRows.length/pageSize),1);var requested=parseInt(jump.value||"",10);if(Number.isNaN(requested)){jump.value=String(pageIndex+1);return;}pageIndex=Math.min(Math.max(requested-1,0),totalPages-1);render();}function resetFilters(){if(!initialized){initialize();}search.value="";for(var i=0;i<filterCount;i+=1){var fieldNode=document.getElementById(filterFieldPrefix+"-"+i);var valueNode=document.getElementById(filterValuePrefix+"-"+i);if(fieldNode){fieldNode.value="";}if(valueNode){valueNode.value="";}}filteredRows=allRows.slice();pageIndex=Math.max(Math.ceil(filteredRows.length/pageSize)-1,0);render();}function initialize(){if(initialized){return;}columns=JSON.parse(columnsNode.textContent||"[]");allRows=JSON.parse(recordsNode.textContent||"[]");filteredRows=allRows.slice();pageIndex=Math.max(Math.ceil(filteredRows.length/pageSize)-1,0);initialized=true;render();}details.addEventListener("toggle",function(){if(details.open){initialize();}});search.addEventListener("input",function(){if(!initialized){initialize();}applyFilter();});for(var filterIndex=0;filterIndex<filterCount;filterIndex+=1){(function(currentIndex){var fieldNode=document.getElementById(filterFieldPrefix+"-"+currentIndex);var valueNode=document.getElementById(filterValuePrefix+"-"+currentIndex);if(fieldNode){fieldNode.addEventListener("change",function(){if(!initialized){initialize();}applyFilter();});}if(valueNode){valueNode.addEventListener("input",function(){if(!initialized){initialize();}applyFilter();});}})(filterIndex);}contextToggle.addEventListener("click",function(){if(!initialized){initialize();}showContextColumns=!showContextColumns;render();});prev.addEventListener("click",function(){if(!initialized){initialize();}pageIndex-=1;render();});next.addEventListener("click",function(){if(!initialized){initialize();}pageIndex+=1;render();});go.addEventListener("click",jumpToPage);reset.addEventListener("click",resetFilters);jump.addEventListener("keydown",function(event){if(event.key==="Enter"){event.preventDefault();jumpToPage();}});})();</script>
</details>
