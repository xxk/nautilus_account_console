              {% endif %}
              {% if final_validation_plan_id and (final_report_href or final_curve_evidence_available) %}
                <div class="stage-evidence-meta" data-testid="final-validation-plan-id">validation_plan=<code>{{ final_validation_plan_id }}</code></div>
