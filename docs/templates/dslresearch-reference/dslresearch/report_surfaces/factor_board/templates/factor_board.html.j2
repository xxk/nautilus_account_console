                </select>
                <input name="reason" placeholder="决策原因 / reason" required />
                <button class="decision-submit" type="submit" data-testid="factor-decision-submit-{{ row.factor_key }}">记录 / Record</button>
                <span class="decision-status" data-decision-status></span>
              </form>
            {% else %}
              <span style="color:#98a2ad">需 source run</span>
            {% endif %}
          </td>
          <td data-col-group="decision" class="col-group-hidden">
            {% if row.next_action and row.next_action != "none" %}
              <span class="next-action-btn" data-testid="{{ row.field_testids.get('next_action_button', '') }}">{{ row.next_action }}</span>
            {% else %}
              <span class="next-action-none">—</span>
            {% endif %}
          </td>
          <td data-col-group="decision" class="col-group-hidden" style="max-width:320px;color:#57606a;font-size:.82rem">
            {{ row.decision_reason or "—" }}
            {% if row.lifecycle_decision_reason %}
              <br /><span data-testid="lifecycle-decision-reason">{{ row.lifecycle_decision_reason }}</span>
            {% endif %}
            {% if row.lifecycle_decision_disabled_reason_display is defined and row.lifecycle_decision_disabled_reason_display %}
              <br /><span data-testid="lifecycle-decision-disabled-reason">{{ row.lifecycle_decision_disabled_reason_display }}</span>
            {% endif %}
            {% if row.decision_gate %}
              <br /><code data-testid="decision-gate-reason">{{ row.decision_gate.reason }}</code>
            {% endif %}
            {% if row.strategy_contract_diff %}
              <details class="strategy-diff" data-testid="strategy-contract-diff">
                <summary>strategy_contract_diff</summary>
                {% for diff in row.strategy_contract_diff %}
                  <div><code>{{ diff.field }}</code>: <code>{{ diff.prescreen }}</code> → <code>{{ diff.final }}</code></div>
