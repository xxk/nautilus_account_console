              </div>
            {% endif %}
          </td>
          <td data-col-group="decision" class="col-group-hidden">
            {% if row.composite_uptake_count > 0 %}
              <span class="chip">{{ row.composite_uptake_count }} 个组合</span>
            {% else %}
              <span style="color:#98a2ad">0</span>
            {% endif %}
          </td>
          <td data-col-group="decision" class="col-group-hidden">
            <div class="decision-lane-stack" data-testid="decision-lane-stack">
              <div class="decision-lane" data-testid="decision-lane-eligibility" data-lane-source="decision_facet">
