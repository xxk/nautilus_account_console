    {% if assetization_advisory_lane %}
    <div class="assetization-readiness-summary" data-testid="assetization-advisory-lane">
      <div class="assetization-readiness-summary-item">
        <span class="assetization-readiness-summary-label">Gate Mode</span>
        <span class="assetization-readiness-summary-value">{{ assetization_advisory_lane.gate_mode }}</span>
      </div>
      <div class="assetization-readiness-summary-item">
        <span class="assetization-readiness-summary-label">Assetization Readiness</span>
        <span class="assetization-readiness-summary-value">{{ assetization_advisory_lane.assetization_readiness_label }}</span>
        <code>{{ assetization_advisory_lane.assetization_readiness }}</code>
      </div>
      <div class="assetization-readiness-summary-item">
        <span class="assetization-readiness-summary-label">Asset Decision</span>
        <span class="assetization-readiness-summary-value">{{ assetization_advisory_lane.asset_decision }}</span>
      </div>
      <div class="assetization-readiness-summary-item">
        <span class="assetization-readiness-summary-label">Production Admission Boundary</span>
        <span class="assetization-readiness-summary-value">{{ assetization_advisory_lane.production_admission }}</span>
        <div class="assetization-readiness-meta">{{ assetization_advisory_lane.production_admission_note }}</div>
      </div>
      <div class="assetization-readiness-summary-item" data-testid="assetization-advisory-research-view-boundary">
        <span class="assetization-readiness-summary-label">Research View Boundary</span>
        <span class="assetization-readiness-summary-value">research_view_only</span>
        <div class="assetization-readiness-meta">research/backtest evidence only; no production/admission/capital truth</div>
      </div>
      <div class="assetization-readiness-summary-item">
        <span class="assetization-readiness-summary-label">Global Inclusion</span>
        <span class="assetization-readiness-summary-value">{{ assetization_advisory_lane.successful_global }}</span>
      </div>
      <div class="assetization-readiness-summary-item">
        <span class="assetization-readiness-summary-label">Candidate set</span>
        <span class="assetization-readiness-summary-value">{{ assetization_advisory_lane.candidate_count_label }}</span>
        <div class="assetization-readiness-meta">
          {% for factor_key in assetization_advisory_lane.candidate_factors %}
          <code>{{ factor_key }}</code>
          {% endfor %}
        </div>
      </div>
      <div class="assetization-readiness-summary-item">
        <span class="assetization-readiness-summary-label">Excluded gaps</span>
        <span class="assetization-readiness-summary-value">{{ assetization_advisory_lane.excluded_gap_count_label }}</span>
        <div class="assetization-readiness-meta">
          {% for factor_key in assetization_advisory_lane.excluded_gap_factors %}
          <code>{{ factor_key }}</code>
          {% endfor %}
        </div>
      </div>
      <div class="assetization-readiness-summary-item">
        <span class="assetization-readiness-summary-label">Next action</span>
        <span class="assetization-readiness-summary-value">{{ assetization_advisory_lane.next_action }}</span>
