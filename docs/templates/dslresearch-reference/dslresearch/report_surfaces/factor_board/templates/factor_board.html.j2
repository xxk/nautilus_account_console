              </details>
            {% endif %}
            {% if row.decision_gate_display is defined and row.decision_gate_display.next_action_zh is defined and row.decision_gate_display.next_action_zh %}
              <br /><span data-testid="strategy-parity-next-action-zh">{{ row.decision_gate_display.next_action_zh }}</span>
            {% endif %}
          </td>
          <td data-col-group="evidence">
            {% if row.evidence_uri_link %}
              <a class="evidence-link" href="{{ row.evidence_uri_link }}" data-testid="{{ row.field_testids.get('evidence_uri_link', 'evidence-uri-link') }}">{{ row.evidence_uri }}</a>
            {% else %}
              <span style="color:#98a2ad">—</span>
            {% endif %}
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="empty-state">
    <h2>暂无因子候选 / No Factor Candidates</h2>
    <p>尚未发现任何候选因子（projection 位于 <code>RESEARCH_OUTPUT_DIR/governance/factor_candidate_projection.json</code>）。<br />
      请先通过 <code>python -m dslresearch sync-control-plane --case-id &lt;case-id&gt;</code> 生成投影文件。</p>
  </div>
  {% endif %}

