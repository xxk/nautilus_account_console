              {% set gate_display = row.decision_gate_display if row.decision_gate_display is defined else row.decision_gate %}
              <span class="decision-gate-badge {{ gate_display.badge_class if gate_display.badge_class is defined else row.decision_gate.status }}" data-testid="decision-gate-status">{{ gate_display.status_label if gate_display.status_label is defined else row.decision_gate.status }} · {{ row.decision_gate.reason }}</span>
