.factor-pipeline-status.blocked{border-color:var(--status-blocker-border);background:var(--status-blocker-bg);color:var(--status-blocker-text)}
.factor-pipeline-stage-meaning{font-size:.72rem;color:#475569;line-height:1.35;overflow-wrap:anywhere;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.factor-pipeline-stage-meaning.compact{font-size:.7rem;-webkit-line-clamp:2}
.factor-pipeline-stage-source{font-size:.68rem;color:#64748b;line-height:1.32;overflow-wrap:anywhere}
.factor-pipeline-stage-source summary{cursor:pointer;color:#0969da;font-weight:850;white-space:nowrap}
.factor-pipeline-stage-source-body{display:grid;gap:2px;margin-top:4px}
.factor-pipeline-stage-extra{display:grid;gap:3px;margin-top:3px;color:#475569;font-size:.68rem;line-height:1.32}
.factor-pipeline-stage-extra.compact{display:block}
.factor-pipeline-blocker-chip{display:inline-flex;width:max-content;max-width:100%;padding:2px 7px;border-radius:999px;border:1px solid var(--status-blocker-border);background:var(--status-blocker-bg);color:var(--status-blocker-text);font-size:.66rem;font-weight:900;overflow-wrap:anywhere}
.factor-pipeline-stage-extra a{color:#0969da;font-weight:850;text-decoration:none}
.factor-pipeline-stage-extra a:hover{text-decoration:underline}
@media(max-width:1100px){.factor-pipeline-rail{grid-template-columns:repeat(3,minmax(150px,1fr))}}
@media(max-width:700px){.claim-proof-strip,.factor-pipeline-rail{grid-template-columns:1fr}.factor-pipeline-stage{min-height:0}}
@media(max-width:900px){
  .hero{display:block}
  .shell{padding:14px 10px 24px}
  .factor-table{min-width:1900px}
  .assurance-strip{grid-template-columns:1fr}
  .assurance-trust-summary{grid-template-columns:1fr}
  .assurance-trust-metrics{justify-content:flex-start}
}
</style>
</head>
<body>
<div class="shell">
  <section class="hero">
    <div class="hero-left">
      <h1>因子生命周期看板 / Factor Lifecycle Board</h1>
      <p class="meta hero-title-meta" data-testid="factor-board-header-candidate-count">
        候选数 / Candidates: <strong>{{ candidate_count }}</strong>
        {% if include_retired %} · 含已退役 / incl. retired{% endif %}
      </p>
      <details class="projection-audit" data-testid="factor-board-header-audit">
        <summary>Projection audit / 投影审计</summary>
        <div class="projection-audit-body">
          <span>Schema <code data-testid="factor-board-audit-schema-version">v{{ schema_version }}</code></span>
          <span>Generated <code>{{ generated_at }}</code></span>
          <span>Source <code title="{{ projection_path }}">{{ projection_path }}</code></span>
        </div>
      </details>
    </div>
    <div class="hero-actions">
      {% if not filter_case_id %}
      <a class="portal-link" href="{{ successful_factor_global_uri }}" data-testid="factor-board-open-successful-factor-global">成功因子全局视图 / Successful Factor Global</a>
      {% endif %}
      {% if factor_decision_uri %}
      <span data-factor-decision-url="{{ factor_decision_uri }}" hidden></span>
      {% endif %}
      {% if sync_control_plane_uri %}
      <button class="sync-button" type="button" id="sync-control-plane-button" data-sync-url="{{ sync_control_plane_uri }}">
        同步控制面 / Sync
      </button>
      <span class="sync-status" id="sync-control-plane-status"></span>
      {% endif %}
      <a class="portal-link muted" href="{{ dev_home_uri }}">← 研发首页 / Dev Home</a>
    </div>
  </section>

  {% if claim_proof_surface_projection %}
  <section class="factor-pipeline claim-proof-shell" data-testid="factor-claim-proof-section">
    <h2 class="factor-pipeline-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="factor-claim-proof-case-ref">{{ display_case_ref }}</span>{% endif %}Gate Claim-Proof Summary</h2>
    <div class="claim-proof-strip"
      data-testid="factor-claim-proof-strip"
      data-research-completion-status="{{ claim_proof_surface_projection.research_completion.status }}"
      data-research-completion-rule="{{ claim_proof_surface_projection.research_completion.detail }}">
      <div class="claim-proof-primary {{ claim_proof_surface_projection.research_completion.status_class }}"
        data-testid="factor-claim-proof-summary"
        data-claim-proof-status="{{ claim_proof_surface_projection.research_completion.status }}"
        data-claim-status="{{ claim_proof_surface_projection.research_completion.claim_status }}"
        data-conflict-status="{{ claim_proof_surface_projection.research_completion.conflict_status }}">
        <span class="claim-proof-dot"></span>
        <span>Research:</span>
        <span class="claim-proof-status {{ claim_proof_surface_projection.research_completion.status_class }}">{{ claim_proof_surface_projection.research_completion.status }}</span>
        <span class="claim-proof-summary-detail">Proof: {{ claim_proof_surface_projection.research_completion.detail }}</span>
      </div>
      <div class="claim-proof-card" data-testid="factor-claim-proof-closeout"
        data-claim-status="{{ claim_proof_surface_projection.closeout.claim_status }}"
        data-conflict-status="{{ claim_proof_surface_projection.closeout.conflict_status }}"
        data-primary-blocker-check-id="{{ claim_proof_surface_projection.closeout.primary_blocker_check_id }}"
        data-primary-blocker-rule-id="{{ claim_proof_surface_projection.closeout.primary_blocker_rule_id }}"
        data-primary-blocker-evidence-ref="{{ claim_proof_surface_projection.closeout.primary_blocker_evidence_ref }}">
        <span class="claim-proof-label">{{ claim_proof_surface_projection.closeout.label }}</span>
        <span class="claim-proof-status {{ claim_proof_surface_projection.closeout.status_class }}">{{ claim_proof_surface_projection.closeout.status }}</span>
        <span class="claim-proof-owner">{{ claim_proof_surface_projection.closeout.owner }}</span>
        <span class="claim-proof-proof">
          <span><strong>Claim:</strong> {{ claim_proof_surface_projection.closeout.claim_status }}</span>
          <span><strong>Proof:</strong> {{ claim_proof_surface_projection.closeout.proof_summary }}</span>
          {% if claim_proof_surface_projection.closeout.primary_blocker != "none" %}
          <span><strong>Blocker:</strong> {{ claim_proof_surface_projection.closeout.primary_blocker }}</span>
          {% if claim_proof_surface_projection.closeout.primary_blocker_rule_id and claim_proof_surface_projection.closeout.primary_blocker_rule_id != "MISSING_RULE_ID" %}
          <span><strong>Rule:</strong> <code>{{ claim_proof_surface_projection.closeout.primary_blocker_rule_id }}</code></span>
          {% endif %}
          {% if claim_proof_surface_projection.closeout.primary_blocker_evidence_ref %}
          <span><strong>Evidence:</strong> <code>{{ claim_proof_surface_projection.closeout.primary_blocker_evidence_ref }}</code></span>
          {% endif %}
          <span><strong>Owner:</strong> {{ claim_proof_surface_projection.closeout.primary_blocker_owner }}</span>
          <span><strong>Next:</strong> {{ claim_proof_surface_projection.closeout.next_action }}</span>
          {% if claim_proof_surface_projection.closeout.primary_blocker_rule_id == "MISSING_RULE_ID" %}
          <span><strong>Rule identity missing</strong></span>
          {% endif %}
          {% endif %}
        </span>
      </div>
      <div class="claim-proof-card" data-testid="factor-claim-proof-readiness"
        data-claim-status="{{ claim_proof_surface_projection.readiness.claim_status }}"
        data-conflict-status="{{ claim_proof_surface_projection.readiness.conflict_status }}"
        data-primary-blocker-check-id="{{ claim_proof_surface_projection.readiness.primary_blocker_check_id }}"
        data-primary-blocker-rule-id="{{ claim_proof_surface_projection.readiness.primary_blocker_rule_id }}"
        data-primary-blocker-evidence-ref="{{ claim_proof_surface_projection.readiness.primary_blocker_evidence_ref }}">
        <span class="claim-proof-label">{{ claim_proof_surface_projection.readiness.label }}</span>
        <span class="claim-proof-status {{ claim_proof_surface_projection.readiness.status_class }}">{{ claim_proof_surface_projection.readiness.status }}</span>
        <span class="claim-proof-owner">{{ claim_proof_surface_projection.readiness.owner }}</span>
        <span class="claim-proof-proof">
          <span><strong>Claim:</strong> {{ claim_proof_surface_projection.readiness.claim_status }}</span>
          <span><strong>Proof:</strong> {{ claim_proof_surface_projection.readiness.proof_summary }}</span>
          {% if claim_proof_surface_projection.readiness.primary_blocker != "none" %}
          <span><strong>Blocker:</strong> {{ claim_proof_surface_projection.readiness.primary_blocker }}</span>
          {% if claim_proof_surface_projection.readiness.primary_blocker_rule_id and claim_proof_surface_projection.readiness.primary_blocker_rule_id != "MISSING_RULE_ID" %}
          <span><strong>Rule:</strong> <code>{{ claim_proof_surface_projection.readiness.primary_blocker_rule_id }}</code></span>
          {% endif %}
          {% if claim_proof_surface_projection.readiness.primary_blocker_evidence_ref %}
          <span><strong>Evidence:</strong> <code>{{ claim_proof_surface_projection.readiness.primary_blocker_evidence_ref }}</code></span>
          {% endif %}
          <span><strong>Owner:</strong> {{ claim_proof_surface_projection.readiness.primary_blocker_owner }}</span>
          <span><strong>Next:</strong> {{ claim_proof_surface_projection.readiness.next_action }}</span>
          {% if claim_proof_surface_projection.readiness.primary_blocker_rule_id == "MISSING_RULE_ID" %}
          <span><strong>Rule identity missing</strong></span>
          {% endif %}
          {% endif %}
        </span>
      </div>
    </div>
  </section>
  {% endif %}

  {% if research_quality_analysis %}
  <section
    class="factor-pipeline"
    id="research-quality-analysis"
    data-testid="factor-board-research-quality-analysis"
    data-analysis-status="{{ research_quality_analysis.status }}"
    data-typed-blocker-count="{{ research_quality_analysis.typed_blockers|length }}"
  >
    <h2 class="factor-pipeline-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="research-quality-analysis-case-ref">{{ display_case_ref }}</span>{% endif %}研究质量分析 / Research Quality Analysis</h2>
    <div class="research-view-banner" data-testid="research-quality-analysis-boundary">
      <span class="research-view-badge">Analysis Evidence / 分析证据</span>
      <span>{{ research_quality_analysis.boundary }}</span>
    </div>
    {% if research_quality_analysis.typed_blockers %}
    <div class="factor-pipeline-blocker" data-testid="research-quality-analysis-typed-blockers">
      <div>Typed blockers surfaced from analysis evidence:</div>
      {% for blocker in research_quality_analysis.typed_blockers %}
      <code>{{ blocker }}</code>
      {% endfor %}
    </div>
    {% endif %}
    <div class="factor-pipeline-rail" data-testid="research-quality-analysis-artifacts">
      {% for artifact in research_quality_analysis.artifacts %}
      <article class="factor-pipeline-stage research" data-testid="research-quality-analysis-artifact" data-analysis-kind="{{ artifact.analysis_kind }}" data-analysis-status="{{ artifact.status }}">
        <div class="factor-pipeline-stage-label">{{ artifact.analysis_kind }}</div>
        <span class="factor-pipeline-status {% if artifact.typed_blockers %}blocked{% else %}ready{% endif %}">{{ artifact.status }}</span>
        <div class="factor-pipeline-stage-meaning compact">
          <code>{{ artifact.file_name }}</code>
        </div>
        <div class="factor-pipeline-stage-extra compact">
          <code>artifact_class={{ artifact.artifact_class }}</code>
          <code>candidate_count={{ artifact.candidate_count }}</code>
          <code>not_owner_decision={{ artifact.not_owner_decision }}</code>
          {% for blocker in artifact.typed_blockers %}
          <span class="factor-pipeline-blocker-chip">{{ blocker }}</span>
          {% endfor %}
          {% if artifact.evidence_href %}
          <a href="{{ artifact.evidence_href }}" title="{{ artifact.evidence_ref }}">Open evidence</a>
          {% else %}
          <code title="{{ artifact.evidence_ref }}">{{ artifact.evidence_ref }}</code>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if factor_research_pipeline %}
  <section class="factor-pipeline" data-testid="factor-research-pipeline-section">
    <h2 class="factor-pipeline-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="factor-research-pipeline-case-ref">{{ display_case_ref }}</span>{% endif %}因子研发进度 / Factor Research Pipeline</h2>
    <div class="research-view-banner" data-testid="factor-board-research-view-banner">
      <span class="research-view-badge">Research View / 研发视角</span>
      <span>Research/backtest evidence only; not production admission, paper/live, capital allocation, or asset decision.</span>
    </div>
    <div class="factor-pipeline-summary" data-testid="factor-research-pipeline-summary">
      <div class="factor-pipeline-summary-item">
        <span class="factor-pipeline-summary-label">候选因子 / Candidate</span>
        <span class="factor-pipeline-summary-value">{{ factor_research_pipeline.summary.candidate_identity }}</span>
      </div>
      <div class="factor-pipeline-summary-item">
        <span class="factor-pipeline-summary-label">当前里程碑 / Current Milestone</span>
        <span class="factor-pipeline-summary-value">{{ factor_research_pipeline.summary.current_milestone }} · {{ factor_research_pipeline.summary.current_status }}</span>
      </div>
      <div class="factor-pipeline-summary-item">
        <span class="factor-pipeline-summary-label">含义 / Meaning</span>
        <span class="factor-pipeline-summary-value">{{ factor_research_pipeline.summary.meaning }}</span>
      </div>
      <div class="factor-pipeline-summary-item">
        <span class="factor-pipeline-summary-label">下一 Owner 动作 / Next Owner Action</span>
        <span class="factor-pipeline-summary-value" data-next-action-code="{{ factor_research_pipeline.summary.next_owner_action_code }}">{{ factor_research_pipeline.summary.next_owner_action }}</span>
        {% if factor_research_pipeline.summary.next_owner_action_owner %}
        <span class="factor-pipeline-summary-value">owner={{ factor_research_pipeline.summary.next_owner_action_owner }}</span>
        {% endif %}
      </div>
      <div class="factor-pipeline-summary-item">
        <span class="factor-pipeline-summary-label">目标因子数 / Target Factors</span>
        <span class="factor-pipeline-summary-value">factors={{ factor_research_pipeline.summary.factor_count }}</span>
      </div>
      <div class="factor-pipeline-summary-item" data-testid="factor-research-effect-summary">
        <span class="factor-pipeline-summary-label">研究效果 / Research Effect</span>
        <span class="factor-pipeline-summary-value">{{ factor_research_pipeline.summary.research_effect_status }} · {{ factor_research_pipeline.summary.research_effect_next_action }}</span>
        <span class="factor-pipeline-summary-value">{{ factor_research_pipeline.summary.research_effect_meaning }}</span>
        {% if factor_research_pipeline.summary.research_effect_report_href %}
        <a class="evidence-link" data-testid="factor-research-effect-report-link" href="{{ factor_research_pipeline.summary.research_effect_report_href }}">打开研究效果报告 / Open research-only effect report</a>
        {% else %}
        <span class="evidence-link disabled" data-testid="factor-research-effect-report-unavailable">research_only_report=missing</span>
        {% endif %}
      </div>
      <div class="factor-pipeline-summary-item" data-testid="factor-formal-readiness-summary">
        <span class="factor-pipeline-summary-label">正式就绪 / Formal Readiness</span>
        <span class="factor-pipeline-summary-value">{{ factor_research_pipeline.summary.formal_readiness_status }}</span>
      </div>
    </div>
    {% if factor_research_pipeline.summary.blocking_stage in ["source_input", "compiled_input", "candidate_trials", "assetization_readiness", "backtestable_portfolio"] %}
    <div class="factor-pipeline-blocker" data-testid="factor-pipeline-current-blocker-summary">
      <div>当前卡点 / Current blocker: {{ factor_research_pipeline.summary.current_milestone }} · {{ factor_research_pipeline.summary.current_status }}</div>
      {% if factor_research_pipeline.summary.blocking_stage == "backtestable_portfolio" %}
      <div>Formal backtest waits for a canonical Backtestable Portfolio package with dual-scope verifier findings.</div>
      <div>Allowed now: <code>research_only</code> effect analysis and readiness review. Not allowed: production approval, portfolio admission, paper/live, capital allocation, or asset decision.</div>
      {% elif factor_research_pipeline.summary.blocking_stage == "assetization_readiness" %}
      <div>Formal backtest waits for Assetization Readiness / candidate_ready evidence.</div>
      <div>Allowed now: <code>research_only</code> effect analysis. Not allowed: formal portfolio readiness, production approval, portfolio admission, paper/live, capital allocation, or asset decision.</div>
      {% else %}
      <div>Resolve {{ factor_research_pipeline.summary.current_milestone }} before formal backtest readiness can be claimed.</div>
      <div>Allowed now: inspect available evidence. Not allowed: formal portfolio readiness, production approval, portfolio admission, paper/live, capital allocation, or asset decision.</div>
      {% endif %}
    </div>
    {% endif %}
    <div class="factor-pipeline-rail" data-testid="factor-research-pipeline-rail">
      {% for stage in factor_research_pipeline.stages %}
      {% if stage.stage_id == "source_input" %}
      <div class="factor-pipeline-lane-heading research" data-testid="factor-pipeline-research-lane-heading">
        <span>Research Lane</span>
        <span>研发主线 / evidence to formal backtest</span>
      </div>
      {% endif %}
      {% if stage.stage_id == "backtestable_portfolio" %}
      <div class="factor-pipeline-gate-divider" data-testid="factor-pipeline-formal-backtest-handoff">
        <strong>{% if stage.status == "backtest_ready" %}正式回测交接{% else %}Formal Backtest Handoff{% endif %}</strong>
        <span class="factor-pipeline-gate-chip">current={{ stage.status }}</span>
        {% if stage.status == "backtest_ready" %}
        <span>回测包已就绪</span>
        <span>下游评审所需证据已完整</span>
        <span>尚未形成准入或资产决策</span>
        {% else %}
        <span>requires candidate_ready + readiness evidence</span>
        <span>next: OOS / cost / capacity + dual-scope findings</span>
        {% endif %}
      </div>
      {% endif %}
      {% if stage.stage_id == "production_admission" %}
      <div class="factor-pipeline-lane-heading downstream" data-testid="factor-pipeline-downstream-lane-heading">
        <span>Downstream Governance</span>
        <span>approval / decision projections</span>
      </div>
      {% if factor_research_pipeline.summary.current_status != "backtest_ready" and factor_research_pipeline.summary.formal_readiness_status == "backtest_ready" %}
      <div class="factor-pipeline-downstream-pending" data-testid="factor-pipeline-downstream-governance-pending">
        <div>下游治理待办 / Downstream governance pending: {{ factor_research_pipeline.summary.current_milestone }} · {{ factor_research_pipeline.summary.current_status }}</div>
        <div>Formal backtest is ready; remaining approval or asset-decision fields are downstream projections.</div>
        <div>Allowed now: inspect formal reports and research-only analysis. Not claimed: <code>approved</code> or asset decision.</div>
      </div>
      {% endif %}
      {% endif %}
      <article class="factor-pipeline-stage {{ stage.lane_class }}" data-testid="factor-research-pipeline-stage" data-stage-id="{{ stage.stage_id }}" data-lane="{{ stage.lane }}">
        <div class="factor-pipeline-stage-label">{{ stage.label }}</div>
        <span class="factor-pipeline-status {{ stage.status_class }}">{{ stage.status }}</span>
        <div class="factor-pipeline-stage-meaning{% if stage.stage_id == "backtestable_portfolio" %} compact{% endif %}">
          {% if stage.stage_id == "backtestable_portfolio" and stage.status != "backtest_ready" %}
          canonical findings required; reports are derived
          {% else %}
          {{ stage.meaning }}
          {% endif %}
        </div>
        {% if stage.stage_id == "assetization_readiness" and assetization_readiness and assetization_readiness.summary %}
        <div class="factor-pipeline-stage-extra" data-testid="factor-pipeline-assetization-summary">
          <div>Retained Final: {{ assetization_readiness.summary.retained_final }}</div>
          <div>OOS Ready: {{ assetization_readiness.summary.oos_ready }} · Cost Ready: {{ assetization_readiness.summary.cost_ready }}</div>
          <div>Capacity Ready: {{ assetization_readiness.summary.capacity_ready }} · Uplift Ready: {{ assetization_readiness.summary.uplift_ready }}</div>
          <a href="#assetization-readiness-detail">View readiness detail</a>
        </div>
        {% endif %}
        {% if stage.stage_id == "backtestable_portfolio" and stage.status != "backtest_ready" %}
        <div class="factor-pipeline-stage-extra compact" data-testid="factor-pipeline-backtest-blocked-by-readiness">
          <span class="factor-pipeline-blocker-chip">blocked: readiness / candidate_ready / findings</span>
        </div>
        {% endif %}
        <details class="factor-pipeline-stage-source" data-testid="factor-pipeline-stage-source-detail">
          <summary>Trace</summary>
          <div class="factor-pipeline-stage-source-body">
            <div>source_kind={{ stage.source_kind }}</div>
            {% if stage.source_ref %}<div>source_ref={{ stage.source_ref }}</div>{% endif %}
            {% if stage.missing_reason %}<div>missing_reason={{ stage.missing_reason }}</div>{% endif %}
          </div>
        </details>
      </article>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if ai_execution_context %}
  <section class="factor-pipeline" data-testid="factor-board-ai-execution-context">
    <h2 class="factor-pipeline-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="factor-board-ai-execution-context-case-ref">{{ display_case_ref }}</span>{% endif %}AI 推进信息 / AI Execution Context</h2>
    <div class="factor-pipeline-summary" data-testid="factor-board-ai-execution-context-summary">
      <div class="factor-pipeline-summary-item" data-testid="factor-board-ai-execution-runner">
        <span class="factor-pipeline-summary-label">Runner</span>
        {% if ai_execution_context.adapter_key %}<span class="factor-pipeline-summary-value"><code>{{ ai_execution_context.adapter_key }}</code></span>{% endif %}
        {% if ai_execution_context.runner_family and ai_execution_context.runner_family != ai_execution_context.adapter_key %}<span class="factor-pipeline-summary-value">family=<code>{{ ai_execution_context.runner_family }}</code></span>{% endif %}
        {% if ai_execution_context.invocation_mode %}<span class="factor-pipeline-summary-value">mode=<code>{{ ai_execution_context.invocation_mode }}</code></span>{% endif %}
        {% if ai_execution_context.terminal_state %}<span class="factor-pipeline-summary-value">terminal=<code>{{ ai_execution_context.terminal_state }}</code></span>{% endif %}
        {% if ai_execution_context.runner_command %}<span class="factor-pipeline-summary-value"><code>{{ ai_execution_context.runner_command }}</code></span>{% endif %}
      </div>
      {% if ai_execution_context.freshness %}
      <div class="factor-pipeline-summary-item" data-testid="factor-board-ai-execution-freshness">
        <span class="factor-pipeline-summary-label">Read-model</span>
        {% if ai_execution_context.freshness.materialization_batch %}<span class="factor-pipeline-summary-value">materialization_batch=<code>{{ ai_execution_context.freshness.materialization_batch }}</code></span>{% endif %}
        {% if ai_execution_context.freshness.source_fingerprint %}<span class="factor-pipeline-summary-value">source_fingerprint=<code>{{ ai_execution_context.freshness.source_fingerprint }}</code></span>{% endif %}
        {% if ai_execution_context.freshness.materialized_at %}<span class="factor-pipeline-summary-value">materialized_at=<code>{{ ai_execution_context.freshness.materialized_at }}</code></span>{% endif %}
      </div>
      {% endif %}
      {% if ai_execution_context.gates %}
      <div class="factor-pipeline-summary-item" data-testid="factor-board-ai-execution-gates">
        <span class="factor-pipeline-summary-label">Gate</span>
        {% for gate in ai_execution_context.gates %}
        <span class="factor-pipeline-summary-value">{{ gate.label }}{% if gate.state %}: <code>{{ gate.state }}</code>{% endif %}</span>
        {% if gate.proof %}<span class="semantic-line">{{ gate.proof }}</span>{% endif %}
        {% if gate.primary %}<span class="semantic-line">{{ gate.primary }}</span>{% endif %}
        {% endfor %}
      </div>
      {% endif %}
      {% if ai_execution_context.verifier %}
      <div class="factor-pipeline-summary-item" data-testid="factor-board-ai-execution-verifier">
        <span class="factor-pipeline-summary-label">Verifier</span>
        {% if ai_execution_context.verifier.status %}<span class="factor-pipeline-summary-value"><code>{{ ai_execution_context.verifier.status }}</code></span>{% endif %}
        {% if ai_execution_context.verifier.profile %}<span class="factor-pipeline-summary-value">profile=<code>{{ ai_execution_context.verifier.profile }}</code></span>{% endif %}
        {% if ai_execution_context.verifier.run_id %}<span class="factor-pipeline-summary-value">run=<code>{{ ai_execution_context.verifier.run_id }}</code></span>{% endif %}
        {% if ai_execution_context.verifier.top_rule %}<span class="factor-pipeline-summary-value">rule=<code>{{ ai_execution_context.verifier.top_rule }}</code></span>{% endif %}
        {% if ai_execution_context.verifier.gate_reason %}<span class="semantic-line">{{ ai_execution_context.verifier.gate_reason }}</span>{% endif %}
        {% if ai_execution_context.verifier.href %}<a class="evidence-link" href="{{ ai_execution_context.verifier.href }}">Open Case Verifier</a>{% endif %}
      </div>
      {% endif %}
      <div class="factor-pipeline-summary-item" data-testid="factor-board-ai-execution-rules">
        <span class="factor-pipeline-summary-label">Rules</span>
        {% if ai_execution_context.validation_plan_id %}
        <span class="factor-pipeline-summary-value" data-testid="factor-board-ai-execution-validation-plan">validation_plan=<code>{{ ai_execution_context.validation_plan_id }}</code></span>
        {% endif %}
        {% if ai_execution_context.row_verifier_rule_count %}
        <span class="factor-pipeline-summary-value">Row Verifier rules=<code>{{ ai_execution_context.row_verifier_rule_count }}</code></span>
        {% endif %}
      </div>
    </div>
    {% if ai_execution_context.policy_sources or ai_execution_context.evidence_refs %}
    <details class="readiness-evidence-details" data-testid="factor-board-ai-execution-evidence-policy">
      <summary>Evidence / Policy Sources</summary>
      <div class="readiness-evidence-list">
        {% for source in ai_execution_context.policy_sources %}
        <code>{{ source.label }}={{ source.value }}</code>
        {% endfor %}
        {% for ref in ai_execution_context.evidence_refs %}
        <code>{{ ref.label }}={{ ref.value }}</code>
        {% endfor %}
      </div>
    </details>
    {% endif %}
  </section>
  {% endif %}

  {% if verifier_summary %}
  <section class="verifier-strip" data-testid="factor-board-case-verifier-shortcut">
    <div class="verifier-strip-main">
      <strong>Verifier</strong>
      <span class="verifier-state {{ verifier_summary.status }}" data-testid="factor-board-verifier-status">{{ verifier_summary.status }}</span>
      {% if verifier_summary.case_ref %}<span data-testid="factor-board-verifier-case-ref">{{ verifier_summary.case_ref }}</span>{% endif %}
      {% if verifier_summary.display_storage_token and verifier_summary.storage_token %}<code data-testid="factor-board-verifier-storage-token">{{ verifier_summary.storage_token }}</code>{% endif %}
      {% if verifier_summary.latest_verifier_run_id %}<code data-testid="factor-board-verifier-run-id">{{ verifier_summary.latest_verifier_run_id }}</code>{% endif %}
      {% if verifier_summary.gate_reason %}<span data-testid="factor-board-verifier-gate-reason">{{ verifier_summary.gate_reason }}</span>{% endif %}
      {% if verifier_summary.top_rule %}<code data-testid="factor-board-verifier-top-rule">{{ verifier_summary.top_rule }}</code>{% endif %}
    </div>
    <a class="portal-link primary" href="{{ verifier_summary.href }}" data-testid="factor-board-open-case-verifier">Open Case Verifier</a>
  </section>
  {% endif %}

  {% if assurance_summary or rows %}
  {% if assurance_summary %}
  <section class="assurance-strip" data-testid="factor-board-assurance-strip">
    <div class="assurance-strip-header">
      <strong class="assurance-strip-title">验收可信度 / Evidence Assurance</strong>
      <button class="portal-link primary" type="button" data-assurance-open data-testid="factor-board-open-assurance-drawer">Open Drawer</button>
    </div>
    {% set assurance_blocker_total =
      assurance_aggregation_counts.get("needs_final_validation", 0)
      + assurance_aggregation_counts.get("evidence_missing", 0)
      + assurance_aggregation_counts.get("verifier_failed", 0)
      + assurance_aggregation_counts.get("stale", 0)
      + assurance_aggregation_counts.get("unsupported", 0)
    %}
    <div
      class="assurance-trust-summary"
      data-testid="factor-board-assurance-trust-summary"
      data-assurance-blocker-total="{{ assurance_blocker_total }}"
    >
      <div class="assurance-trust-primary">
        {% if assurance_blocker_total == 0 %}
        <span class="assurance-trust-state assured" data-testid="factor-board-assurance-trust-state">验收可信 / Evidence assured</span>
        <span class="assurance-trust-copy">Live read model, row verifier and formal evidence agree; technical proof remains available in the drawer.</span>
        {% elif assurance_aggregation_counts.get("verifier_failed", 0) > 0 or assurance_aggregation_counts.get("evidence_missing", 0) > 0 %}
        <span class="assurance-trust-state action" data-testid="factor-board-assurance-trust-state">有阻断 / Action required</span>
        <span class="assurance-trust-copy">Some evidence or verifier checks block trust; open the drawer for owner, rule and next action.</span>
        {% else %}
        <span class="assurance-trust-state review" data-testid="factor-board-assurance-trust-state">需复核 / Review needed</span>
        <span class="assurance-trust-copy">Readiness is not clean yet; open the drawer for stale, unsupported or final-validation detail.</span>
        {% endif %}
      </div>
      <div class="assurance-trust-metrics" data-testid="factor-board-assurance-counts">
        {% for state_key, state_label in assurance_count_order %}
        <span class="assurance-count {{ 'assurance-' ~ state_key|replace('_', '-') }}" data-testid="factor-board-assurance-count-{{ state_key }}">{{ state_label }} {{ assurance_aggregation_counts.get(state_key, 0) }}</span>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  <div class="assurance-drawer-backdrop" data-assurance-close data-testid="factor-board-assurance-backdrop" aria-hidden="true"></div>
  <aside class="assurance-drawer" data-testid="factor-board-assurance-drawer" aria-hidden="true">
    <div class="assurance-drawer-header">
      <h2 class="assurance-drawer-title">Assurance</h2>
      <div class="assurance-actions">
        {% if assurance_summary and assurance_summary.case_assurance_href %}
        <a class="portal-link" href="{{ assurance_summary.case_assurance_href }}" data-testid="factor-board-open-full-case-assurance">Open full Case Assurance</a>
        {% else %}
        <span class="portal-link disabled" data-testid="factor-board-open-full-case-assurance">Open full Case Assurance</span>
        {% endif %}
        <button class="assurance-close" type="button" data-assurance-close>Close</button>
      </div>
    </div>
    <div class="assurance-card-list" data-testid="factor-board-assurance-drawer-card-deck">
      {% if assurance_summary %}
      {% if assurance_summary.top_strip %}
      <section class="assurance-card" data-testid="factor-board-assurance-card-technical-summary" data-assurance-card="technical_summary" aria-expanded="false">
        <div class="assurance-card-header">
          <div class="assurance-card-title-row">
            <span class="assurance-card-title">Technical Gate Summary</span>
            <span class="assurance-card-token">drawer only</span>
          </div>
          <div class="assurance-card-grid" data-testid="factor-board-assurance-card-deck">
            {% for chip in assurance_summary.top_strip %}
            {% set target_card = chip.key %}
            {% if chip.key == "case_formal" and chip.first_blocker and "compiled_input" in chip.first_blocker %}
              {% set target_card = "compiled_input" %}
            {% elif chip.key == "case_formal" %}
              {% set target_card = "read_model" %}
            {% elif chip.key == "input_chain" %}
              {% set target_card = "compiled_input" %}
            {% elif chip.key == "factor_matrix" %}
              {% set target_card = "compiled_input" %}
            {% endif %}
            <button
              class="assurance-status-card {{ chip.state_class }}"
              type="button"
              data-assurance-open
              data-assurance-target="{{ target_card }}"
              data-testid="factor-board-assurance-chip-{{ chip.key }}"
              title="{{ chip.first_blocker or chip.status_text }}">
              <span class="assurance-status-card-title">{{ chip.label }}</span>
              <span class="assurance-status-card-main">
                <span class="assurance-card-token {{ chip.state_class }}">{{ chip.status_text }}</span>
                {% if chip.first_blocker %}<code class="assurance-blocker">{{ chip.first_blocker }}</code>{% endif %}
              </span>
            </button>
            {% endfor %}
          </div>
        </div>
      </section>
      {% endif %}
      {% for card in assurance_summary.drawer_cards %}
      <section class="assurance-card" data-testid="factor-board-assurance-card-{{ card.key }}" data-assurance-card="{{ card.key }}" aria-expanded="false">
        <div class="assurance-card-header">
          <div class="assurance-card-title-row">
            <span class="assurance-card-title">{{ card.label }}</span>
            <span class="assurance-card-token {{ card.state_class }}">{{ card.verdict }}</span>
          </div>
          <div class="assurance-token-grid">
            {% if card.profile %}<span class="assurance-card-token">artifact_profile={{ card.profile }}</span>{% endif %}
            {% for token in card.summary_tokens %}<span class="assurance-card-token">{{ token }}</span>{% endfor %}
            {% for item in card.provenance %}<span class="assurance-card-token">{{ item }}</span>{% endfor %}
            {% if card.first_blocker %}<code class="assurance-blocker">{{ card.first_blocker }}</code>{% endif %}
          </div>
        </div>
      </section>
      {% endfor %}
      {% endif %}
    </div>
    {% if assurance_summary and assurance_row_details %}
    <div class="assurance-row-detail" data-testid="factor-board-assurance-row-detail">
      <div class="assurance-row-detail-header">
        <strong class="assurance-card-title">Row Detail</strong>
        <span class="assurance-card-token">{{ assurance_row_details | length }}</span>
      </div>
      <table class="assurance-row-detail-table">
        <thead>
          <tr><th>Factor</th><th>State</th><th>Blockers</th></tr>
        </thead>
        <tbody>
        {% for factor_key, detail in assurance_row_details.items() %}
        <tr class="assurance-row-detail-card" data-assurance-row-detail="{{ factor_key }}">
          <td><code>{{ factor_key }}</code></td>
          <td><span class="{{ 'assurance-' ~ detail.assurance_state | replace('_', '-') }}">{{ detail.assurance_state }}</span></td>
          <td>
            {% if detail.exception_blockers %}
            {% for blocker in detail.exception_blockers %}<code class="assurance-blocker">{{ blocker }}</code> {% endfor %}
            {% else %}<span style="color:#98a2ad">—</span>{% endif %}
          </td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
    {% if rows %}
    <div class="assurance-row-detail" data-testid="factor-board-row-verifier-detail">
      <div class="assurance-row-detail-header">
        <strong class="assurance-card-title">Row Verifier Detail</strong>
        <span class="assurance-card-token">{{ rows | length }}</span>
      </div>
      {% for row in rows %}
      {% if row.row_verifier %}
      <section class="assurance-card" data-row-verifier-row-detail="{{ row.factor_key }}" data-testid="factor-board-row-verifier-detail-{{ row.factor_key }}">
        <div class="assurance-card-title-row">
          <span class="assurance-card-title"><code>{{ row.row_verifier.factor_key }}</code></span>
          <span class="assurance-card-token {{ row.row_verifier.state_class }}" data-testid="factor-board-row-verifier-drawer-state">{{ row.row_verifier.state_label }}</span>
        </div>
        {% if row.row_verifier.primary_rule %}
        <code class="assurance-blocker" data-testid="factor-board-row-verifier-drawer-primary">{{ row.row_verifier.primary_rule }}</code>
        {% endif %}
        {% if row.row_verifier.root_cause_hint_zh and row.row_verifier.state != "verified" %}
        <div class="state-owner-row"><span class="state-owner-label">root cause:</span><span class="semantic-line" data-testid="factor-board-row-verifier-drawer-root-cause">{{ row.row_verifier.root_cause_hint_zh }}</span></div>
        {% endif %}
        <div class="row-verifier-binding" data-testid="factor-board-row-verifier-binding">
          <span>prescreen=<code>{{ row.row_verifier.prescreen_run_id or "—" }}</code></span>
          <span>final=<code>{{ row.row_verifier.final_run_id or "—" }}</code></span>
          <span>validation_plan={{ row.row_verifier.validation_plan_id or "—" }}</span>
          <span>case_verifier=<code>{{ row.row_verifier.case_verifier_run_id or "—" }}</code></span>
        </div>
        {% if assurance_summary and assurance_summary.case_assurance_href %}
        <a class="evidence-link" href="{{ assurance_summary.case_assurance_href }}" data-testid="factor-board-row-verifier-case-assurance-link">Open full Case Assurance</a>
        {% endif %}
        <a class="evidence-link" href="#row-verifier-json-{{ row.factor_key }}" data-testid="factor-board-row-verifier-json">row_verifier_payload.json</a>
        {% if inline_row_verifier_payload_json %}
        <pre id="row-verifier-json-{{ row.factor_key }}" class="row-verifier-json" data-testid="factor-board-row-verifier-json-payload">{{ row.row_verifier_payload_json | safe }}</pre>
        {% else %}
        <span id="row-verifier-json-{{ row.factor_key }}" class="metric-label" data-testid="factor-board-row-verifier-json-deferred">deferred in live view</span>
        {% endif %}
        <table class="assurance-row-detail-table" data-testid="factor-board-row-verifier-rules">
          <thead>
            <tr><th>Status</th><th>Rule</th><th>Expected</th><th>Actual</th><th>Next Action</th></tr>
          </thead>
          <tbody>
          {% for rule in row.row_verifier.rules %}
            <tr>
              <td><span class="row-verifier-rule-status {{ rule.status }}">{{ rule.status }}</span></td>
              <td><code>{{ rule.rule_id }}</code></td>
              <td>{{ rule.expected }}</td>
              <td>{{ rule.actual }}</td>
              <td>{{ rule.next_action_zh or rule.next_action or "—" }}</td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </section>
      {% endif %}
      {% endfor %}
    </div>
    {% endif %}
    {% if assurance_summary and assurance_summary.provenance %}
    <div class="assurance-provenance" data-testid="factor-board-assurance-provenance">
      {% for item in assurance_summary.provenance %}<span>{{ item.kind }}=<code>{{ item.value }}</code></span>{% endfor %}
    </div>
    {% endif %}
  </aside>
  {% endif %}

  {% set verifier_top_rule_text = verifier_summary.top_rule if verifier_summary else "" %}
  {% set verifier_gate_reason_text = verifier_summary.gate_reason if verifier_summary else "" %}
  {% set verifier_block_text = verifier_top_rule_text ~ " " ~ verifier_gate_reason_text %}
  {% set input_prerequisite_blocked = verifier_summary and verifier_summary.status == "blocked" and (
    "missing_compiled_input_dir" in verifier_block_text
    or "compiled_input_dir_missing" in verifier_block_text
    or "source_contract." in verifier_block_text
  ) %}
  {% if source_inputs or compiled_inputs %}
  <section class="input-scope" data-testid="research-input-scope">
    <div class="input-scope-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="research-input-scope-case-ref">{{ display_case_ref }}</span>{% endif %}研究输入摘要 / Research Input Scope</div>
    {% set input_default_tab = "source" if source_inputs else "compiled" %}
    {% set compiled_input_gate_status = input_compiled_gate.status if input_compiled_gate else (compiled_inputs|length if compiled_inputs else 0) %}
    {% set compiled_input_gate_class = input_compiled_gate.status_class if input_compiled_gate else "pass" %}
    <div class="input-tabs" data-testid="research-input-tabs">
      {% if source_inputs %}
      <button class="input-tab-button active" type="button" data-input-tab-target="source" data-testid="research-input-tab-source" aria-selected="true">
        源头输入 / Source Input <span class="rule-status pass">{{ source_inputs|length }}</span>
      </button>
      {% endif %}
      {% if compiled_inputs or source_inputs %}
      <button class="input-tab-button{% if input_default_tab == 'compiled' %} active{% endif %}" type="button" data-input-tab-target="compiled" data-testid="research-input-tab-compiled" aria-selected="{{ 'true' if input_default_tab == 'compiled' else 'false' }}">
        编译输入 / Compiled Input <span class="rule-status {{ compiled_input_gate_class }}" data-testid="compiled-input-gate-status">{{ compiled_input_gate_status }}</span>
        <span class="count-badge" data-testid="compiled-input-count">{{ compiled_inputs|length if compiled_inputs else 0 }}</span>
      </button>
      {% endif %}
    </div>
    <div class="input-scope-grid">
    {% if source_inputs %}
    <section class="input-card input-tab-panel" data-input-tab-panel="source" data-testid="source-input-scope">
      <div class="input-card-header" data-testid="source-input-card">
        <h2 class="input-card-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="source-input-card-case-ref">{{ display_case_ref }}</span>{% endif %}源头输入 / Source Input</h2>
        <p class="input-card-meta">input case package: study_request + research_idea · rows={{ source_inputs|length }}</p>
      </div>
      <div class="input-scope-scroll">
        <table class="input-scope-table source-input-table" data-testid="source-input-scope-table">
          <thead>
            <tr>
              <th>Case</th>
              <th>请求 / Request</th>
              <th>策略 / Source Strategy</th>
              <th>参数 / Parameters</th>
              <th>窗口 / Windows</th>
              <th>
                验收 / Acceptance
                <button
                  class="help-tip"
                  type="button"
                  data-testid="acceptance-policy-help"
                  aria-label="验收策略说明：prescreen = 初筛排名证据；retained_only = 只有保留的 Top N 进入 final backtest；final = 正式验收绩效、资金曲线和 owner report。"
                  title="验收策略说明：prescreen = 初筛排名证据；retained_only = 只有保留的 Top N 进入 final backtest；final = 正式验收绩效、资金曲线和 owner report。">?</button>
              </th>
              <th>源头文件 / Input Files</th>
            </tr>
          </thead>
          <tbody>
          {% for si in source_inputs %}
            <tr data-testid="source-input-row">
              <td>
                {% if si.case_ref %}
                <span class="case-ref-badge" data-testid="source-input-case-ref">{{ si.case_ref }}</span><br />
                {% else %}
                <code class="input-scope-code" data-testid="source-input-case-id">{{ si.case_id }}</code>
                {% endif %}
                {% if si.title and not (si.case_ref and si.title == si.case_id) %}<br /><span data-testid="source-input-title">{{ si.title }}</span>{% endif %}
                {% if si.lifecycle_state %}<br /><span class="chip" data-testid="source-input-lifecycle-state">{{ si.lifecycle_state }}</span>{% endif %}
                {% if si.status %}<br /><span data-testid="source-input-status">{{ si.status }}</span>{% endif %}
              </td>
              <td>
                {% if si.search_contract_id %}<div><strong>contract</strong> <code class="input-scope-code" data-testid="source-input-search-contract-id">{{ si.search_contract_id }}</code></div>{% endif %}
                {% if si.source_input_source_kind %}<span class="chip" data-testid="source-input-source-kind">source_kind={{ si.source_input_source_kind }}</span>{% endif %}
                {% if si.layered_input_projection_status %}<span class="chip" data-testid="source-input-projection-status">projection_status={{ si.layered_input_projection_status }}</span>{% endif %}
                {% if si.layered_input_blocker_code and si.layered_input_blocker_code != "none" %}<span class="chip" data-testid="source-input-blocker-code">blocker_code={{ si.layered_input_blocker_code }}</span>{% endif %}
                {% if si.source_input_provenance_refs %}
                <div style="margin-top:4px" data-testid="source-input-provenance-refs">
                  {% for ref in si.source_input_provenance_refs %}<code class="input-scope-code" data-testid="source-input-provenance-ref">{{ ref }}</code>{% endfor %}
                </div>
                {% endif %}
                {% if si.execution_target %}<span class="chip" data-testid="source-input-execution-target">{{ si.execution_target }}</span>{% endif %}
                {% if si.trial_budget %}<span class="chip" data-testid="source-input-trial-budget">trial_budget={{ si.trial_budget }}</span>{% endif %}
                {% if si.acceptance_tier %}<span class="chip" data-testid="source-input-acceptance-tier">tier={{ si.acceptance_tier }}</span>{% endif %}
                {% if si.schema_version %}<span class="chip" data-testid="source-input-schema-version">schema={{ si.schema_version }}</span>{% endif %}
                {% if si.search_axes %}
                <div style="margin-top:4px" data-testid="source-input-search-axes">
                  {% for axis in si.search_axes %}<span class="chip">{{ axis }}</span>{% endfor %}
                </div>
                {% endif %}
                {% if si.base_universe %}
                <div style="margin-top:4px" data-testid="source-input-base-universe">
                  {% for item in si.base_universe %}<span class="chip chip-sym">{{ item|upper }}</span>{% endfor %}
                </div>
                {% endif %}
              </td>
              <td>
                {% if si.strategy_key %}<div><strong>strategy_key</strong> <code class="input-scope-code" data-testid="source-input-strategy-key">{{ si.strategy_key }}</code></div>{% endif %}
                {% if si.source_strategy_name %}<div><strong>source</strong> <code class="input-scope-code" data-testid="source-input-source-strategy">{{ si.source_strategy_name }}</code></div>{% endif %}
                {% if si.strategy_family %}<div data-testid="source-input-strategy-family">{{ si.strategy_family }}</div>{% endif %}
                {% if si.source_repo %}<div><strong>repo</strong> <code class="input-scope-code" data-testid="source-input-source-repo">{{ si.source_repo }}</code></div>{% endif %}
                {% if si.symbol_universe %}
                <div data-testid="source-input-symbol-universe">
                  {% for item in si.symbol_universe %}<span class="chip chip-sym">{{ item }}</span>{% endfor %}
                </div>
                {% endif %}
                {% if si.underlyings %}
                <div data-testid="source-input-underlyings">
                  {% for item in si.underlyings %}<span class="chip">{{ item }}</span>{% endfor %}
                </div>
                {% endif %}
              </td>
              <td>
                <div class="input-lines" data-testid="source-input-factor-params">
                  {% if si.trading_mode %}<span data-testid="source-input-trading-mode"><strong>trading_mode</strong> <code class="input-scope-code">{{ si.trading_mode }}</code></span>{% endif %}
                  {% if si.strategy_trade_mode %}<span data-testid="source-input-strategy-trade-mode"><strong>strategy_trade_mode</strong> <code class="input-scope-code">{{ si.strategy_trade_mode }}</code></span>{% endif %}
                  {% if si.validation_plan_id %}<span data-testid="source-input-validation-plan-id"><strong>validation_plan</strong> <code class="input-scope-code">{{ si.validation_plan_id }}</code></span>{% endif %}
                  {% if si.runtime_scope %}<span data-testid="source-input-runtime-scope"><strong>runtime_scope</strong> <code class="input-scope-code">{{ si.runtime_scope }}</code></span>{% endif %}
                  {% if si.purpose %}<span data-testid="source-input-purpose"><strong>purpose</strong> <code class="input-scope-code">{{ si.purpose }}</code></span>{% endif %}
                  {% if si.canonical_search_cell_policy %}<span data-testid="source-input-canonical-search-cell-policy"><strong>cell_policy</strong> <code class="input-scope-code">{{ si.canonical_search_cell_policy }}</code></span>{% endif %}
                  {% if si.selection_policies %}
                  <span data-testid="source-input-selection-policies"><strong>selection_policies</strong>
                    <span class="input-token-list">
