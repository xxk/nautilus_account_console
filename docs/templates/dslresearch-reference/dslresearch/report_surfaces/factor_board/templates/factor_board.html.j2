              </div>
              {% else %}
              {% set final_missing_title = final_missing_reason if final_missing_reason else ('缺 Final 证据 / Missing final evidence' if final_missing_is_asset_gap else '未找到 Final 绩效 run / No final performance run') %}
              {% set final_missing_label = "未入围 Final / Not retained for final" if final_missing_is_prescreen_not_retained else ("缺 Final 证据 / Missing final evidence" if final_missing_is_asset_gap else ("Not retained" if final_missing_is_retained_only else "未找到 Final 绩效 run / No final performance run")) %}
              <div class="stage-missing-stack" data-testid="final-missing-stack">
                <span class="stage-badge" data-testid="performance-stage-label">{{ final_perf.evaluation_stage_label }}</span>
                <span class="stage-missing-summary" data-testid="final-performance-missing-summary" title="{{ final_missing_title }}">{{ final_missing_label }}</span>
              </div>
              {% endif %}
            {% else %}
              <div class="stage-missing-stack" data-testid="final-missing-stack">
                <span class="stage-missing-summary" data-testid="final-performance-missing-summary" title="{{ '未入围 Final / Not retained for final' if final_missing_is_prescreen_not_retained or final_missing_is_factor_not_retained else ('缺 Final 证据 / Missing final evidence' if final_missing_is_asset_gap else '未找到 Final 绩效 run / No final performance run') }}">{{ "未入围 Final / Not retained for final" if final_missing_is_prescreen_not_retained or final_missing_is_factor_not_retained else ("缺 Final 证据 / Missing final evidence" if final_missing_is_asset_gap else "未找到 Final 绩效 run / No final performance run") }}</span>
                {% if (not final_missing_is_prescreen_not_retained) and (not final_missing_is_factor_not_retained) and (not final_missing_is_asset_gap) %}
                <span class="stage-missing-summary" data-testid="final-equity-missing-summary" title="未找到 Final 资金曲线 run / No final equity run">未找到 Final 资金曲线 run / No final equity run</span>
