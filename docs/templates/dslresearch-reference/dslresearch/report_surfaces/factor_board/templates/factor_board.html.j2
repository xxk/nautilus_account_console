<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8" />
<title>因子生命周期看板 / Factor Lifecycle Board</title>
<style>
:root{--status-blocker-bg:#ef4444;--status-blocker-border:#dc2626;--status-blocker-text:#fff;--status-hint-bg:#fef08a;--status-hint-border:#facc15;--status-hint-text:#713f12}
*,*::before,*::after{box-sizing:border-box}
body{margin:0;padding:0;background:#f6f8fa;color:#1f2328;font-family:Segoe UI,Microsoft YaHei,sans-serif}
.shell{width:100%;max-width:none;margin:0 auto;padding:20px 16px 32px}
.hero{background:#fff;border:1px solid #dfe7f0;border-radius:10px;padding:18px 20px;margin-bottom:14px;display:flex;gap:16px;justify-content:space-between;align-items:flex-start;flex-wrap:wrap}
.hero-left h1{margin:0 0 4px;font-size:1.5rem;font-weight:700}
.portal-prefix{font-size:.72rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:#57606a;margin:0 0 4px}
.meta{color:#57606a;font-size:.82rem;line-height:1.55}
.hero-title-meta{margin:0;font-weight:700}
.hero-title-meta strong{color:#1f2328;font-size:.92rem}
.projection-audit{margin-top:8px;color:#57606a;font-size:.78rem}
.projection-audit summary{cursor:pointer;color:#0969da;font-weight:800;width:max-content;max-width:100%}
.projection-audit-body{display:flex;flex-wrap:wrap;gap:6px 12px;margin-top:6px;line-height:1.45}
.projection-audit-body span{display:inline-flex;align-items:center;gap:4px;max-width:100%}
.projection-audit-body code{max-width:560px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.hero-actions{display:flex;flex-wrap:wrap;gap:8px;align-items:center}
.portal-link{display:inline-flex;align-items:center;justify-content:center;min-height:34px;padding:6px 12px;border-radius:8px;border:1px solid #d0d7de;text-decoration:none;font-weight:700;font-size:.84rem;white-space:nowrap;color:#0969da;background:#f6f8fa}
.portal-link.primary{background:#0969da;border-color:#0969da;color:#fff}
.portal-link.muted{color:#57606a;background:#fff}
.portal-link.disabled{pointer-events:none;color:#98a2ad;border-style:dashed}
.sync-button{display:inline-flex;align-items:center;justify-content:center;min-height:34px;padding:6px 12px;border-radius:8px;border:1px solid #0969da;background:#0969da;color:#fff;font-weight:700;font-size:.84rem;white-space:nowrap;cursor:pointer}
.sync-button:disabled{cursor:wait;opacity:.65}
.sync-status{font-size:.78rem;color:#57606a;min-width:120px}
.toolbar{background:#fff;border:1px solid #dfe7f0;border-radius:10px;padding:12px 16px;margin-bottom:14px;display:flex;flex-wrap:wrap;gap:10px;align-items:center}
.toolbar-label{font-size:.76rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#57606a;white-space:nowrap}
.filter-chip{display:inline-flex;align-items:center;padding:5px 10px;border-radius:999px;border:1px solid #d0d7de;background:#fff;color:#57606a;font-size:.78rem;font-weight:700;cursor:pointer;transition:background .1s,color .1s}
.filter-chip:hover{background:#f0f4fa;color:#0969da}
.filter-chip.active{background:#0969da;border-color:#0969da;color:#fff}
.filter-chip[data-state="proposed"].active{background:#3b82f6;border-color:#3b82f6}
.filter-chip[data-state="tested"].active{background:#0891b2;border-color:#0891b2}
.filter-chip[data-state="retained"].active{background:#16a34a;border-color:#16a34a}
.filter-chip[data-state="promoted"].active{background:#7c3aed;border-color:#7c3aed}
.filter-chip[data-state="composite_candidate"].active{background:#4f46e5;border-color:#4f46e5}
.filter-chip[data-state="accepted"].active{background:#059669;border-color:#059669}
.filter-chip[data-state="rejected"].active{background:#dc2626;border-color:#dc2626;opacity:.8}
.filter-chip[data-state="retired"].active{background:#6b7280;border-color:#6b7280;opacity:.8}
.factor-table [data-col-group].col-group-hidden{display:none}
.table-wrap{background:#fff;border:1px solid #dfe7f0;border-radius:10px;overflow-x:auto;overflow-y:hidden}
.factor-table{width:max-content;min-width:1900px;border-collapse:collapse;font-size:.82rem}
.factor-table th:nth-child(1),.factor-table td:nth-child(1){min-width:150px}
.factor-table th:nth-child(2),.factor-table td:nth-child(2){min-width:145px}
.factor-table th:nth-child(3),.factor-table td:nth-child(3){min-width:110px}
.factor-table th:nth-child(4),.factor-table td:nth-child(4){min-width:115px}
.factor-table th:nth-child(5),.factor-table td:nth-child(5){min-width:110px}
.factor-table th:nth-child(6),.factor-table td:nth-child(6){min-width:105px}
.factor-table th:nth-child(7),.factor-table td:nth-child(7){min-width:220px}
.factor-table th:nth-child(8),.factor-table td:nth-child(8){min-width:190px}
.factor-table th:nth-child(9),.factor-table td:nth-child(9){min-width:250px}
.factor-table th:nth-child(10),.factor-table td:nth-child(10){min-width:300px}
.factor-table.prescreen-empty th:nth-child(9),.factor-table.prescreen-empty td:nth-child(9){width:90px;min-width:90px;max-width:90px;text-align:center}
.factor-table.prescreen-empty th:nth-child(9){white-space:normal;line-height:1.16;padding-left:5px;padding-right:5px}
.factor-table.prescreen-empty td:nth-child(9){padding-left:5px;padding-right:5px}
.factor-table th:nth-child(11),.factor-table td:nth-child(11){min-width:105px}
.factor-table th:nth-child(12),.factor-table td:nth-child(12){min-width:270px}
.factor-table th:nth-child(13),.factor-table td:nth-child(13){min-width:125px}
.factor-table th:nth-child(14),.factor-table td:nth-child(14){min-width:220px}
.factor-table th:nth-child(15),.factor-table td:nth-child(15){min-width:260px}
.factor-board-table-title{margin:12px 0 8px;font-size:1rem;font-weight:850;color:#24292f}
.factor-board-table-subtitle{margin:0 0 8px;color:#57606a;font-size:.78rem}
.factor-table thead th{position:sticky;top:0;background:#f8fafc;color:#475569;font-size:.7rem;text-align:left;text-transform:uppercase;letter-spacing:0;border-bottom:2px solid #dfe7f0;padding:7px 8px;white-space:nowrap;z-index:1}
.row-type-header{display:grid;gap:5px;align-items:start}
.row-type-filter{width:100%;max-width:180px;min-height:28px;padding:4px 26px 4px 8px;border:1px solid #d0d7de;border-radius:7px;background:#fff;color:#24292f;font-size:.72rem;font-weight:700;text-transform:none;letter-spacing:0}
.factor-table tbody td{border-top:1px solid #f0f4f8;padding:6px 8px;vertical-align:top;line-height:1.28}
.factor-table tbody tr:first-child td{border-top:0}
.factor-table tbody tr.deemphasized{opacity:.6}
.factor-table tbody tr.hidden{display:none}
.state-badge{display:inline-flex;align-items:center;padding:2px 7px;border-radius:999px;font-size:.69rem;font-weight:800;border:1px solid;white-space:nowrap}
.state-proposed{background:#dbeafe;color:#1d4ed8;border-color:#93c5fd}
.state-tested{background:#cffafe;color:#0e7490;border-color:#67e8f9}
.state-retained{background:#dcfce7;color:#15803d;border-color:#86efac}
.state-promoted{background:#ede9fe;color:#6d28d9;border-color:#c4b5fd}
.state-composite-candidate{background:#e0e7ff;color:#3730a3;border-color:#a5b4fc}
.state-accepted{background:#d1fae5;color:#065f46;border-color:#6ee7b7}
.state-rejected-muted{background:var(--status-blocker-bg);color:var(--status-blocker-text);border-color:var(--status-blocker-border)}
.state-retired-muted{background:#f3f4f6;color:#4b5563;border-color:#d1d5db}
.formal-outcome{display:inline-flex;align-items:center;margin-top:4px;padding:2px 7px;border-radius:7px;border:1px solid;font-size:.68rem;font-weight:900;white-space:nowrap}
.formal-pass{background:#d1fae5;color:#065f46;border-color:#6ee7b7}
.formal-fail{background:var(--status-blocker-bg);color:var(--status-blocker-text);border-color:var(--status-blocker-border)}
.formal-pending{background:#f3f4f6;color:#4b5563;border-color:#d1d5db}
.decision-lane-stack{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:6px;margin-top:8px}
.decision-lane{display:flex;flex-direction:column;gap:2px;min-width:0;border:1px solid #d0d7de;border-radius:6px;background:#fff;padding:6px}
.decision-lane-label{font-size:.62rem;font-weight:800;color:#57606a;text-transform:uppercase;letter-spacing:0}
.decision-lane-value{font-size:.72rem;font-weight:800;color:#24292f;overflow-wrap:anywhere}
@media(max-width:760px){.decision-lane-stack{grid-template-columns:1fr}}
.decision-gate-note{margin:12px 0 16px;padding:10px 16px;border:1px solid var(--status-hint-border);border-radius:8px;background:var(--status-hint-bg);color:var(--status-hint-text);font-size:.84rem;font-weight:700}
.decision-gate-block{display:grid;gap:5px;margin-top:7px;color:#475569;font-size:.76rem}
.decision-gate-badge{display:inline-flex;width:max-content;max-width:100%;align-items:center;padding:3px 8px;border-radius:7px;border:1px solid #d0d7de;background:#f6f8fa;color:#24292f;font-weight:900;white-space:nowrap}
.decision-gate-badge.blocked,.decision-gate-badge.fail{background:var(--status-blocker-bg);border-color:var(--status-blocker-border);color:var(--status-blocker-text)}
.decision-gate-badge.not_ready{background:var(--status-hint-bg);border-color:var(--status-hint-border);color:var(--status-hint-text)}
.decision-gate-badge.ready{background:#d1fae5;border-color:#6ee7b7;color:#065f46}
.decision-gate-decomposition{display:grid;gap:4px;padding:8px 10px;border-radius:8px;border:1px solid var(--status-blocker-border);background:var(--status-blocker-bg);color:var(--status-blocker-text)}
.decision-gate-decomposition-label{font-weight:800}
.decision-gate-decomposition ul{margin:0;padding-left:18px}
.display-state-label{display:inline-flex;width:max-content;max-width:100%;align-items:center;padding:3px 8px;border-radius:7px;border:1px solid #bfdbfe;background:#eff6ff;color:#1d4ed8;font-weight:900;white-space:nowrap}
.strategy-diff{margin-top:6px;font-size:.75rem;color:#475569}
.strategy-diff summary{cursor:pointer;font-weight:800;color:#0969da}
.strategy-diff code{display:inline-block;margin:2px 0}
.decision-disabled{display:grid;gap:5px;max-width:360px;color:#dc2626;font-size:.78rem;font-weight:700}
.chip{display:inline-flex;align-items:center;padding:1px 5px;border-radius:999px;border:1px solid #e2e8f0;background:#f8fafc;color:#475569;font-size:.69rem;margin:0 2px 1px 0}
.chip-sym{background:#e0e7ff;border-color:#a5b4fc;color:#3730a3;font-weight:700}
.chip-mode{background:var(--status-hint-bg);border-color:var(--status-hint-border);color:var(--status-hint-text)}
.chip-freq{background:#dcfce7;border-color:#86efac;color:#166534}
code{background:#f0f3f6;border-radius:5px;padding:1px 5px;font-size:.82em;word-break:break-word}
.run-link{color:#0969da;text-decoration:none;font-size:.82rem;font-weight:600}
.run-link:hover{text-decoration:underline}
.run-link-best{color:#166534;font-weight:900}
.run-link-best code{background:#dcfce7;border:1px solid #86efac;color:#166534}
.run-best-label{display:inline-flex;align-items:center;margin-left:4px;padding:1px 5px;border-radius:999px;border:1px solid #86efac;background:#dcfce7;color:#166534;font-size:.66rem;font-weight:900;text-transform:uppercase}
.next-action-btn{display:inline-flex;align-items:center;padding:4px 10px;border-radius:8px;border:1px solid #0969da;background:#f0f7ff;color:#0969da;font-size:.78rem;font-weight:700;text-decoration:none;white-space:nowrap}
.next-action-none{color:#98a2ad;font-size:.78rem}
.param-list{display:flex;flex-wrap:wrap;gap:2px;max-width:220px}
.source-list{display:flex;flex-wrap:wrap;gap:2px;max-width:250px}
.metric-list{display:grid;grid-template-columns:max-content max-content;gap:2px 6px;white-space:nowrap;font-size:.74rem}
.metric-label{color:#57606a}
.metric-value{font-family:ui-monospace,SFMono-Regular,Consolas,monospace;color:#1f2328}
.stage-evidence-cell>*+*{margin-top:5px}
.stage-evidence-cell .metric-list{margin-top:5px}
.stage-evidence-meta{display:grid;gap:4px;color:#57606a;font-size:12px;line-height:1.45}
.stage-badge{display:inline-flex;align-items:center;margin-bottom:3px;padding:1px 6px;border-radius:6px;border:1px solid #c7d2fe;background:#eef2ff;color:#3730a3;font-size:.69rem;font-weight:800;white-space:nowrap}
.stage-missing-stack{display:flex;flex-direction:column;align-items:flex-start;gap:4px}
.stage-missing-summary{display:inline-flex;max-width:130px;align-items:center;padding:2px 6px;border-radius:6px;border:1px solid #d0d7de;background:#f6f8fa;color:#57606a;font-size:.72rem;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.semantic-stack{display:grid;gap:3px;min-width:145px}
.semantic-kind{display:inline-flex;width:max-content;max-width:100%;align-items:center;padding:2px 6px;border-radius:7px;border:1px solid #0ea5e9;background:#e0f2fe;color:#075985;font-size:.69rem;font-weight:900;white-space:nowrap}
.semantic-kind.asset{border-color:#22c55e;background:#dcfce7;color:#166534}
.semantic-kind.trial{border-color:var(--status-hint-border);background:var(--status-hint-bg);color:var(--status-hint-text)}
.semantic-kind.planned{border-color:#94a3b8;background:#f8fafc;color:#475569}
.semantic-line{color:#475569;font-size:.7rem;line-height:1.22}
.semantic-line code{font-size:.92em}
.equity-cell{min-width:190px}
.equity-spark{display:block;width:170px;height:48px;margin-bottom:3px}
.evidence-link{color:#0969da;text-decoration:none;font-size:.78rem;font-weight:600;word-break:break-all}
.evidence-link:hover{text-decoration:underline}
.decision-form{display:grid;grid-template-columns:minmax(92px,120px) minmax(150px,1fr) auto;gap:6px;align-items:center;min-width:360px}
.decision-form select,.decision-form input{min-height:30px;border:1px solid #d0d7de;border-radius:7px;background:#fff;color:#1f2328;font-size:.78rem;padding:4px 7px}
.decision-submit{min-height:30px;border:1px solid #0969da;border-radius:7px;background:#f0f7ff;color:#0969da;font-size:.78rem;font-weight:800;padding:4px 9px;cursor:pointer;white-space:nowrap}
.decision-submit:disabled{cursor:wait;opacity:.65}
.decision-status{display:block;margin-top:5px;color:#57606a;font-size:.76rem;max-width:360px}
.empty-state{padding:48px 20px;text-align:center;color:#57606a}
.empty-state h2{font-size:1.2rem;margin:0 0 8px}
.empty-state p{margin:0;font-size:.9rem}
.count-badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:999px;background:#f0f3f6;border:1px solid #d0d7de;color:#57606a;font-size:.74rem;font-weight:700;margin-left:6px}
.case-ref-badge{display:inline-flex;align-items:center;margin-right:8px;padding:3px 9px;border-radius:999px;border:1px solid #0969da;background:#f0f7ff;color:#0969da;font-size:.78rem;font-weight:800}
.case-id-inline{color:#57606a;font-size:.78rem;word-break:break-all}
.verifier-strip{margin:12px 0 16px;padding:12px 18px;background:#fff;border:1px solid #dfe7f0;border-radius:8px;display:flex;flex-wrap:wrap;gap:10px;align-items:center;justify-content:space-between}
.verifier-strip-main{display:flex;flex-wrap:wrap;gap:8px 12px;align-items:center;color:#57606a;font-size:.83rem}
.verifier-state{display:inline-flex;align-items:center;padding:3px 9px;border-radius:999px;border:1px solid #d0d7de;background:#f6f8fa;color:#24292f;font-size:.78rem;font-weight:800}
.verifier-state.blocked,.verifier-state.fail{background:var(--status-blocker-bg);border-color:var(--status-blocker-border);color:var(--status-blocker-text)}
.verifier-state.pass{background:#d1fae5;border-color:#6ee7b7;color:#065f46}
.assurance-strip{margin:12px 0 16px;padding:14px 18px;background:#fff;border:1px solid #dfe7f0;border-radius:10px;display:grid;gap:12px}
.assurance-strip-header{display:flex;justify-content:space-between;gap:12px;align-items:center}
.assurance-strip-title{font-weight:900;color:#24292f}
.assurance-trust-summary{display:grid;grid-template-columns:minmax(220px,1fr) auto;gap:10px;align-items:center;padding:10px 12px;border:1px solid #dfe7f0;border-radius:8px;background:#f8fafc}
.assurance-trust-primary{display:grid;gap:4px;min-width:0}
.assurance-trust-state{display:inline-flex;width:max-content;max-width:100%;align-items:center;padding:3px 9px;border-radius:999px;border:1px solid #d0d7de;background:#fff;color:#24292f;font-size:.78rem;font-weight:950;white-space:nowrap}
.assurance-trust-state.assured{background:#d1fae5;border-color:#6ee7b7;color:#065f46}
.assurance-trust-state.action{background:var(--status-blocker-bg);border-color:var(--status-blocker-border);color:var(--status-blocker-text)}
.assurance-trust-state.review{background:var(--status-hint-bg);border-color:var(--status-hint-border);color:var(--status-hint-text)}
.assurance-trust-copy{color:#475569;font-size:.78rem;font-weight:750;line-height:1.35}
.assurance-trust-metrics{display:flex;flex-wrap:wrap;justify-content:flex-end;gap:6px}
.assurance-card-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:8px}
.assurance-count-grid{display:flex;flex-wrap:wrap;gap:6px}
.assurance-status-card{display:grid;gap:6px;align-content:start;min-height:82px;padding:10px;border:1px solid #dfe7f0;border-radius:10px;background:#f8fafc;color:#24292f;text-align:left;cursor:pointer}
.assurance-status-card-title{font-size:.76rem;font-weight:900;color:#57606a}
.assurance-status-card-main{display:flex;flex-wrap:wrap;gap:6px;align-items:center}
.assurance-chip,.assurance-count,.assurance-row-button,.assurance-blocker{display:inline-flex;align-items:center;max-width:100%;border-radius:999px;border:1px solid #d0d7de;background:#f6f8fa;color:#24292f;font-size:.72rem;font-weight:850;white-space:nowrap}
.assurance-chip{min-height:30px;padding:4px 10px;cursor:pointer}
.assurance-count{padding:3px 8px}
.assurance-row-button{margin-top:5px;padding:3px 8px;cursor:pointer}
.assurance-blocker{margin-top:4px;padding:2px 7px;border-color:var(--status-blocker-border);background:var(--status-blocker-bg);color:var(--status-blocker-text)}
.assurance-verified{background:#d1fae5;border-color:#6ee7b7;color:#065f46}
.assurance-needs-final-validation{background:var(--status-hint-bg);border-color:var(--status-hint-border);color:var(--status-hint-text)}
.assurance-evidence-missing,.assurance-verifier-failed,.assurance-stale,.assurance-unsupported{background:var(--status-blocker-bg);border-color:var(--status-blocker-border);color:var(--status-blocker-text)}
.assurance-drawer-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,.2);z-index:299;cursor:pointer}
.assurance-drawer-backdrop.open{display:block}
.assurance-drawer{position:fixed;top:0;right:0;width:min(560px,100vw);height:100vh;overflow-y:auto;padding:18px 20px 40px;background:#fff;border-left:2px solid #dfe7f0;box-shadow:-6px 0 28px rgba(0,0,0,.1);z-index:300;transform:translateX(110%);transition:transform .22s cubic-bezier(.4,0,.2,1)}
.assurance-drawer.open{transform:translateX(0)}
.assurance-drawer-header{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:14px;padding-bottom:12px;border-bottom:1px solid #f0f4f8}
.assurance-drawer-title{margin:0;font-size:.98rem;font-weight:850;color:#24292f}
.assurance-card-list{display:grid;grid-template-columns:1fr;gap:8px;margin-bottom:12px}
.assurance-card{border:1px solid #dfe7f0;border-radius:10px;background:#f8fafc;padding:10px}
.assurance-card-header{display:grid;gap:8px}
.assurance-card-title-row{display:flex;justify-content:space-between;gap:8px;align-items:center}
.assurance-card-title{font-weight:900;color:#24292f}
.assurance-card-token{display:inline-flex;align-items:center;padding:2px 6px;border-radius:6px;border:1px solid #d0d7de;background:#fff;color:#475569;font-size:.7rem;font-weight:750}
.assurance-token-grid{display:flex;flex-wrap:wrap;gap:6px}
.assurance-row-detail{padding:10px;border-radius:10px;border:1px solid #dfe7f0;background:#fff}
.assurance-row-detail-header{display:flex;gap:8px;align-items:center;margin-bottom:8px}
.assurance-row-detail-table{width:100%;border-collapse:collapse;font-size:.76rem}
.assurance-row-detail-table thead th{position:sticky;top:0;background:#f8fafc;padding:5px 8px;text-align:left;border-bottom:1px solid #dfe7f0;font-weight:700;color:#57606a;white-space:nowrap;font-size:.69rem;letter-spacing:.04em;text-transform:uppercase}
.assurance-row-detail-table tbody td{padding:5px 8px;border-top:1px solid #f0f4f8;vertical-align:top;line-height:1.4}
.assurance-row-detail-table tbody tr:first-child td{border-top:0}
.assurance-row-detail-table tbody tr:hover{background:#f8fafc}
.assurance-row-detail-card{display:table-row}
.row-verifier-binding{display:grid;gap:4px;margin:8px 0;padding:8px;border:1px solid #dfe7f0;border-radius:8px;background:#f8fafc;color:#475569;font-size:.74rem}
