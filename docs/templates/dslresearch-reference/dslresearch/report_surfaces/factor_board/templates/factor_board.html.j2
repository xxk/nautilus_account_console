    {% if compiled_inputs %}
    <section class="input-card input-tab-panel" data-input-tab-panel="compiled" data-testid="compiled-input-scope"{% if input_default_tab != "compiled" %} hidden{% endif %}>
      <div class="input-card-header" data-testid="compiled-input-card">
