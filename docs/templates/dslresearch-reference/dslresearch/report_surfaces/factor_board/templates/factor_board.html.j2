      <div class="assetization-readiness-summary-item"><span class="assetization-readiness-summary-label">OOS Ready</span><span class="assetization-readiness-summary-value">{{ assetization_readiness.summary.oos_ready }}</span></div>
      <div class="assetization-readiness-summary-item"><span class="assetization-readiness-summary-label">Cost Ready</span><span class="assetization-readiness-summary-value">{{ assetization_readiness.summary.cost_ready }}</span></div>
      <div class="assetization-readiness-summary-item"><span class="assetization-readiness-summary-label">Capacity Ready</span><span class="assetization-readiness-summary-value">{{ assetization_readiness.summary.capacity_ready }}</span></div>
      <div class="assetization-readiness-summary-item"><span class="assetization-readiness-summary-label">Uplift Ready</span><span class="assetization-readiness-summary-value">{{ assetization_readiness.summary.uplift_ready }}</span></div>
      <div class="assetization-readiness-summary-item"><span class="assetization-readiness-summary-label">Decision Ready</span><span class="assetization-readiness-summary-value">{{ assetization_readiness.summary.decision_ready }}</span></div>
