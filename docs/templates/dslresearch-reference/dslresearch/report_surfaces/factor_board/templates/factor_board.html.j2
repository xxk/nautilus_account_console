                <input type="hidden" name="decision_facet_hash" value="{{ row.decision_handle.decision_facet_hash }}" />
                <input type="hidden" name="validation_plan_hash" value="{{ row.decision_handle.validation_plan_hash }}" />
                <input type="hidden" name="decision_handle_hash" value="{{ row.decision_handle_hash }}" data-decision-handle-hash="{{ row.decision_handle_hash }}" />
                <input type="hidden" name="decision_package_hash" value="{{ row.decision_package_hash }}" />
                {% endif %}
                <input type="hidden" name="decided_by" value="live_dev_home" />
                <select name="decision_status" aria-label="factor asset decision state">
                  <option value="hold">保留观察 / Hold</option>
                  <option value="promote">晋升 / Promote</option>
                  <option value="reject">拒绝 / Reject</option>
