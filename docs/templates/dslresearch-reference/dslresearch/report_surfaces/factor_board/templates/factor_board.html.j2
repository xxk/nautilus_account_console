  {%- endmacro %}

  {% macro assetization_readiness_section(assetization_readiness) -%}
  {% if assetization_readiness and assetization_readiness.rows %}
  <section class="assetization-readiness" id="assetization-readiness-detail" data-testid="factor-board-assetization-readiness">
    <div class="assetization-readiness-header">
      <div>
        <h2 class="assetization-readiness-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="assetization-readiness-case-ref">{{ display_case_ref }}</span>{% endif %}资产化准备度明细 / Assetization Readiness Detail</h2>
