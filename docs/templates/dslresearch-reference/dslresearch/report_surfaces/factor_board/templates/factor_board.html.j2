                <span class="decision-lane-value">{{ row.decision_facet.formal_verdict if row.decision_facet else row.validation_verdict }}</span>
              </div>
              <div class="decision-lane" data-testid="decision-lane-asset-decision" data-lane-source="factor_asset_decision_projection">
                <span class="decision-lane-label">Asset Decision</span>
                <span class="decision-lane-value">{{ row.lifecycle_decision_status or "no_decision" }}</span>
              </div>
              <div class="decision-lane" data-testid="decision-lane-global-inclusion" data-lane-source="successful_factor_global_projection">
                <span class="decision-lane-label">Global Inclusion</span>
                <span class="decision-lane-value">{{ row.global_inclusion_state or "not_included" }}</span>
              </div>
            </div>
            {% if row.decision_gate %}
