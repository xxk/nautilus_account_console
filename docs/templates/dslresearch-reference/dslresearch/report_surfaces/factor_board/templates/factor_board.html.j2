        {% endif %}
      </div>
    <div class="input-scope-scroll">
      <table class="input-scope-table" data-testid="compiled-input-scope-table">
        <thead>
          <tr>
            <th>Case</th>
            <th>因子 / Factor</th>
            <th>标的 / Universe</th>
            <th>周期 / Period</th>
            <th>数据 / Dataset</th>
            <th>输出 / Outputs</th>
            <th>目标 / Research Goal</th>
