                  <li>{{ step }}</li>
                {% endfor %}
                </ul>
              </div>
              {% endif %}
            </div>
            {% endif %}
            {% if row.row_kind != "factor_asset" %}
              <span style="color:#98a2ad">—</span>
            {% elif row.lifecycle_decision_allowed is defined and not row.lifecycle_decision_allowed %}
              <span class="badge-state {{ row.factor_decision_disabled_class or 'fail' }}" data-testid="factor-decision-disabled-{{ row.factor_key }}">{{ row.factor_decision_disabled_label or "Blocked" }}</span>
