          {% if input_compiled_gate.reason_code %}<code>{{ input_compiled_gate.reason_code }}</code>{% endif %}
          {% if input_compiled_gate.next_action %}<span>next_action={{ input_compiled_gate.next_action }}</span>{% endif %}
