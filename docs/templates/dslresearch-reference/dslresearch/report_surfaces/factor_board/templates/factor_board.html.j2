              {% endif %}
              {% if row.lifecycle_decision_status and row.lifecycle_decision_status != "no_decision" %}
              <span class="decision-gate-badge ready" data-testid="lifecycle-decision-status">{{ row.lifecycle_decision_status }}</span>
              {% if row.lifecycle_decision_id %}
              <code data-testid="lifecycle-decision-id">{{ row.lifecycle_decision_id }}</code>
              {% endif %}
              {% endif %}
              {% if gate_display.auto_decomposition_steps is defined and gate_display.auto_decomposition_steps %}
              <div class="decision-gate-decomposition" data-testid="decision-gate-auto-decomposition">
