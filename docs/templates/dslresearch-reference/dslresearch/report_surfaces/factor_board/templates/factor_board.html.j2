          <tr data-testid="compiled-input-row">
            <td>
              {% if ci.case_ref %}
              <span class="case-ref-badge" data-testid="compiled-input-case-ref">{{ ci.case_ref }}</span><br />
              {% else %}
              <code class="input-scope-code" data-testid="compiled-input-case-id">{{ ci.case_id }}</code>
              {% endif %}
              {% if ci.storage_token and not ci.case_ref %}
              <br /><code class="input-scope-code" data-testid="compiled-input-storage-token">{{ ci.storage_token }}</code>
              {% endif %}
              {% if ci.acceptance_tier %}
              <br /><span class="chip" data-testid="compiled-input-acceptance-tier">tier={{ ci.acceptance_tier }}</span>
              {% endif %}
            </td>
            <td>
              <div class="input-lines">
                {% if ci.factor_key %}<div><strong>key</strong> <code class="input-scope-code" data-testid="compiled-input-factor-key">{{ ci.factor_key }}</code></div>{% endif %}
                {% if ci.factor_name %}<div><strong>name</strong> <code class="input-scope-code" data-testid="compiled-input-factor-name">{{ ci.factor_name }}</code></div>{% endif %}
                {% if ci.factor_op %}<div><strong>op</strong> <code class="input-scope-code" data-testid="compiled-input-factor-op">{{ ci.factor_op }}</code></div>{% endif %}
                <div>
                  {% if ci.factor_version %}<span class="chip" data-testid="compiled-input-factor-version">version={{ ci.factor_version }}</span>{% endif %}
                  {% if ci.factor_output_type %}<span class="chip" data-testid="compiled-input-factor-output-type">output={{ ci.factor_output_type }}</span>{% endif %}
                </div>
                {% if ci.factor_field_pairs %}
                <div data-testid="compiled-input-factor-fields">
                  {% for field in ci.factor_field_pairs %}<span class="chip">{{ field.label }}={{ field.value }}</span>{% endfor %}
                </div>
                {% elif ci.factor_fields %}
                <div data-testid="compiled-input-factor-fields">
                  {% for field in ci.factor_fields %}<span class="chip">field={{ field }}</span>{% endfor %}
                </div>
                {% endif %}
                {% if ci.factor_identities %}
                <div class="input-token-list" data-testid="compiled-input-factor-identities">
                  {% for factor_identity in ci.factor_identities %}<code class="input-scope-code" data-testid="compiled-input-factor-identity-token">{{ factor_identity }}</code>{% endfor %}
                </div>
                {% endif %}
                {% if ci.factor_families %}
                <div data-testid="compiled-input-factor-families">
                  {% for factor_family in ci.factor_families %}<span class="chip">{{ factor_family }}</span>{% endfor %}
                </div>
                {% endif %}
                {% if ci.pair_count %}<span class="chip" data-testid="compiled-input-pair-count">pair_count={{ ci.pair_count }}</span>{% endif %}
                {% if ci.trial_count %}<span class="chip" data-testid="compiled-input-trial-count">trial_count={{ ci.trial_count }}</span>{% endif %}
                {% if ci.static_subset_size %}<span class="chip" data-testid="compiled-input-static-subset-size">N={{ ci.static_subset_size }}</span>{% endif %}
              </div>
            </td>
            <td>
              {% if ci.base_universe_symbols %}
              <div><strong>U</strong></div>
              <div data-testid="compiled-input-base-universe-symbols">
                {% for s in ci.base_universe_symbols %}<span class="chip chip-sym">{{ s }}</span>{% endfor %}
              </div>
              {% endif %}
              {% if ci.selected_subset_symbols %}
              <div style="margin-top:4px"><strong>N</strong></div>
              <div data-testid="compiled-input-selected-subset-symbols">
                {% for s in ci.selected_subset_symbols %}<span class="chip chip-sym">{{ s }}</span>{% endfor %}
              </div>
              {% endif %}
              <div style="margin-top:4px"><strong>candidate_symbols</strong></div>
              <div data-testid="compiled-input-candidate-symbols">
                {% for s in ci.candidate_symbols %}<span class="chip chip-sym">{{ s }}</span>{% endfor %}
              </div>
              {% if ci.selection_mode %}<div style="margin-top:4px"><span class="chip" data-testid="compiled-input-selection-mode">mode={{ ci.selection_mode }}</span></div>{% endif %}
              {% if ci.selection_evidence_uri %}<div style="margin-top:4px"><strong>selection evidence</strong> <code class="input-scope-code" data-testid="compiled-input-selection-evidence-uri">{{ ci.selection_evidence_uri }}</code></div>{% endif %}
            </td>
            <td>
              {% if ci.frequency %}<div data-testid="compiled-input-frequency"><strong>frequency</strong> <code class="input-scope-code">{{ ci.frequency }}</code></div>{% endif %}
              {% if ci.train_period %}<div data-testid="compiled-input-train-period"><strong>Train</strong> <code class="input-scope-code">{{ ci.train_period }}</code></div>{% endif %}
              {% if ci.oos_period %}<div data-testid="compiled-input-oos-period"><strong>OOS</strong> <code class="input-scope-code">{{ ci.oos_period }}</code></div>{% endif %}
            </td>
            <td>
              {% if ci.provider_contract %}<div data-testid="compiled-input-provider-contract"><strong>provider</strong> <code class="input-scope-code">{{ ci.provider_contract }}</code></div>{% endif %}
              {% if ci.catalog_roots %}
              <div data-testid="compiled-input-catalog-roots">
                {% for catalog_root in ci.catalog_roots %}<code class="input-scope-code">{{ catalog_root }}</code>{% if not loop.last %}<br />{% endif %}{% endfor %}
              </div>
              {% endif %}
              {% if ci.meta_config_path %}<div data-testid="compiled-input-meta-config"><strong>meta</strong> <code class="input-scope-code">{{ ci.meta_config_path }}</code></div>{% endif %}
            </td>
            <td data-testid="compiled-input-expected-outputs">
              {% for output in ci.expected_outputs %}<span class="chip">{{ output }}</span>{% endfor %}
              {% if not ci.expected_outputs %}<span style="color:#98a2ad">—</span>{% endif %}
            </td>
            <td data-testid="compiled-input-research-goal">{{ ci.research_goal or "—" }}</td>
            <td><code class="input-scope-code" data-testid="compiled-input-dir">{{ ci.compiled_input_dir }}</code></td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
    </section>
    {% elif source_inputs %}
    <section class="input-card input-tab-panel" data-input-tab-panel="compiled" data-testid="compiled-input-scope" hidden>
      <div class="input-card-header" data-testid="compiled-input-card">
        <h2 class="input-card-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="compiled-input-card-case-ref">{{ display_case_ref }}</span>{% endif %}编译输入 / Compiled Input</h2>
        <p class="input-card-meta">compiled_input: not produced for this case</p>
        {% if input_compiled_gate %}
        <div class="input-gate-block {{ input_compiled_gate.status_class }}" data-testid="compiled-input-closeout-gate">
          <strong>Input / Compiled Input: {{ input_compiled_gate.status }}</strong>
          {% if input_compiled_gate.primary_rule %}<code>{{ input_compiled_gate.primary_rule }}</code>{% endif %}
          {% if input_compiled_gate.reason_code %}<code>{{ input_compiled_gate.reason_code }}</code>{% endif %}
          {% if input_compiled_gate.next_action %}<span>next_action={{ input_compiled_gate.next_action }}</span>{% endif %}
          {% if input_compiled_gate.root_cause_hint_zh %}<span>{{ input_compiled_gate.root_cause_hint_zh }}</span>{% endif %}
        </div>
        {% endif %}
      </div>
      <div class="input-scope-scroll">
        <table class="input-scope-table" data-testid="compiled-input-scope-table">
          <thead>
            <tr>
              <th>Case</th>
              <th>状态 / Status</th>
              <th>计划 / Validation Plan</th>
              <th>因子输入 / Factor Input</th>
              <th>源头文件 / Source</th>
            </tr>
          </thead>
          <tbody>
          {% for si in source_inputs %}
            <tr data-testid="compiled-input-policy-row">
              <td>
                {% if si.case_ref %}
                <span class="case-ref-badge" data-testid="compiled-input-case-ref">{{ si.case_ref }}</span>
                {% else %}
                <code class="input-scope-code" data-testid="compiled-input-case-id">{{ si.case_id }}</code>
                {% endif %}
              </td>
              <td>
                <span class="chip" data-testid="compiled-input-policy-status">not_produced_by_policy</span>
                {% if si.runtime_scope %}<div data-testid="compiled-input-policy-runtime-scope"><code class="input-scope-code">{{ si.runtime_scope }}</code></div>{% endif %}
                {% if si.purpose %}<div data-testid="compiled-input-policy-purpose">{{ si.purpose }}</div>{% endif %}
              </td>
              <td>
                {% if si.validation_plan_id %}
                <code class="input-scope-code" data-testid="compiled-input-policy-validation-plan-id">{{ si.validation_plan_id }}</code>
                {% else %}
                <span style="color:#98a2ad">—</span>
                {% endif %}
              </td>
              <td>
                {% if si.factor_identities %}
                <div class="input-token-list" data-testid="compiled-input-policy-factor-identities">
                  {% for factor_identity in si.factor_identities %}<code class="input-scope-code" data-testid="compiled-input-policy-factor-identity-token">{{ factor_identity }}</code>{% endfor %}
                </div>
                <div class="input-metric-list" data-testid="compiled-input-policy-metrics">
                {% if si.expected_search_count %}<span class="chip" data-testid="compiled-input-policy-expected-search-count">expected_search_count={{ si.expected_search_count }}</span>{% endif %}
                {% if si.retained_top_n %}<span class="chip" data-testid="compiled-input-policy-retained-top-n">retained_top_n={{ si.retained_top_n }}</span>{% endif %}
                {% if si.factor_count %}<span class="chip" data-testid="compiled-input-policy-factor-count">factor_count={{ si.factor_count }}</span>{% endif %}
                {% if si.factor_combination_size %}<span class="chip" data-testid="compiled-input-policy-factor-combination-size">combination_size={{ si.factor_combination_size }}</span>{% endif %}
                </div>
                {% else %}
                <span style="color:#98a2ad">—</span>
                {% endif %}
              </td>
              <td>
                {% if si.study_request_file %}<code class="input-scope-code" data-testid="compiled-input-policy-study-request-file">{{ si.study_request_file }}</code>{% endif %}
              </td>
            </tr>
