        {% for detail in candidate_evidence_details %}
          <tr data-testid="candidate-evidence-detail-row">
            <td><code>{{ detail.factor_key }}</code></td>
            <td>{{ detail.row_kind_label }}</td>
            <td>
              <a class="run-link{% if 'Selected' in detail.role_labels %} run-link-best{% endif %}" href="{{ detail.href }}" data-testid="candidate-evidence-run-link"><code>{{ detail.run_id }}</code></a>
            </td>
            <td>
              <div class="candidate-evidence-role-list" data-testid="candidate-evidence-detail-role">
                {% for role_label in detail.role_labels %}
                <span class="candidate-evidence-role {{ role_label | lower }}">{{ role_label }}</span>
                {% endfor %}
              </div>
            </td>
            <td>{{ detail.candidate_state or "—" }}</td>
            <td>{{ detail.validation_verdict_label or "—" }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  {% if evidence_authority_cards %}
  <section class="evidence-authority-panel" data-testid="factor-board-evidence-authority-panel">
    <div class="evidence-authority-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="evidence-authority-case-ref">{{ display_case_ref }}</span>{% endif %}证据权威 / Evidence Authority</div>
    <div class="evidence-authority-grid">
      {% for card in evidence_authority_cards %}
      <article class="evidence-authority-card" data-testid="evidence-authority-{{ card.kind }}">
        <div class="evidence-authority-card-title">{{ card.label }}</div>
        <div class="evidence-authority-line"><strong>Claim:</strong> {{ card.claim }}</div>
        <div class="evidence-authority-line"><strong>Proof:</strong> {{ card.proof }}</div>
        <div class="evidence-authority-line"><strong>Owner:</strong> {{ card.owner }}</div>
        <div class="evidence-authority-line"><strong>Next:</strong> {{ card.next_action }}</div>
      </article>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if filter_case_id %}
  <section class="verifier-strip" data-testid="factor-board-global-scope-note">
    <div class="verifier-strip-main">
      <strong>Scope</strong>
      <span>当前页面是按 case 过滤后的因子候选板，不是 Successful Factor Global View。</span>
      <code data-testid="factor-board-filter-case-id">{{ filter_case_id }}</code>
      <span>Successful Factor Global 聚合全局 formal accepted factors，不会按当前 case 自动内联到本页。</span>
    </div>
    <a class="portal-link primary" href="{{ successful_factor_global_uri }}" data-testid="factor-board-open-successful-factor-global-from-note">Open Successful Factor Global</a>
  </section>
  {% else %}
  <section class="verifier-strip" data-testid="factor-board-global-scope-note">
    <div class="verifier-strip-main">
      <strong>Scope</strong>
      <span data-testid="factor-board-global-scope-message">当前未选择 case，展示全部 cases / Global Board</span>
      <span>如需隔离单个 case，请使用 <code>?case_id=&lt;case_id or case_ref&gt;</code>。</span>
    </div>
    <a class="portal-link primary" href="{{ dev_home_uri }}" data-testid="factor-board-open-case-picker">Open Dev Home Case Picker</a>
  </section>
  {% endif %}

  <section class="semantics-rules" data-testid="factor-board-semantics-rules">
    <div class="semantics-rules-title">Semantics & Decision Rules</div>
    <div class="semantics-rules-body">
      {% if candidate_count > 0 or not input_prerequisite_blocked %}
      <section class="decision-gate-note" data-testid="factor-board-decision-gate-note">
        回测报告可随时查看；只有 Final 验收 ready 后，才允许把因子结论写入 accepted / promoted / rejected。
      </section>
      {% endif %}
      <section class="verifier-strip" data-testid="factor-board-c-ready-legend">
        <div class="verifier-strip-main">
          <strong>C-ready row types</strong>
          <span class="semantic-kind asset">因子结论 / Factor Conclusion</span>
          <span class="semantic-kind trial">回测证据 / Backtest Evidence</span>
          <span class="semantic-kind planned">计划因子 / Planned Factor</span>
          <span>计划因子必须显示 <strong>尚不可用</strong>；Formal PASS 只代表 validation verdict，不代表投资质量或组合配置结论。</span>
        </div>
      </section>
    </div>
  </section>
</div>

<script>
(function () {
  var currentStateFilter = 'all';
  var currentRowKindFilter = 'all';
  var syncButton = document.getElementById('sync-control-plane-button');
  var syncStatus = document.getElementById('sync-control-plane-status');
  var assuranceDrawer = document.querySelector('[data-testid="factor-board-assurance-drawer"]');
  var assuranceBackdrop = document.querySelector('[data-testid="factor-board-assurance-backdrop"]');

  function queryByDataAttr(root, attrName, attrValue) {
    if (!root || !attrValue) {
      return null;
    }
    return Array.prototype.find.call(root.querySelectorAll('[' + attrName + ']'), function (item) {
      return item.getAttribute(attrName) === attrValue;
    }) || null;
  }

  function scrollAssuranceTarget(target) {
    if (!target) {
      return;
    }
    if (assuranceDrawer && assuranceDrawer.contains(target)) {
      var panelRect = assuranceDrawer.getBoundingClientRect();
      var targetRect = target.getBoundingClientRect();
      var offset = targetRect.top - panelRect.top + assuranceDrawer.scrollTop - 16;
      assuranceDrawer.scrollTo({top: offset, behavior: 'smooth'});
    } else {
      target.scrollIntoView({behavior: 'smooth', block: 'start'});
    }
  }

  function filterAssuranceCards(targetCard) {
    var cards = assuranceDrawer.querySelectorAll('[data-assurance-card]');
    cards.forEach(function (card) {
      card.style.display = (!targetCard || card.getAttribute('data-assurance-card') === targetCard) ? '' : 'none';
    });
  }

  function openAssuranceDrawer(targetCard, targetRow, targetDetail) {
    if (!assuranceDrawer) {
      return;
    }
    filterAssuranceCards(targetCard);
    assuranceDrawer.classList.add('open');
    assuranceDrawer.setAttribute('aria-hidden', 'false');
    if (assuranceBackdrop) {
      assuranceBackdrop.classList.add('open');
    }
    requestAnimationFrame(function () {
      assuranceDrawer.scrollTo({top: 0, behavior: 'instant'});
      if (targetDetail === 'row-verifier' && targetRow) {
        var verifierDetail = queryByDataAttr(assuranceDrawer, 'data-row-verifier-row-detail', targetRow);
        scrollAssuranceTarget(verifierDetail);
      } else if (targetCard) {
        var card = queryByDataAttr(assuranceDrawer, 'data-assurance-card', targetCard);
        scrollAssuranceTarget(card);
      } else if (targetRow) {
        var detail = queryByDataAttr(assuranceDrawer, 'data-assurance-row-detail', targetRow);
        scrollAssuranceTarget(detail);
      }
    });
  }

  document.querySelectorAll('[data-assurance-open]').forEach(function (trigger) {
    trigger.addEventListener('click', function (event) {
      event.preventDefault();
      openAssuranceDrawer(
        trigger.getAttribute('data-assurance-target') || '',
        trigger.getAttribute('data-assurance-row') || '',
        trigger.getAttribute('data-assurance-detail') || ''
      );
    });
  });
  document.querySelectorAll('[data-assurance-close]').forEach(function (trigger) {
    trigger.addEventListener('click', function (event) {
      event.preventDefault();
      if (!assuranceDrawer) return;
      filterAssuranceCards('');
      assuranceDrawer.classList.remove('open');
      assuranceDrawer.setAttribute('aria-hidden', 'true');
      if (assuranceBackdrop) {
        assuranceBackdrop.classList.remove('open');
      }
    });
  });

  document.querySelectorAll('[data-input-tab-target]').forEach(function (tab) {
    tab.addEventListener('click', function (event) {
      event.preventDefault();
      var target = tab.getAttribute('data-input-tab-target') || '';
      document.querySelectorAll('[data-input-tab-target]').forEach(function (item) {
        var active = item.getAttribute('data-input-tab-target') === target;
        item.classList.toggle('active', active);
        item.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      document.querySelectorAll('[data-input-tab-panel]').forEach(function (panel) {
        panel.hidden = panel.getAttribute('data-input-tab-panel') !== target;
      });
    });
  });

  function applyBoardFilters() {
    var state = currentStateFilter;
    var rows = document.querySelectorAll('#factor-board-table tbody tr');
    rows.forEach(function (row) {
      var rowState = row.getAttribute('data-state') || '';
      var rowKind = row.getAttribute('data-row-kind') || '';
      var matchesState = state === 'all' || rowState === state;
      var matchesRowKind = currentRowKindFilter === 'all' || rowKind === currentRowKindFilter;
      if (matchesState && matchesRowKind) {
        row.classList.remove('hidden');
      } else {
        row.classList.add('hidden');
      }
    });
  }

  function filterBoard(state) {
    currentStateFilter = state;
    applyBoardFilters();
    document.querySelectorAll('.filter-chip[data-state]').forEach(function (btn) {
      var btnState = btn.getAttribute('data-state') || '';
      if (btnState === state) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
  }
  window.filterBoard = filterBoard;
  document.querySelectorAll('.filter-chip[data-state]').forEach(function (btn) {
    btn.addEventListener('click', function (event) {
      event.preventDefault();
      filterBoard(btn.getAttribute('data-state') || 'all');
    });
  });
  document.querySelectorAll('[data-row-kind-filter]').forEach(function (select) {
    select.addEventListener('change', function () {
      currentRowKindFilter = select.value || 'all';
      applyBoardFilters();
    });
  });

  function extractEquityValues(payload) {
    var points = [];
    if (payload && Array.isArray(payload.points)) {
      points = payload.points;
    } else if (payload && Array.isArray(payload.equity_curve)) {
      points = payload.equity_curve;
    }
    return points.map(function (point) {
      if (point && typeof point === 'object') {
        return Number(point.equity ?? point.value ?? point.nav ?? point.y);
      }
      return Number(point);
    }).filter(function (value) {
      return Number.isFinite(value);
    });
  }

  function sampleEquityValues(values, maxPoints) {
    if (values.length <= maxPoints) {
      return values;
    }
    var sampled = [];
    var step = (values.length - 1) / (maxPoints - 1);
    for (var index = 0; index < maxPoints; index += 1) {
      sampled.push(values[Math.round(index * step)]);
    }
    return sampled;
  }

  function buildEquityPolyline(values) {
    if (!values.length) {
      return '';
    }
    if (values.length === 1) {
      return '110,32';
    }
    var minValue = Math.min.apply(null, values);
    var maxValue = Math.max.apply(null, values);
    var range = maxValue - minValue;
    var width = 212;
    var height = 52;
    var left = 4;
    var top = 6;
    return values.map(function (value, index) {
      var x = left + (index / (values.length - 1)) * width;
      var yRatio = range === 0 ? 0.5 : (value - minValue) / range;
      var y = top + (1 - yRatio) * height;
      return x.toFixed(2) + ',' + y.toFixed(2);
    }).join(' ');
  }

  function hydrateDynamicEquitySparklines() {
    document.querySelectorAll('[data-equity-curve-src]').forEach(function (chart) {
      var source = chart.getAttribute('data-equity-curve-src') || '';
      var polyline = chart.querySelector('[data-equity-polyline]');
      if (!source || !polyline || chart.getAttribute('data-equity-loaded') === 'true') {
        return;
      }
      fetch(source, {headers: {'Accept': 'application/json'}})
        .then(function (response) {
          if (!response.ok) {
            throw new Error('equity curve fetch failed: HTTP ' + response.status);
          }
          return response.json();
        })
        .then(function (payload) {
          var values = sampleEquityValues(extractEquityValues(payload), 240);
          var points = buildEquityPolyline(values);
          if (!points) {
            throw new Error('equity curve payload has no numeric points');
          }
          polyline.setAttribute('points', points);
          chart.setAttribute('data-equity-loaded', 'true');
        })
        .catch(function () {
          chart.setAttribute('data-equity-load-state', 'failed');
        });
    });
  }
  hydrateDynamicEquitySparklines();

  function setColumnGroupVisibility(group, visible) {
    var cells = document.querySelectorAll('#factor-board-table [data-col-group="' + group + '"]');
    cells.forEach(function (cell) {
      if (visible) {
        cell.classList.remove('col-group-hidden');
      } else {
        cell.classList.add('col-group-hidden');
      }
    });
  }

  document.querySelectorAll('.filter-chip[data-col-group-toggle]').forEach(function (btn) {
    btn.addEventListener('click', function (event) {
      event.preventDefault();
      var group = btn.getAttribute('data-col-group-toggle') || '';
      var nextVisible = !btn.classList.contains('active');
      btn.classList.toggle('active', nextVisible);
      btn.setAttribute('aria-pressed', nextVisible ? 'true' : 'false');
      setColumnGroupVisibility(group, nextVisible);
    });
  });

  if (syncButton) {
    syncButton.addEventListener('click', function () {
      var syncUrl = syncButton.getAttribute('data-sync-url') || '';
      if (!syncUrl) {
        return;
      }
      syncButton.disabled = true;
      syncStatus.textContent = '同步中...';
      fetch(syncUrl, {method: 'POST', headers: {'Accept': 'application/json'}})
        .then(function (response) {
          return response.json().then(function (payload) {
            if (!response.ok || payload.status !== 'ok') {
              throw new Error(payload.message || ('sync failed: HTTP ' + response.status));
            }
            syncStatus.textContent = '已同步，刷新中...';
            window.location.reload();
          });
        })
        .catch(function (error) {
          syncStatus.textContent = error.message || '同步失败';
          syncButton.disabled = false;
        });
    });
  }

  document.querySelectorAll('[data-decision-form]').forEach(function (form) {
    form.addEventListener('submit', function (event) {
      event.preventDefault();
      var status = form.querySelector('[data-decision-status]');
      var button = form.querySelector('button[type="submit"]');
      var reason = form.querySelector('input[name="reason"]');
      if (!reason || !reason.value.trim()) {
        if (status) status.textContent = '请填写决策原因';
        return;
      }
      if (!window.confirm('确认记录这条因子生命周期决策吗？')) {
        return;
      }
      if (button) button.disabled = true;
      if (status) status.textContent = '记录中...';
      fetch(form.getAttribute('action') || '', {
        method: 'POST',
        body: new URLSearchParams(new FormData(form)),
        headers: {'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded'}
      })
        .then(function (response) {
          return response.json().then(function (payload) {
            if (!response.ok || payload.status !== 'ok') {
              throw new Error(payload.message || ('decision failed: HTTP ' + response.status));
            }
            if (status) status.textContent = '已记录，刷新中...';
            window.location.reload();
          });
        })
        .catch(function (error) {
          if (status) status.textContent = error.message || '记录失败';
          if (button) button.disabled = false;
        });
    });
  });
})();
</script>
</body>
</html>
