    {% endif %}
    {% if assetization_candidate_readiness_details %}
    <section class="assetization-readiness-subsection" data-testid="candidate-readiness-matrix-section">
      <h3 class="assetization-readiness-subtitle">Candidate Readiness Matrix / 全候选准备度矩阵</h3>
      <p class="assetization-readiness-scope-note" data-testid="candidate-readiness-matrix-scope-note">Candidate readiness rows come from selected retained-final factors. Row count is the selected factor count, not the generated package count.</p>
      <div class="assetization-readiness-scroll" data-testid="assetization-candidate-readiness-detail">
        <table class="candidate-evidence-table" data-testid="assetization-candidate-readiness-table">
          <thead>
            <tr>
              <th>因子 / Factor</th>
              <th>研究质量 / Research Quality</th>
              <th>Profit Gate</th>
              <th>Cost / Yearly</th>
              <th>Assetization Package</th>
              <th>Typed Blocker</th>
              <th>下一动作 / Next Action</th>
            </tr>
          </thead>
          <tbody>
          {% for detail in assetization_candidate_readiness_details %}
            <tr data-testid="assetization-candidate-readiness-row" data-factor-key="{{ detail.factor_key }}">
              <td><code>{{ detail.factor_key }}</code></td>
              <td><span class="readiness-status pass">{{ detail.research_quality }}</span></td>
              <td><span class="readiness-status {{ 'pass' if detail.profit_gate_status == 'pass' else 'blocked' }}">{{ detail.profit_gate_status }}</span></td>
              <td>
                <code>{{ detail.cost_stress_summary }}</code>
                <code>{{ detail.yearly_slice_summary }}</code>
              </td>
              <td><span class="readiness-status {{ 'pass' if detail.assetization_package_status == 'backtest_ready' else 'evidence_gap' }}">{{ detail.assetization_package_status }}</span></td>
              <td>{% if detail.typed_blocker %}<code>{{ detail.typed_blocker }}</code>{% else %}<span class="next-action-none">none</span>{% endif %}</td>
              <td><code>{{ detail.next_action }}</code></td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
    {% endif %}
    <section class="assetization-readiness-subsection secondary" data-testid="generated-package-evidence-section">
      <h3 class="assetization-readiness-subtitle">Generated Package Evidence / 已生成资产化包证据</h3>
      <p class="assetization-readiness-scope-note" data-testid="generated-package-evidence-scope-note">Only materialized packages are shown here. Candidate readiness is shown in the matrix above.</p>
      {% set generated_package_rows = assetization_readiness.generated_package_rows %}
      {% if generated_package_rows %}
      <div class="assetization-readiness-scroll">
        <table class="assetization-readiness-table" data-testid="assetization-readiness-table" data-testid-secondary="generated-package-evidence-table">
        <thead>
          <tr>
            <th>因子 / Factor</th>
            <th>研究状态 / Research</th>
            <th>执行证据 / Execution</th>
            <th>资产化包 / Package</th>
            <th>组合质量 / Portfolio</th>
            <th>投资准备 / Readiness</th>
            <th>投资决策 / Decision</th>
            <th>证据与下一步 / Evidence &amp; Next</th>
          </tr>
        </thead>
        <tbody>
        {% for row in generated_package_rows %}
          <tr data-testid="{% if row.backtestable_portfolio_package %}generated-package-evidence-row{% else %}assetization-readiness-row{% endif %}" data-factor-key="{{ row.factor_identity }}" data-decision-status="{{ row.decision_status }}">
            <td>
              <code>{{ row.factor_identity }}</code>
              {% if row.case_ref %}<div class="assetization-readiness-meta">{{ row.case_ref }}</div>{% endif %}
            </td>
            <td>
              <span class="readiness-status {{ row.formal_status }}">formal={{ row.formal_status }}</span>
              <span class="readiness-status {{ row.retained_final_status }}">retained_final={{ row.retained_final_status }}</span>
            </td>
            <td>
              <span class="readiness-status {{ row.execution_reality_status }}" data-testid="assetization-readiness-execution-reality">execution_reality={{ row.execution_reality_status }}</span>
              <div class="assetization-readiness-meta" data-testid="assetization-readiness-execution-reality-reason"><code>{{ row.execution_reality_reason }}</code></div>
              {% if row.execution_reality_proof %}
              <details class="readiness-summary-drilldown" data-testid="assetization-readiness-execution-reality-proof" open>
                <summary>Execution Reality Proof</summary>
                <div class="readiness-compact-stack">
                  <code>execution_verdict={{ row.execution_reality_proof.execution_verdict }}</code>
                  <code>fill_source={{ row.execution_reality_proof.fill_source }}</code>
                  <code>session_check={{ row.execution_reality_proof.session_check }}</code>
                  <code>cost_check={{ row.execution_reality_proof.cost_check }}</code>
                  <code>causality_check={{ row.execution_reality_proof.causality_check }}</code>
                  <code>next_action={{ row.execution_reality_proof.next_action }}</code>
                  <code>portfolio_run_id={{ row.execution_reality_proof.scope.portfolio_run_id }}</code>
                  <code>factor_ref={{ row.execution_reality_proof.scope.factor_ref }}</code>
                  {% if row.execution_reality_proof.scope.portfolio_uid %}<code>portfolio_uid={{ row.execution_reality_proof.scope.portfolio_uid }}</code>{% endif %}
                  {% if row.execution_reality_proof.scope.portfolio_spec_ref %}<code>portfolio_spec_ref={{ row.execution_reality_proof.scope.portfolio_spec_ref }}</code>{% endif %}
                  {% if row.execution_reality_proof.scope.binding_id %}<code>binding_id={{ row.execution_reality_proof.scope.binding_id }}</code>{% endif %}
                  {% if row.execution_reality_proof.scope.strategy_identity %}<code>strategy_identity={{ row.execution_reality_proof.scope.strategy_identity }}</code>{% endif %}
                  {% if row.execution_reality_proof.scope.source_run_ref %}<code>source_run_ref={{ row.execution_reality_proof.scope.source_run_ref }}</code>{% endif %}
                  {% if row.execution_reality_proof.scope.source_run_checksum %}<code>source_run_checksum={{ row.execution_reality_proof.scope.source_run_checksum }}</code>{% endif %}
                  {% for proof_gap in row.execution_reality_proof.evidence_gaps %}
                  <code>evidence_gap={{ proof_gap }}</code>
                  {% endfor %}
                </div>
              </details>
              {% endif %}
              {% if row.handoff_chain_summary %}
              <details class="readiness-summary-drilldown" data-testid="assetization-readiness-handoff-chain" open>
                <summary>Cross-repo handoff chain</summary>
                <div class="readiness-compact-stack">
                  <code>handoff_chain_id={{ row.handoff_chain_summary.handoff_chain_id }}</code>
                  <code>terminal_handoff_gap={{ row.handoff_chain_summary.terminal_handoff_gap.gap_id }}</code>
                  <code>terminal_owner={{ row.handoff_chain_summary.terminal_handoff_gap.owner_domain }}</code>
                  <code>terminal_expected_artifact={{ row.handoff_chain_summary.terminal_handoff_gap.expected_artifact }}</code>
                  <code>nearest_executable_gap={{ row.handoff_chain_summary.nearest_executable_gap.gap_id }}</code>
                  <code>owner={{ row.handoff_chain_summary.nearest_executable_gap.owner_domain }}</code>
                  <code>expected_artifact={{ row.handoff_chain_summary.nearest_executable_gap.expected_artifact }}</code>
                  {% for chain_node in row.handoff_chain_summary.chain %}
                  <code>{{ chain_node.node }}={{ chain_node.status }}; owner={{ chain_node.owner }}</code>
                  {% endfor %}
                </div>
              </details>
              {% endif %}
            </td>
            <td>
              {% if row.backtestable_portfolio_package %}
              <span class="readiness-status {{ row.backtestable_portfolio_package.package_status }}">package_status={{ row.backtestable_portfolio_package.package_status }}</span>
              <div class="package-report-actions" data-testid="assetization-readiness-package-report-actions">
                <span class="package-report-actions-title">回测报告 / Backtest Reports</span>
                {% for scope in row.backtestable_portfolio_package.backtest_scopes %}
                  {% if row.backtestable_portfolio_package.package_status == "backtest_ready" and scope.formal_backtest_report_href %}
                  <a class="evidence-link package-report-link" data-testid="assetization-readiness-formal-portfolio-report-link-{{ scope.scope_id }}" href="{{ scope.formal_backtest_report_href }}">打开回测报告 / Open backtest report · {{ scope.scope_id }}</a>
                  {% else %}
                  <span class="evidence-link package-report-link disabled" data-testid="assetization-readiness-formal-portfolio-report-disabled-{{ scope.scope_id }}">{% if scope.formal_backtest_report_blocker %}{{ scope.formal_backtest_report_blocker }}{% else %}formal_portfolio_report_waits_for_backtest_ready{% endif %} · {{ scope.scope_id }}</span>
                  {% endif %}
                {% endfor %}
              </div>
              <details class="readiness-summary-drilldown" data-testid="assetization-readiness-backtestable-portfolio-package"{% if row.backtestable_portfolio_package.blockers or row.backtestable_portfolio_package.package_status != "backtest_ready" %} open{% endif %}>
                <summary>
                  <span class="decision-package-summary">
                    <strong>Backtestable portfolio package</strong>
                    <span class="decision-package-filter">package_status={{ row.backtestable_portfolio_package.package_status }}</span>
                    <span class="decision-package-filter evidence">evidence {{ row.backtestable_portfolio_package.evidence_refs|length }} refs</span>
                    {% if row.backtestable_portfolio_package.blockers %}
                    <span class="decision-package-filter exception">blockers {{ row.backtestable_portfolio_package.blockers|length }}</span>
                    {% endif %}
                  </span>
                </summary>
                <div class="readiness-compact-stack">
                  <code>candidate_identity={{ row.backtestable_portfolio_package.candidate_identity }}</code>
                  <code>source_fingerprint={{ row.backtestable_portfolio_package.source_fingerprint }}</code>
                  <code>next_action={{ row.backtestable_portfolio_package.next_action }}</code>
                  {% if row.backtestable_portfolio_package.blockers %}
                    {% for blocker in row.backtestable_portfolio_package.blockers %}
                    <code>blocker={{ blocker }}</code>
                    {% endfor %}
                  {% else %}
                  <code>blockers=none</code>
                  {% endif %}
                  {% for scope in row.backtestable_portfolio_package.backtest_scopes %}
                  <code>scope_id={{ scope.scope_id }}</code>
                  <code>includes_existing_portfolio_strategies={{ scope.includes_existing_portfolio_strategies }}</code>
                  <code>equity_curve_ref={{ scope.equity_curve_ref }}</code>
                  <code>metrics_ref={{ scope.metrics_ref }}</code>
                  <code>orders_or_positions_ref={{ scope.orders_or_positions_ref }}</code>
                  <code>formal_backtest_report_ref={{ scope.formal_backtest_report_blocker or scope.formal_backtest_report_ref_display or scope.formal_backtest_report_ref }}</code>
                  <code>canonical_verifier_findings_ref={{ scope.canonical_verifier_findings_ref }}</code>
                  <code>canonical_verifier_fingerprint={{ scope.canonical_verifier_fingerprint }}</code>
                  <code>verifier_run_id={{ scope.verifier_run_id }}</code>
                  <code>verifier_scope={{ scope.verifier_scope }}</code>
                  {% if scope.derived_portfolio_summary_ref %}<code>derived_portfolio_summary_ref={{ scope.derived_portfolio_summary_ref }}</code>{% endif %}
                  {% if scope.derived_component_findings_ref %}<code>derived_component_findings_ref={{ scope.derived_component_findings_ref }}</code>{% endif %}
                  {% if scope.derived_report_ref %}<code>derived_report_ref={{ scope.derived_report_ref }}</code>{% endif %}
                  {% endfor %}
                  {% for evidence_ref in row.backtestable_portfolio_package.evidence_refs %}
                  <code title="{{ evidence_ref }}">{{ evidence_ref }}</code>
                  {% endfor %}
                </div>
              </details>
              {% elif row.portfolio_admission_candidate %}
              <details class="readiness-summary-drilldown" data-testid="assetization-readiness-backtestable-portfolio-package-empty" open>
                <summary>Backtestable portfolio package</summary>
                <div class="readiness-compact-stack">
                  <code>backtestable_portfolio_package_status=missing</code>
                  <code>next_action=publish_backtestable_portfolio_package</code>
                </div>
              </details>
              {% else %}
              <code>backtestable_portfolio_package_status=missing</code>
              {% endif %}
            </td>
            <td>
              <div data-testid="assetization-readiness-portfolio-uplift">
                <span class="readiness-status {{ row.uplift_status }}" data-testid="assetization-readiness-uplift">uplift={{ row.uplift_status }}</span>
                <span class="readiness-status {{ row.diversification_status }}" data-testid="assetization-readiness-diversification">diversification={{ row.diversification_status }}</span>
                <span class="readiness-status {{ row.risk_budget_status }}" data-testid="assetization-readiness-risk-budget">risk_budget={{ row.risk_budget_status }}</span>
                <span class="readiness-status {{ row.correlation_status }}" data-testid="assetization-readiness-correlation">correlation={{ row.correlation_status }}</span>
                <span class="readiness-status {{ row.allocation_status }}" data-testid="assetization-readiness-allocation">allocation={{ row.allocation_status }}</span>
              </div>
              <details class="readiness-summary-drilldown" data-testid="assetization-readiness-uplift-summary">
                <summary>Portfolio detail</summary>
                <div class="readiness-compact-stack">
                  <code class="readiness-compact-code" title="uplift_summary={{ row.uplift_summary }}">uplift_summary={{ row.uplift_summary }}</code>
                  <code class="readiness-compact-code" data-testid="assetization-readiness-risk-contribution" title="risk_contribution_summary={{ row.risk_contribution_summary }}">risk_contribution_summary={{ row.risk_contribution_summary }}</code>
                  <code class="readiness-compact-code" title="correlation_summary={{ row.correlation_summary }}">correlation_summary={{ row.correlation_summary }}</code>
                  <code class="readiness-compact-code" title="allocation_summary={{ row.allocation_summary }}">allocation_summary={{ row.allocation_summary }}</code>
                </div>
              </details>
            </td>
            <td>
              <span class="readiness-status {{ row.assetization_decision_ready_status_class }}" data-testid="assetization-readiness-decision-ready">asset_decision_ready={{ row.assetization_decision_ready_display }}</span>
              <span class="readiness-status {{ row.oos_status }}" data-testid="assetization-readiness-oos">oos={{ row.oos_status }}</span>
              <span class="readiness-status {{ row.rolling_status }}" data-testid="assetization-readiness-rolling">rolling={{ row.rolling_status }}</span>
              <span class="readiness-status {{ row.regime_status }}" data-testid="assetization-readiness-regime">regime={{ row.regime_status }}</span>
              <span class="readiness-status {{ row.cost_status }}" data-testid="assetization-readiness-cost">cost={{ row.cost_status }}</span>
              <span class="readiness-status {{ row.slippage_status }}" data-testid="assetization-readiness-slippage">slippage={{ row.slippage_status }}</span>
              <span class="readiness-status {{ row.turnover_status }}" data-testid="assetization-readiness-turnover">turnover={{ row.turnover_status }}</span>
              <span class="readiness-status {{ row.capacity_status }}" data-testid="assetization-readiness-capacity">capacity={{ row.capacity_status }}</span>
              <details class="readiness-summary-drilldown">
                <summary>Cost/capacity detail</summary>
                <div class="readiness-compact-stack">
                  <code class="readiness-compact-code" data-testid="assetization-readiness-cost-assumptions" title="cost_assumptions={{ row.cost_assumptions }}">cost_assumptions={{ row.cost_assumptions }}</code>
                  <code class="readiness-compact-code" data-testid="assetization-readiness-turnover-summary" title="turnover_summary={{ row.turnover_summary }}">turnover_summary={{ row.turnover_summary }}</code>
                  <code class="readiness-compact-code" data-testid="assetization-readiness-capacity-summary" title="capacity_summary={{ row.capacity_summary }}">capacity_summary={{ row.capacity_summary }}</code>
                  <code class="readiness-compact-code" data-testid="assetization-readiness-liquidity-summary" title="liquidity_summary={{ row.liquidity_summary }}">liquidity_summary={{ row.liquidity_summary }}</code>
                </div>
              </details>
              {% set production_quality_status = row.production_quality_status|default("") %}
              {% set production_quality_status_class = row.production_quality_status_class|default("") %}
              {% if not production_quality_status %}
                {% if row.portfolio_admission_candidate and row.portfolio_admission_candidate.candidate_ready_basis == "research_backtest_candidate_ready" %}
                  {% set production_quality_status = "monitoring=not_applicable_research_backtest" %}
                  {% set production_quality_status_class = "neutral" %}
                {% else %}
                  {% set production_quality_status = "monitoring=not_run" %}
                  {% set production_quality_status_class = "not_run" %}
                {% endif %}
              {% endif %}
              <div class="assetization-readiness-meta">
                <code class="readiness-compact-code readiness-status {{ production_quality_status_class }}">{{ production_quality_status }}</code>
              </div>
              {% if row.blockers %}
              <div class="assetization-readiness-meta" data-testid="assetization-readiness-blockers">
                {% for blocker in row.blockers %}
                <code>{{ blocker }}</code>
                {% endfor %}
              </div>
              {% endif %}
            </td>
            <td>
              <span class="readiness-status {{ row.decision_package_status }}">decision_package={{ row.decision_package_status }}</span>
              <div class="assetization-readiness-meta"><code>decision_status={{ row.decision_status }}</code></div>
              <div class="decision-package-controls" data-testid="assetization-readiness-decision-package-filters" aria-label="Decision package scoped filters">
                <span class="decision-package-filter exception">blockers first</span>
                <span class="decision-package-filter">all checks</span>
                <span class="decision-package-filter evidence">evidence refs</span>
                <span class="decision-package-filter" data-testid="decision-package-group-candidate">Candidate</span>
                <span class="decision-package-filter" data-testid="decision-package-group-package">Package</span>
                <span class="decision-package-filter evidence" data-testid="decision-package-group-evidence">Evidence</span>
                <span class="decision-package-filter" data-testid="decision-package-group-rule">Rule</span>
              </div>
              {% if row.decision_status_label != row.decision_status %}
              <div class="assetization-readiness-meta" data-testid="assetization-readiness-ui-decision-label">{{ row.decision_status_label }}</div>
              {% endif %}
              {% if row.approved_factor_ref_handoff %}
              <details class="readiness-summary-drilldown" data-testid="adr112-fplus-approved-factor-ref-handoff" open>
                <summary>
                  <span class="decision-package-summary">
                    <strong>Research Deliverable</strong>
                    <span class="decision-package-filter success" data-testid="adr112-fplus-approved-factor-ref-issued">ApprovedFactorRef={{ row.approved_factor_ref_handoff.status }}</span>
                  </span>
                </summary>
                <div class="readiness-compact-stack">
                  <code>owner={{ row.approved_factor_ref_handoff.owner }}</code>
                  <code>factor_ref_uid={{ row.approved_factor_ref_handoff.factor_ref_uid }}</code>
                  <code>artifact={{ row.approved_factor_ref_handoff.artifact_ref }}</code>
                  <code>mint_preconditions={{ row.approved_factor_ref_handoff.mint_preconditions }}</code>
                  <a class="evidence-link" data-testid="adr113-view-approved-factor-ref" href="{{ dev_home_uri }}approved-factor-ref.html?factor_ref_uid={{ row.approved_factor_ref_handoff.factor_ref_uid }}">View Ref</a>
                  {% if row.approved_factor_ref_handoff.execution_reality_handoff %}
                  <div data-testid="p034-execution-reality-handoff">
                    <strong>Execution Reality Handoff</strong>
                    <code>execution_reality_handoff={{ row.approved_factor_ref_handoff.execution_reality_handoff.status }}</code>
                    <code>owner_domain={{ row.approved_factor_ref_handoff.execution_reality_handoff.owner_domain }}</code>
                    <code>artifact_kind={{ row.approved_factor_ref_handoff.execution_reality_handoff.artifact_kind }}</code>
                    <code>manifest_ref={{ row.approved_factor_ref_handoff.execution_reality_handoff.manifest_ref }}</code>
                    <code>expected_artifact={{ row.approved_factor_ref_handoff.execution_reality_handoff.expected_artifact }}</code>
                    <code>proof_checksum={{ row.approved_factor_ref_handoff.execution_reality_handoff.proof_checksum }}</code>
                    {% if row.approved_factor_ref_handoff.execution_reality_handoff.schema_version %}
                    <code>schema_version={{ row.approved_factor_ref_handoff.execution_reality_handoff.schema_version }}</code>
                    {% endif %}
                    {% if row.approved_factor_ref_handoff.execution_reality_handoff.produced_at %}
                    <code>produced_at={{ row.approved_factor_ref_handoff.execution_reality_handoff.produced_at }}</code>
                    {% endif %}
                  </div>
                  {% endif %}
                  <div data-testid="adr112-fplus-scope-boundary">
                  <strong>Scope Boundary</strong>
                  {% for boundary in row.approved_factor_ref_handoff.negative_boundary %}
                  <span class="decision-package-filter neutral">{{ boundary }}</span>
                  {% endfor %}
                  </div>
                </div>
              </details>
              <details class="readiness-summary-drilldown" data-testid="adr112-fplus-assetization-readiness-pointer" open>
                <summary>
                  <span class="decision-package-summary">
                    <strong>Assetization Readiness</strong>
                    {% set handoff_readiness_status = row.approved_factor_ref_handoff.assetization_readiness.status|string %}
                    <span class="decision-package-filter {% if handoff_readiness_status|lower == 'pass' %}success{% else %}exception{% endif %}" data-testid="adr112-fplus-assetization-readiness-status">{{ row.approved_factor_ref_handoff.assetization_readiness.status }}</span>
                  </span>
                </summary>
                <div class="readiness-compact-stack">
                  <code>blocker={{ row.approved_factor_ref_handoff.assetization_readiness.blocker }}</code>
                  <code>next_owner={{ row.approved_factor_ref_handoff.assetization_readiness.next_owner }}</code>
                  <code>next_artifact={{ row.approved_factor_ref_handoff.assetization_readiness.next_artifact }}</code>
                </div>
              </details>
              <details class="readiness-summary-drilldown" data-testid="adr112-fplus-owner-decision-pointer" open>
                <summary>
                  <span class="decision-package-summary">
                    <strong>Owner Decision</strong>
                    <span class="decision-package-filter">owner_decision={{ row.approved_factor_ref_handoff.owner_decision.status }}</span>
                  </span>
                </summary>
                <div class="readiness-compact-stack">
                  <code>action={{ row.approved_factor_ref_handoff.owner_decision.action }}</code>
                </div>
              </details>
              {% endif %}
              {% if row.scoped_authority_handoff %}
              <details class="readiness-summary-drilldown" data-testid="assetization-readiness-scoped-handoff" open>
                <summary>
                  <span class="decision-package-summary">
                    <strong>Scoped authority handoff</strong>
                    <span class="decision-package-filter">{{ row.scoped_authority_handoff.authority_review_status }}</span>
                    <span class="decision-package-filter evidence">evidence {{ row.scoped_authority_handoff.evidence_refs|length }} refs</span>
                  </span>
                </summary>
                <div class="readiness-compact-stack">
                  <code data-testid="assetization-readiness-scope-identity">scope={{ row.scoped_authority_handoff.instrument_scope_ref }}</code>
                  <code>universe={{ row.scoped_authority_handoff.universe_ref }}</code>
                  <code>asset_class={{ row.scoped_authority_handoff.asset_class }}</code>
                  <code>bar_frequency={{ row.scoped_authority_handoff.bar_frequency }}</code>
                  <code>authority_review_status={{ row.scoped_authority_handoff.authority_review_status }}</code>
                  <code>scope_applicability={{ row.scoped_authority_handoff.scope_applicability }}</code>
                  <code>package_freshness={{ row.scoped_authority_handoff.package_freshness }}</code>
                  <code>next_action={{ row.scoped_authority_handoff.display_next_action }}</code>
                  <code>linked_typed_evidence={{ row.scoped_authority_handoff.linked_typed_evidence_status }}</code>
                  {% if row.scoped_authority_handoff.blockers %}
                    {% for blocker in row.scoped_authority_handoff.blockers %}
                    <code>blocker={{ blocker }}</code>
                    {% endfor %}
                  {% else %}
                  <code>blockers=none</code>
                  {% endif %}
                  {% for evidence_ref in row.scoped_authority_handoff.evidence_refs %}
                  <code title="{{ evidence_ref }}">{{ evidence_ref }}</code>
                  {% endfor %}
                </div>
              </details>
              {% endif %}
              {% if row.portfolio_admission_candidate %}
              <details class="readiness-summary-drilldown" data-testid="assetization-readiness-portfolio-admission-candidate"{% if row.portfolio_admission_candidate.blockers or row.portfolio_admission_candidate.admission_candidate_status != "candidate_ready" %} open{% endif %}>
                <summary>
                  <span class="decision-package-summary">
                    <strong>{% if row.portfolio_admission_candidate.candidate_ready_basis == "research_backtest_candidate_ready" %}Research-view candidate{% else %}Portfolio admission candidate{% endif %}</strong>
                    <span class="decision-package-filter">{{ row.portfolio_admission_candidate.admission_candidate_status }}</span>
                    <span class="decision-package-filter evidence">evidence {{ row.portfolio_admission_candidate.evidence_refs|length }} refs</span>
                    {% if row.portfolio_admission_candidate.blockers %}
                    <span class="decision-package-filter exception">blockers {{ row.portfolio_admission_candidate.blockers|length }}</span>
                    {% endif %}
                  </span>
                </summary>
                <div class="readiness-compact-stack">
                  <code>admission_candidate_status={{ row.portfolio_admission_candidate.admission_candidate_status }}</code>
                  <code>candidate_ready_basis={{ row.portfolio_admission_candidate.candidate_ready_basis }}</code>
                  <code>research_backtest_readiness_status={{ row.portfolio_admission_candidate.research_backtest_readiness_status }}</code>
                  <code>authority_decision_status={{ row.portfolio_admission_candidate.authority_decision_status }}</code>
                  <code>instrument_scope_ref={{ row.portfolio_admission_candidate.instrument_scope_ref }}</code>
                  <code>factor_decision_package={{ row.portfolio_admission_candidate.factor_decision_package_status }}</code>
                  <code>portfolio_context_ref={{ row.portfolio_admission_candidate.portfolio_context_ref }}</code>
                  <code>capacity_ref={{ row.portfolio_admission_candidate.capacity_ref }}</code>
                  <code>liquidity_ref={{ row.portfolio_admission_candidate.liquidity_ref }}</code>
                  <code>risk_budget_ref={{ row.portfolio_admission_candidate.risk_budget_ref }}</code>
                  {% if row.backtestable_portfolio_package and row.portfolio_admission_candidate.candidate_ready_basis == "research_backtest_candidate_ready" %}
                  <code>handoff_state=superseded_by_backtestable_portfolio_package</code>
                  <code>candidate_next_action_completed={{ row.portfolio_admission_candidate.next_action }}</code>
                  {% else %}
                  <code>candidate_next_action={{ row.portfolio_admission_candidate.next_action }}</code>
                  {% endif %}
                  {% if row.portfolio_admission_candidate.blockers %}
                    {% for blocker in row.portfolio_admission_candidate.blockers %}
                    <code>blocker={{ blocker }}</code>
                    {% endfor %}
                  {% else %}
                  <code>blockers=none</code>
                  {% endif %}
                  {% for evidence_ref in row.portfolio_admission_candidate.evidence_refs %}
                  <code title="{{ evidence_ref }}">{{ evidence_ref }}</code>
                  {% endfor %}
                </div>
              </details>
              {% endif %}
            </td>
            <td>
              <div data-testid="assetization-readiness-next-action">
                <strong>{{ row.next_action_label }}</strong>
                <div class="assetization-readiness-meta"><code>{{ row.next_action_display_code }}</code> · owner={{ row.next_action_owner }}</div>
              </div>
              {% if row.evidence_refs %}
              <details class="readiness-evidence-details" data-testid="assetization-readiness-evidence-refs">
                <summary>Evidence {{ row.evidence_refs|length }} refs</summary>
                <div class="readiness-evidence-list">
                  {% for evidence_ref in row.evidence_refs %}
                  <code title="{{ evidence_ref }}">{{ evidence_ref }}</code>
                  {% endfor %}
                </div>
              </details>
              {% else %}
              <span style="color:#98a2ad">—</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
      </div>
      {% else %}
      <p class="assetization-readiness-scope-note" data-testid="generated-package-evidence-empty">No materialized package evidence. Candidate readiness matrix carries package gaps and next actions.</p>
      {% endif %}
    </section>
  </section>
  {% endif %}
  {%- endmacro %}

  {% if rows %}
  <div class="table-wrap" data-testid="factor-board-table-wrap">
    <table id="factor-board-table" class="factor-table{% if not has_prescreen_content %} prescreen-empty{% endif %}">
      <thead>
        <tr>
          <th data-col-group="identity">因子 Key / Factor Key</th>
          <th data-col-group="identity">
            <div class="row-type-header">
              <span>记录类型 / Row Type</span>
              <select
                class="row-type-filter"
                data-row-kind-filter
                data-testid="factor-board-row-type-filter"
                aria-label="记录类型筛选 / Row Type filter">
                <option value="all">全部 / All</option>
                <option value="factor_asset">因子结论 / Factor Conclusion</option>
                <option value="trial_evidence">回测证据 / Backtest Evidence</option>
                <option value="planned_factor">计划因子 / Planned Factor</option>
              </select>
            </div>
          </th>
          <th data-col-group="identity">名称 / Name</th>
          <th data-col-group="identity">状态 / State</th>
          <th data-col-group="input" class="col-group-hidden">市场 / Market</th>
          <th data-col-group="input" class="col-group-hidden">频率 / Frequency</th>
          <th data-col-group="input" class="col-group-hidden">参数 / Params</th>
          <th data-col-group="evidence">试验 Run / Source Runs</th>
          <th data-col-group="evidence">初筛 / Prescreen</th>
          <th data-col-group="evidence">正式验收 / Final</th>
          <th data-col-group="decision" class="col-group-hidden">组合使用 / Composite</th>
          <th data-col-group="decision" class="col-group-hidden">人工决策 / Decision</th>
          <th data-col-group="decision" class="col-group-hidden">下一动作 / Next Action</th>
          <th data-col-group="decision" class="col-group-hidden">判断原因 / Reason</th>
          <th data-col-group="evidence">证据 / Evidence</th>
        </tr>
      </thead>
      <tbody>
      {% for row in rows %}
        {% set prescreen_perf = row.performance_by_stage.prescreen %}
        {% set final_perf = row.performance_by_stage.final %}
        {% set final_metrics_available = final_perf and final_perf.metrics_available %}
        {% set prescreen_metrics_available = prescreen_perf and prescreen_perf.metrics_available %}
        {% set prescreen_missing_reason = prescreen_perf.missing_reason if prescreen_perf and prescreen_perf.missing_reason else "" %}
        {% set prescreen_missing_reason_lower = prescreen_missing_reason|lower %}
        {% set prescreen_is_scoped_authority_handoff = prescreen_perf and (prescreen_perf.scoped_authority_handoff_evidence or "scoped authority handoff" in prescreen_missing_reason_lower) %}
        {% set final_missing_reason = final_perf.missing_reason if final_perf and final_perf.missing_reason else "" %}
        {% set final_missing_reason_lower = final_missing_reason|lower %}
        {% set final_is_scoped_authority_handoff = final_perf and (final_perf.scoped_authority_handoff_evidence or "scoped authority handoff" in final_missing_reason_lower) %}
        {% set final_missing_is_retained_only = final_missing_reason and ("retained final" in final_missing_reason) %}
        {% set final_missing_is_prescreen_not_retained = (final_missing_reason and ("not retained for final" in final_missing_reason_lower or "未进入 retained final" in final_missing_reason)) or (row.row_kind == "trial_evidence" and ((not final_perf) and prescreen_perf and prescreen_perf.metrics_available and not row.final_validated_trial_id)) %}
        {% set final_missing_is_claim_proof_blocked = row.final_missing_is_claim_proof_blocked %}
        {% set final_missing_is_factor_not_retained = row.row_kind == "factor_asset" and (not row.final_validated_trial_id) and row.usable_status in ["needs_final_validation", "blocked_missing_final_evidence"] and not final_missing_is_claim_proof_blocked %}
        {% set final_missing_is_asset_gap = row.row_kind == "factor_asset" and (not final_perf or (not final_metrics_available and not final_is_scoped_authority_handoff)) %}
        {% if row.validation_verdict == "final_pass" %}
          {% set formal_outcome_class = "formal-pass" %}
        {% elif row.validation_verdict == "final_fail" %}
          {% set formal_outcome_class = "formal-fail" %}
        {% else %}
          {% set formal_outcome_class = "formal-pending" %}
        {% endif %}
        <tr class="{% if row.is_deemphasized %}deemphasized {% endif %}"
            data-state="{{ row.candidate_state }}"
            data-row-kind="{{ row.row_kind }}"
            data-factor-key="{{ row.factor_key }}"
            data-case-ref="{{ row.case_ref or row.representative_params.case_ref if row.representative_params else row.case_ref or '' }}"
            data-trial-id="{{ row.final_validated_trial_id or row.trial_id or row.best_run_id or '' }}"
            data-decision-actionability="{{ row.decision_facet.actionability if row.decision_facet else '' }}"
            data-formal-verdict="{{ row.decision_facet.formal_verdict if row.decision_facet else '' }}"
            data-decision-handle-hash="{{ row.decision_handle.decision_facet_hash if row.decision_handle else '' }}"
            data-asset-decision-state="{{ row.lifecycle_decision_status or 'no_decision' }}"
            data-global-inclusion-state="{{ row.global_inclusion_state or 'not_included' }}"
            data-testid="{{ row.testid }}"
             id="{{ row.row_testid }}">
          <td data-col-group="identity"><code>{{ row.factor_key }}</code></td>
          <td data-col-group="identity" data-testid="c-ready-semantic-layer">
            <div class="semantic-stack">
              <span class="semantic-kind {% if row.row_kind == 'factor_asset' %}asset{% elif row.row_kind == 'trial_evidence' %}trial{% else %}planned{% endif %}" data-testid="c-ready-row-kind">{{ row.row_kind_label }}</span>
              <span class="semantic-line" data-testid="c-ready-evidence-role">{{ row.evidence_role_label }}</span>
              <span class="semantic-line" data-testid="c-ready-usable-status">{{ row.usable_status_label }}</span>
              {% if row.trial_id %}<span class="semantic-line">trial_id=<code>{{ row.trial_id }}</code></span>{% endif %}
              {% if row.prescreen_winner_trial_id %}<span class="semantic-line">prescreen=<code style="word-break:break-all;max-width:18ch;display:inline-block;vertical-align:top">{{ row.prescreen_winner_trial_id }}</code></span>{% endif %}
              {% if row.final_validated_trial_id %}<span class="semantic-line">final=<code>{{ row.final_validated_trial_id }}</code></span>{% endif %}
              {% if row.blocking_gaps %}<span class="semantic-line">gap=<code>{{ row.blocking_gaps | join(',') }}</code></span>{% endif %}
            </div>
            {% if row.factor_journey %}
            <details class="factor-journey" data-testid="factor-journey-detail-{{ row.factor_key }}">
              <summary data-testid="factor-journey-open-{{ row.factor_key }}">因子旅程 / Factor Journey</summary>
              <div class="factor-journey-body">
                <div class="factor-journey-business" data-testid="factor-journey-business-summary">
                  <span><strong>Rationale:</strong> {{ row.factor_journey.rationale }}</span>
                  <span><strong>Scope:</strong> case_ref={{ row.factor_journey.case_ref }}; validation_plan={{ row.factor_journey.validation_plan_id }}; market={{ row.factor_journey.market_scope | join(',') if row.factor_journey.market_scope else 'not_surfaced' }}; frequency={{ row.factor_journey.frequency_scope | join(',') if row.factor_journey.frequency_scope else 'not_surfaced' }}</span>
                  <span><strong>Business triage:</strong> readiness={{ row.factor_journey.readiness_status }}; blocker={{ row.factor_journey.blockers | join(',') }}; next={{ row.factor_journey.next_action }}</span>
                  <span><strong>Portfolio boundary:</strong> {{ row.factor_journey.portfolio_boundary }}</span>
                  <span><strong>Overlap context:</strong> {{ row.factor_journey.uniqueness_context }}</span>
                </div>
                <div class="factor-journey-grid">
                  {% for stage in row.factor_journey.stages %}
                  <div class="factor-journey-item" data-testid="factor-journey-stage-{{ stage.label | lower | replace(' ', '-') }}">
                    <span class="factor-journey-label">{{ stage.label }}</span>
                    <span class="factor-journey-value">{{ stage.status }}</span>
                    <span class="factor-journey-detail">{{ stage.detail }}</span>
                  </div>
                  {% endfor %}
                </div>
              </div>
            </details>
            {% endif %}
          </td>
          <td data-col-group="identity">{{ row.factor_name }}</td>
          <td data-col-group="identity">
            <div class="state-owner-row">
              <span class="state-owner-label" data-testid="factor-board-lifecycle-state-label">Lifecycle:</span>
              <span class="state-badge {{ row.candidate_state_badge.class }}"
                    data-state="{{ row.candidate_state_badge.data_state }}"
                    data-testid="{{ row.candidate_state_badge.testid }}">
                {{ row.candidate_state }}
              </span>
            </div>
            <div class="state-owner-row">
              <span class="state-owner-label" data-testid="factor-board-formal-state-label">Formal:</span>
              <span class="formal-outcome {{ formal_outcome_class }}" data-testid="formal-outcome-badge">{{ row.validation_verdict_label }}</span>
            </div>
            {% if row.assurance_state %}
            <div class="state-owner-row">
              <span class="state-owner-label" data-testid="factor-board-assurance-state-label">Assurance:</span>
              <button
                class="assurance-row-button {{ row.assurance_state_class }}"
                type="button"
                data-assurance-open
                data-assurance-row="{{ row.factor_key }}"
                data-testid="factor-board-row-assurance-state">
                {{ row.assurance_state_label }}
              </button>
            </div>
            {% if row.assurance_primary_blocker %}
            <div class="state-owner-row state-owner-detail"><span class="state-owner-label">blocker:</span><code class="assurance-blocker" data-assurance-open data-assurance-row="{{ row.factor_key }}" data-testid="factor-board-row-assurance-blocker">{{ row.assurance_primary_blocker }}</code></div>
            {% endif %}
            {% endif %}
            {% if row.row_verifier %}
            <div class="state-owner-row">
              <span class="state-owner-label" data-testid="factor-board-row-verifier-state-label">Row verifier:</span>
              <button
                class="assurance-row-button {{ row.row_verifier.state_class }}"
                type="button"
                data-assurance-open
                data-assurance-detail="row-verifier"
                data-assurance-row="{{ row.factor_key }}"
                data-testid="factor-board-row-verifier-state">
                {{ row.row_verifier.state_label }}
              </button>
            </div>
            {% if row.row_verifier.primary_rule %}
            <div class="state-owner-row state-owner-detail"><span class="state-owner-label">blocker:</span><code class="assurance-blocker" data-assurance-open data-assurance-detail="row-verifier" data-assurance-row="{{ row.factor_key }}" data-testid="factor-board-row-verifier-primary-rule">{{ row.row_verifier.primary_rule }}</code></div>
            {% endif %}
            {% if row.row_verifier.root_cause_hint_zh and row.row_verifier.state != "verified" %}
            <div class="state-owner-row state-owner-detail"><span class="state-owner-label">root cause:</span><span class="semantic-line" data-testid="factor-board-row-verifier-root-cause">{{ row.row_verifier.root_cause_hint_zh }}</span></div>
            {% endif %}
            {% if row.row_verifier.next_action and row.row_verifier.state != "verified" %}
            <div class="state-owner-row state-owner-detail"><span class="state-owner-label">next action:</span><span class="semantic-line" data-testid="factor-board-row-verifier-next-action">{{ row.row_verifier.next_action_zh or row.row_verifier.next_action }}</span></div>
            {% endif %}
            {% endif %}
          </td>
          <td data-col-group="input" class="col-group-hidden">
            {% for scope in row.market_scope %}<span class="chip">{{ scope }}</span>{% endfor %}
            {% if not row.market_scope %}<span style="color:#98a2ad">—</span>{% endif %}
          </td>
          <td data-col-group="input" class="col-group-hidden">
            {% for mode in row.execution_modes %}<span class="chip chip-mode">{{ mode }}</span>{% endfor %}
            {% for freq in row.frequency_scope %}<span class="chip chip-freq">{{ freq }}</span>{% endfor %}
            {% if not row.execution_modes and not row.frequency_scope %}<span style="color:#98a2ad">—</span>{% endif %}
          </td>
          <td data-col-group="input" class="col-group-hidden" data-testid="{{ row.field_testids.get('representative_params', '') }}">
            {% if row.representative_params %}
              <div class="param-list">
              {% for key, value in row.representative_params.items() %}
                <span class="chip">{{ key }}={{ value }}</span>
              {% endfor %}
              </div>
            {% else %}
              <span style="color:#98a2ad">—</span>
            {% endif %}
          </td>
          <td data-col-group="evidence" data-testid="source-run-ids">
            {% if row.source_run_links %}
              <div class="source-list">
              {% for source_run in row.source_run_links %}
                {% set is_best_run = row.best_run_id and source_run.run_id == row.best_run_id %}
                <a class="run-link{% if is_best_run %} run-link-best{% endif %}" href="{{ source_run.href }}" data-testid="{% if is_best_run %}best-run-id-link source-run-id-link{% else %}source-run-id-link{% endif %}"><code>{{ source_run.run_id }}</code>{% if is_best_run %}<span class="run-best-label">Selected</span>{% endif %}</a>
              {% endfor %}
              {% if row.best_run_id and (row.best_run_id not in (row.source_run_links | map(attribute='run_id') | list)) %}
