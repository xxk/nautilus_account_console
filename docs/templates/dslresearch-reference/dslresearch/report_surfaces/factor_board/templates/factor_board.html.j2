  <h2 class="factor-board-table-title" data-testid="factor-board-table-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="factor-board-table-case-ref">{{ display_case_ref }}</span>{% endif %}因子表格 / Factor Board</h2>
  <p class="factor-board-table-subtitle">按状态过滤行，按列组展开输入、证据和决策信息。</p>
  <div class="toolbar" id="factor-board-toolbar">
    <span class="toolbar-label">过滤状态 / Filter State:</span>
    <button class="filter-chip" data-testid="factor-board-include-retired-toggle" style="display:none">含退役</button>
    <button class="filter-chip active" data-state="all" onclick="filterBoard('all')">全部 / All <span class="count-badge" id="count-all">{{ candidate_count }}</span></button>
    {% for state in ["proposed", "tested", "retained", "promoted", "composite_candidate", "accepted", "rejected", "retired"] %}
    {% set state_label_map = {
      "proposed": "提案 / Proposed",
      "tested": "已测试 / Tested",
      "retained": "保留 / Retained",
      "promoted": "晋升 / Promoted",
      "composite_candidate": "组合候选 / Composite",
      "accepted": "验收通过 / Accepted",
      "rejected": "已拒绝 / Rejected",
      "retired": "已退役 / Retired"
    } %}
    {% set count = rows | selectattr("candidate_state", "equalto", state) | list | length %}
    {% if count > 0 %}
    <button class="filter-chip" data-state="{{ state }}" onclick="filterBoard('{{ state }}')">{{ state_label_map[state] }} <span class="count-badge" id="count-{{ state }}">{{ count }}</span></button>
    {% endif %}
    {% endfor %}
    <span class="toolbar-label">列组 / Columns:</span>
    <button class="filter-chip active" type="button" data-col-group-toggle="identity" aria-pressed="true">Identity</button>
    <button class="filter-chip" type="button" data-col-group-toggle="input" aria-pressed="false">Input</button>
    <button class="filter-chip active" type="button" data-col-group-toggle="evidence" aria-pressed="true">Evidence</button>
    <button class="filter-chip" type="button" data-col-group-toggle="decision" aria-pressed="false">Decision</button>
  </div>

  {% macro assetization_readiness_gate_section(assetization_readiness_gate) -%}
  {% if assetization_readiness_gate %}
  <section class="assetization-readiness" id="assetization-readiness-gate" data-testid="factor-board-assetization-readiness-gate">
    <div class="assetization-readiness-header">
      <div>
        <h2 class="assetization-readiness-title">{% if filter_case_id and display_case_ref %}<span class="case-ref-badge" data-testid="assetization-readiness-gate-case-ref">{{ display_case_ref }}</span>{% endif %}资产准备 / Assetization Readiness Gate</h2>
        <p class="assetization-readiness-meta" data-testid="assetization-readiness-gate-breadcrumb">Factor Lifecycle Board &gt; Asset Preparation</p>
      </div>
      <div class="assetization-readiness-meta">
        schema v{{ assetization_readiness_gate.schema_version }} · generated <code>{{ assetization_readiness_gate.generated_at }}</code>
      </div>
    </div>
    <div class="assetization-readiness-summary" data-testid="assetization-readiness-gate-summary">
      <div class="assetization-readiness-summary-item"><span class="assetization-readiness-summary-label">State</span><span class="assetization-readiness-summary-value" data-testid="assetization-readiness-gate-state"><span class="rule-status {{ assetization_readiness_gate.state|string|lower|replace('_', '-') }}">{{ assetization_readiness_gate.state }}</span></span></div>
      <div class="assetization-readiness-summary-item"><span class="assetization-readiness-summary-label">Primary Check</span><span class="assetization-readiness-summary-value">{{ assetization_readiness_gate.primary_check }}</span></div>
      <div class="assetization-readiness-summary-item"><span class="assetization-readiness-summary-label">Primary Reason</span><span class="assetization-readiness-summary-value">{{ assetization_readiness_gate.primary_reason }}</span></div>
      <div class="assetization-readiness-summary-item"><span class="assetization-readiness-summary-label">Next Action</span><span class="assetization-readiness-summary-value">{{ assetization_readiness_gate.next_action }}</span></div>
    </div>
    {% set gate_check_counts = namespace(pass=0, gap=0) %}
    {% for check in assetization_readiness_gate.required_checks %}
      {% if (check.status|string|lower) == "pass" %}
        {% set gate_check_counts.pass = gate_check_counts.pass + 1 %}
      {% else %}
        {% set gate_check_counts.gap = gate_check_counts.gap + 1 %}
      {% endif %}
    {% endfor %}
    <div class="assetization-gate-check-summary" data-testid="assetization-readiness-gate-check-summary">
      <span class="assetization-gate-check-summary-label">Required checks</span>
      <span class="readiness-status pass">PASS {{ gate_check_counts.pass }}</span>
      <span class="readiness-status {% if gate_check_counts.gap > 0 %}blocked{% else %}ready{% endif %}">Gaps {{ gate_check_counts.gap }}</span>
    </div>
    <details class="assetization-gate-check-details" data-testid="assetization-readiness-gate-check-details"{% if gate_check_counts.gap > 0 %} open{% endif %}>
      <summary>Required checks {{ assetization_readiness_gate.required_checks|length }} total</summary>
      <div class="assetization-readiness-scroll">
        <table class="assetization-readiness-table" data-testid="assetization-readiness-gate-check-table">
          <thead>
            <tr>
              <th>检查 / Check</th>
              <th>状态 / Status</th>
              <th>原因 / Reason</th>
