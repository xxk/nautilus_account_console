<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <title>{{ report_title }}</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 24px 28px; background: #f6f8fa; color: #1f2328; font-family: Segoe UI, Microsoft YaHei, sans-serif; }
        .shell { max-width: 1200px; margin: 0 auto; }
        .hero, .card { background: #fff; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.08); padding: 18px 20px; margin-bottom: 16px; }
        .eyebrow { font-size: .78rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: #57606a; margin: 0 0 4px; }
        .meta, .boundary { color: #57606a; line-height: 1.8; }
        .summary-pills { display: flex; flex-wrap: wrap; gap: 8px; }
        .pill { display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 999px; background: #eef2f6; color: #44505c; border: 1px solid #d0d7de; font-size: .76rem; font-weight: 700; }
        .pill.retained { background: #dafbe1; color: #116329; border-color: #aee5b8; }
        .pill.rejected { background: #ffebe9; color: #82071e; border-color: #ffcecb; }
        .pill.promoted { background: #ddf4ff; color: #0550ae; border-color: #a8d8ea; }
        .pill.retired { background: #f6e3ce; color: #7a4800; border-color: #eac88c; }
        .portal-link { display: inline-flex; align-items: center; justify-content: center; min-height: 38px; padding: 8px 14px; border-radius: 10px; border: 1px solid rgba(9,105,218,.16); background: #fff; color: #0969da; text-decoration: none; font-weight: 600; }
        .portal-link.primary { background: #0969da; color: #fff; border-color: #0969da; }
        .portal-link.secondary { background: #f6f8fa; color: #24507a; border-color: #d0d7de; }
        .factor-table { width: 100%; border-collapse: collapse; margin-top: 12px; }
        .factor-table th, .factor-table td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #eaecef; vertical-align: top; font-size: .88rem; }
        .factor-table th { color: #57606a; background: #f6f8fa; position: sticky; top: 0; }
        .run-link { display: inline-block; margin-right: 6px; color: #0969da; text-decoration: none; font-size: .82rem; }
        .empty { color: #6b7280; font-style: italic; }
    </style>
</head>
<body>
    <div class="shell">
        <section class="hero">
            <p class="eyebrow">knowledge workspace</p>
            <h1>{{ title }}</h1>
            <div class="meta">{{ subtitle }}</div>
            {% if has_projection and stats %}
            <div class="summary-pills" style="margin-top: 12px;">
                <span class="pill">total={{ stats.total }}</span>
                {% for status_name, count in stats.by_status.items() %}
                <span class="pill {{ status_name }}">{{ status_name }}={{ count }}</span>
                {% endfor %}
                <span class="pill">generated={{ stats.generated_at }}</span>
            </div>
            {% endif %}
            <div style="margin-top: 14px;">
                <a class="portal-link secondary" href="{{ dev_home_uri }}">研发首页 / Dev Home</a>
            </div>
        </section>

        {% if not has_projection %}
        <section class="card">
            <h2>Unavailable</h2>
            <div class="empty">当前没有 factor_candidate_projection，Knowledge Workspace 暂时不可用。请先运行 sync-control-plane 或 run-research 以生成 projection。</div>
        </section>
        {% else %}
        <section class="card">
            <h2>Factor Candidates</h2>
            <div class="boundary">以下条目来自 factor_candidate_projection 的只读投影——展示每个 case 的因子命运、决策原因与来源 run。</div>
            {% if candidate_rows %}
            <table class="factor-table">
                <thead>
                    <tr>
                        <th>Case</th>
                        <th>Factor</th>
                        <th>Op</th>
                        <th>Status</th>
                        <th>Decision Reason</th>
                        <th>Source Runs</th>
                        <th>Updated</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in candidate_rows %}
                    <tr>
                        <td>
                            {% if row.case_href %}
                            <a href="{{ row.case_href }}">{{ row.case_id }}</a>
                            {% else %}
                            {{ row.case_id }}
                            {% endif %}
                        </td>
                        <td>{{ row.factor_name }}</td>
                        <td>{{ row.factor_op }}</td>
                        <td><span class="pill {{ row.status }}">{{ row.status }}</span></td>
                        <td>{{ row.decision_reason }}</td>
                        <td>
                            {% for link in row.run_links %}
                            {% if link.href %}
                            <a class="run-link" href="{{ link.href }}">{{ link.run_id }}</a>
                            {% else %}
                            <span class="run-link">{{ link.run_id }}</span>
                            {% endif %}
                            {% endfor %}
                            {% if not row.run_links %}
                            <span class="empty">-</span>
                            {% endif %}
                        </td>
                        <td>{{ row.updated_at }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="empty" style="margin-top: 14px;">factor_candidate_projection 存在，但没有符合条件的 candidate 条目。</div>
            {% endif %}
        </section>
        {% endif %}
    </div>
</body>
</html>
